' Gambas class file


PUBLIC SUB Form_Open()
  ' L'orario lo imposta setOrario PRIMA di ShowModal: non azzerarlo qui.
  FArrivo.Center()
END

PUBLIC SUB setOrario(Orario AS String)
  
  Label1.Text = Orario
  
END

PUBLIC SUB Label1_MouseDown()

  

END

PUBLIC SUB Button1_Click()

DIM Numero AS Integer
DIM Confermato AS Boolean
Confermato = FALSE
Numero = 0
TRY Numero = TextBox1.Text
IF Numero > 0 AND Numero < 10000 THEN 
IF FMain.ReturnArrivo(Numero) <> 0 THEN 
IF Message.Question("L'equipaggio " & Numero & " risulta essere già arrivato! Si desidera sostituire il suo orario di arrivo con questo?", "Sì", "No") = 1 THEN
Confermato = TRUE
ENDIF 
ELSE 
Confermato = TRUE
ENDIF 
IF Confermato = TRUE THEN
FMain.SetArrivo(Numero, Label1.Text)
Try MLog.Write("arrivo", "numero=" & CStr(Numero) & " orario=" & Label1.Text)
FArrivo.Close
ENDIF
ELSE
Message("Numero non riconosciuto!")
Try MLog.Write("arrivo_numero_invalido", "input=" & TextBox1.Text & " orario=" & Label1.Text)
ENDIF
END

PUBLIC SUB Button2_Click()
  IF FMain.ConfermaScartoOrario("arrivo") THEN
    Try MLog.Write("scarto_orario", "tipo=arrivo orario=" & Label1.Text)
    FArrivo.Close
  ENDIF
END

    }
    { Label12 Label
      MoveScaled(44,28,21,3)
      Text = ("Arrivo UNIX ms")
    }
    { TextArrUnix TextBox
      MoveScaled(65,28,8,3)
      Text = ("")
    }
    { Label13 Label
      MoveScaled(1,32,32,3)

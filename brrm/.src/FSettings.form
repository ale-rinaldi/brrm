      MoveScaled(1,4,21,3)
      Text = ("File credenziali JSON")
    }
    { TextCred TextBox
      MoveScaled(23,4,40,3)
      Text = ("")
    }
    { ButtonBrowse Button
      MoveScaled(64,4,9,3)
      Text = ("Sfoglia…")
    }
    { Label6 Label
      MoveScaled(1,8,21,3)
      Text = ("ID documento")
    }
    { TextDocId TextBox
      MoveScaled(23,8,50,3)
      Text = ("")
    }
    { Label7 Label
      MoveScaled(1,12,21,3)
      Text = ("Nome foglio (scheda)")
    }
    { TextSheetName TextBox
      MoveScaled(23,12,50,3)
      Text = ("")
    }
    { Label8 Label
      MoveScaled(1,16,21,3)
      Text = ("Colonna equipaggio")
    }
    { TextEqCol TextBox
      MoveScaled(23,16,8,3)
      Text = ("A")
    }
    { LabelHeaderRows Label
      MoveScaled(34,16,22,3)
      Text = ("Righe di intestazione")
    }
    { TextHeaderRows TextBox
      MoveScaled(57,16,6,3)
      Text = ("1")
    }
    { LabelOptHint Label
      MoveScaled(1,20,72,3)
      Foreground = &H666666&
      Text = ("Colonne opzionali (vuoto = disattivata). Per i range split indica la prima colonna.")
    }
    { Label9 Label
      MoveScaled(1,24,32,3)
      Text = ("Partenza split (h, m, s, ms)")
    }
    { TextPartSplit TextBox
      MoveScaled(34,24,8,3)
      Text = ("")
    }
    { Label10 Label
      MoveScaled(44,24,21,3)
      Text = ("Partenza UNIX ms")
    }
    { TextPartUnix TextBox
      MoveScaled(65,24,8,3)
      Text = ("")
    }
    { Label11 Label
      MoveScaled(1,28,32,3)
      Text = ("Arrivo split (h, m, s, ms)")

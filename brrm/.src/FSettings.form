# Gambas Form File 3.0

{ Form Form
  MoveScaled(0,0,76,80)
  Text = ("Impostazioni")
  { FrameSync Frame
    MoveScaled(1,1,74,26)
    Text = ("Sincronizzazione")
    { Label1 Label
      MoveScaled(1,4,15,3)
      Text = ("URL")
    }
    { TextURL TextBox
      MoveScaled(17,4,56,3)
      Text = ("")
    }
    { Label2 Label
      MoveScaled(1,8,15,3)
      Text = ("Username")
    }
    { TextUser TextBox
      MoveScaled(17,8,56,3)
      Text = ("")
    }
    { Label3 Label
      MoveScaled(1,12,15,3)
      Text = ("Password")
    }
    { TextPass TextBox
      MoveScaled(17,12,56,3)
      Text = ("")
      Password = True
    }
    { Label4 Label
      MoveScaled(1,16,15,3)
      Text = ("Session")
    }
    { TextSession TextBox
      MoveScaled(17,16,56,3)
      Text = ("default")
    }
    { LabelSyncHint Label
      MoveScaled(1,20,72,5)
      Foreground = &H666666&
      Text = ("La stessa session su partenza e arrivo. Campi vuoti = sync disattivo.")
    }
  }
  { FrameSheet Frame
    MoveScaled(1,28,74,45)

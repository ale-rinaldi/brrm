' Gambas class file

' Form di configurazione runtime: 3 tab — sync (align.conf), foglio
' Google (sheet.conf), registro di gara (log.conf).

Public Sub Form_Open()
  FSettings.Center()
  LoadSyncConfig()
  LoadSheetConfig()
  LoadLogConfig()
End

Private Sub LoadSyncConfig()
  Dim sPath As String
  TextURL.Text = ""
  TextUser.Text = ""
  TextPass.Text = ""
  TextSession.Text = "default"
  sPath = User.Home &/ ".config/brrm/align.conf"
  If Not Exist(sPath) Then Return
  ReadKvFile(sPath, ["url", "username", "password", "session"], [TextURL, TextUser, TextPass, TextSession])
End

Private Sub LoadSheetConfig()
  Dim sPath As String
  TextCred.Text = ""
  TextDocId.Text = ""
  TextSheetName.Text = ""
  TextEqCol.Text = "A"
  TextHeaderRows.Text = "1"
  TextPartSplit.Text = ""
  TextPartUnix.Text = ""
  TextArrSplit.Text = ""
  TextArrUnix.Text = ""
  TextTempoSplit.Text = ""
  TextTempoMs.Text = ""
  sPath = User.Home &/ ".config/brrm/sheet.conf"
  If Not Exist(sPath) Then Return
  ReadKvFile(sPath, ["credentials", "document_id", "sheet_name", "equipaggio_column", "header_rows", "partenza_split_column", "partenza_unixms_column", "arrivo_split_column", "arrivo_unixms_column", "tempo_split_column", "tempo_ms_column"], [TextCred, TextDocId, TextSheetName, TextEqCol, TextHeaderRows, TextPartSplit, TextPartUnix, TextArrSplit, TextArrUnix, TextTempoSplit, TextTempoMs])
End

Private Sub LoadLogConfig()
  Dim sPath As String
  Dim sLine, sKey, sVal As String
  Dim iEq As Integer
  CheckLogEnabled.Value = False
  TextLogPath.Text = "~/race-log.txt"
  sPath = User.Home &/ ".config/brrm/log.conf"
  If Not Exist(sPath) Then Return
  For Each sLine In Split(File.Load(sPath), gb.NewLine)
    sLine = Trim$(sLine)
    If sLine = "" Or If Left$(sLine, 1) = "#" Then Continue
    iEq = InStr(sLine, "=")
    If iEq < 2 Then Continue
    sKey = LCase$(Trim$(Left$(sLine, iEq - 1)))
    sVal = Trim$(Mid$(sLine, iEq + 1))
    Select Case sKey
      Case "enabled"
        CheckLogEnabled.Value = (LCase$(sVal) = "true" Or sVal = "1")
      Case "path"
        TextLogPath.Text = sVal
    End Select
  Next
End

Private Sub ReadKvFile(sPath As String, keys As String[], controls As Object[])
  ' Parser key=value molto semplice, ignora commenti #.
  Dim sLine, sKey, sVal As String
  Dim iEq, iKey As Integer
  For Each sLine In Split(File.Load(sPath), gb.NewLine)
    sLine = Trim$(sLine)
    If sLine = "" Or If Left$(sLine, 1) = "#" Then Continue
    iEq = InStr(sLine, "=")
    If iEq < 2 Then Continue
    sKey = LCase$(Trim$(Left$(sLine, iEq - 1)))
    sVal = Trim$(Mid$(sLine, iEq + 1))
    iKey = keys.Find(sKey)
    If iKey >= 0 Then controls[iKey].Text = sVal
  Next
End

Public Sub ButtonBrowse_Click()
  Dialog.Title = "Seleziona file credenziali Service Account (.json)"
  Dialog.Filter = ["*.json", "File JSON"]
  If Dialog.OpenFile() Then Return  ' annullato
  TextCred.Text = Dialog.Path
End

Public Sub ButtonSave_Click()
  Dim sDir As String
  sDir = User.Home &/ ".config/brrm"
  If Not Exist(sDir) Then Try Mkdir sDir
  If Not SaveSyncConfig(sDir &/ "align.conf") Then Return
  If Not SaveSheetConfig(sDir &/ "sheet.conf") Then Return
  If Not SaveLogConfig(sDir &/ "log.conf") Then Return
  Try FMain.AlignReinit()
  Try FMain.SheetReinit()
  Try FMain.LogReinit()
  Me.Close
End

Private Function SaveLogConfig(sPath As String) As Boolean
  Dim sOut As String
  If CheckLogEnabled.Value Then
    sOut = "enabled = true" & gb.NewLine
  Else
    sOut = "enabled = false" & gb.NewLine
  Endif
  sOut &= "path = " & Trim$(TextLogPath.Text) & gb.NewLine
  Try MFile.AtomicSave(sPath, sOut)
  If Error Then
    Message.Error("Impossibile salvare log.conf: " & Error.Text)
    Return False
  Endif
  Return True
End

Private Function SaveSyncConfig(sPath As String) As Boolean
  Dim sOut As String
  sOut = "url = " & Trim$(TextURL.Text) & gb.NewLine
  sOut &= "username = " & Trim$(TextUser.Text) & gb.NewLine
  sOut &= "password = " & Trim$(TextPass.Text) & gb.NewLine
  sOut &= "session = " & Trim$(TextSession.Text) & gb.NewLine
  Try MFile.AtomicSave(sPath, sOut)
  If Error Then
    Message.Error("Impossibile salvare align.conf: " & Error.Text)
    Return False
  Endif
  Return True
End

Private Function SaveSheetConfig(sPath As String) As Boolean
  Dim sOut As String
  sOut = "credentials = " & Trim$(TextCred.Text) & gb.NewLine
  sOut &= "document_id = " & Trim$(TextDocId.Text) & gb.NewLine
  sOut &= "sheet_name = " & Trim$(TextSheetName.Text) & gb.NewLine
  sOut &= "equipaggio_column = " & UCase$(Trim$(TextEqCol.Text)) & gb.NewLine
  sOut &= "header_rows = " & Trim$(TextHeaderRows.Text) & gb.NewLine
  sOut &= "partenza_split_column = " & UCase$(Trim$(TextPartSplit.Text)) & gb.NewLine
  sOut &= "partenza_unixms_column = " & UCase$(Trim$(TextPartUnix.Text)) & gb.NewLine
  sOut &= "arrivo_split_column = " & UCase$(Trim$(TextArrSplit.Text)) & gb.NewLine
  sOut &= "arrivo_unixms_column = " & UCase$(Trim$(TextArrUnix.Text)) & gb.NewLine
  sOut &= "tempo_split_column = " & UCase$(Trim$(TextTempoSplit.Text)) & gb.NewLine
  sOut &= "tempo_ms_column = " & UCase$(Trim$(TextTempoMs.Text)) & gb.NewLine
  Try MFile.AtomicSave(sPath, sOut)
  If Error Then
    Message.Error("Impossibile salvare sheet.conf: " & Error.Text)
    Return False
  Endif
  Return True
End

Public Sub ButtonCancel_Click()
  Me.Close
End

' Gambas class file


PUBLIC SUB Button1_Click()
DIM Numero AS Integer
DIM Confermato AS Boolean
DIM Orario AS Date
Orario = 0
TRY Orario = TextBox2.Text
IF Orario <> 0 THEN
Confermato = FALSE
Numero = 0
TRY Numero = TextBox1.Text
IF Numero > 0 AND Numero < 10000 THEN 
IF FMain.LEquipaggi.Find(Numero) < 0 THEN 
FMain.LEquipaggi.Add(Numero)
ENDIF 
IF FMain.ReturnPartenza(Numero) <> 0 THEN 
IF Message.Question("L'equipaggio " & Numero & " risulta essere già partito! Si desidera sostituire il suo orario di partenza con questo?", "Sì", "No") = 1 THEN
Confermato = TRUE
ENDIF 
ELSE 
Confermato = TRUE
ENDIF 
IF Confermato = TRUE THEN
FMain.SetPartenza(Numero, Orario)
Try MLog.Write("partenza_manuale", "numero=" & CStr(Numero) & " orario=" & TextBox2.Text)
FPartenza.Close
ENDIF
ELSE
Message("Numero non riconosciuto!")
Try MLog.Write("partenza_manuale_numero_invalido", "input=" & TextBox1.Text & " orario=" & TextBox2.Text)
ENDIF
ELSE
Message("Orario non riconosciuto!")
Try MLog.Write("partenza_manuale_orario_invalido", "input=" & TextBox2.Text)
ENDIF
END

PUBLIC SUB Button2_Click()
  IF FMain.ConfermaScartoOrario("partenza") THEN
    Try MLog.Write("scarto_orario", "tipo=partenza_manuale orario=" & TextBox2.Text)
    FPartenza.Close
  ENDIF
END

PUBLIC SUB Form_Open()

  FPartenza.Center()
  TextBox1.Text = ""
  TextBox2.Text = ""

END

PUBLIC SUB TextBox2_KeyPress()

  

END

' Gambas class file

' CSheet - Integrazione Google Sheets per brrm (postazione arrivo).
'
' Logica isolata in una classe a sé: FMain crea una sola istanza, la chiama
' su ogni evento rilevante (arrivo, annullamento, cambio numero, etc.) e
' lascia che si arrangi col resto (auth JWT, find row, batch update) in
' modo asincrono e fire-and-forget.
'
' Auth: Service Account → JWT RS256 (firmato via openssl CLI) → OAuth2
' bearer token. Cache token per ~1h, refresh on demand.
'
' Status: FMain.LabelSheet (verde "SHEET OK" / rosso "SHEET FAIL"), nascosta
' se non configurato. Tooltip con dettaglio errore.
'
' Fallimenti: mai propagati a FMain. Retry con backoff esponenziale 1→60s.
' La coda eventi è in memoria e si perde su restart (accettabile per MVP).

' --- config ----------------------------------------------------------------

Private $enabled As Boolean
Private $cfgPath As String

Private $clientEmail As String
Private $privKeyPath As String        ' percorso del file PEM estratto

Private $documentId As String
Private $sheetName As String
Private $eqCol As String              ' colonna equipaggio, es. "A"

' Colonne range opzionali (vuoto = disattivato)
Private $partSplitCol As String       ' h,m,s,ms su 4 colonne consecutive
Private $partUnixCol As String        ' singola colonna con ms-since-epoch
Private $arrSplitCol As String
Private $arrUnixCol As String
Private $tempoSplitCol As String      ' m,s,ms su 3 colonne (m può >60)
Private $tempoMsCol As String         ' singola colonna con totale ms

' --- runtime state ---------------------------------------------------------

Private $accessToken As String
Private $tokenExpiry As Long          ' epoch secs di scadenza token
Private $busy As Boolean
Private $queue As New Integer[]       ' numeri equipaggio da aggiornare
Private $backoffSec As Integer
Private $http As HttpClient
Private $hRetry As Timer

Private $state As String              ' "token" | "scan" | "write" | "probe"
Private $curNumero As Integer
Private $curRow As Integer            ' riga trovata (>0) o -1 = nuova

' --- pubblici --------------------------------------------------------------

Public Sub Init()
  $cfgPath = User.Home &/ ".config/brrm/sheet.conf"
  $enabled = LoadConfig()
  If Not $enabled Then
    Try FMain.LabelSheet.Visible = False
    Return
  Endif
  $http = New HttpClient As "Http"
  $hRetry = New Timer As "RetryTimer"
  $hRetry.Enabled = False
  $backoffSec = 1
  Try FMain.LabelSheet.Visible = False  ' nascosta finche' probe non risolve
  StartProbe()
End

Public Sub Reinit()
  ' Chiamato da FSettings dopo salvataggio config.
  Try $hRetry.Stop
  If $http Then Try $http.Stop
  $http = Null
  $busy = False
  $state = ""
  $queue = New Integer[]
  $accessToken = ""
  $tokenExpiry = 0
  $enabled = False
  Init()
End

Public Sub UpdateForEquipaggio(numero As Integer)
  ' Punto d'ingresso unico. Idempotente: dedup nella coda.
  If Not $enabled Then Return
  If numero <= 0 Or numero >= 10000 Then Return
  If $queue.Find(numero) < 0 Then $queue.Add(numero)
  If Not $busy Then ProcessNext()
End

' --- config loading --------------------------------------------------------

Private Function LoadConfig() As Boolean
  Dim sLine, sKey, sVal As String
  Dim iEq As Integer
  Dim sCredPath As String

  $documentId = ""
  $sheetName = ""
  $eqCol = ""
  $partSplitCol = ""
  $partUnixCol = ""
  $arrSplitCol = ""
  $arrUnixCol = ""
  $tempoSplitCol = ""
  $tempoMsCol = ""
  sCredPath = ""

  If Not Exist($cfgPath) Then Return False

  Dim sCfg As String
  sCfg = ""
  Try sCfg = File.Load($cfgPath)
  If sCfg = "" Then Return False

  For Each sLine In Split(sCfg, gb.NewLine)
    sLine = Trim$(sLine)
    If sLine = "" Or If Left$(sLine, 1) = "#" Then Continue
    iEq = InStr(sLine, "=")
    If iEq < 2 Then Continue
    sKey = LCase$(Trim$(Left$(sLine, iEq - 1)))
    sVal = Trim$(Mid$(sLine, iEq + 1))
    Select Case sKey
      Case "credentials"
        sCredPath = sVal
      Case "document_id"
        $documentId = sVal
      Case "sheet_name"
        $sheetName = sVal
      Case "equipaggio_column"
        $eqCol = UCase$(sVal)
      Case "partenza_split_column"
        $partSplitCol = UCase$(sVal)
      Case "partenza_unixms_column"
        $partUnixCol = UCase$(sVal)
      Case "arrivo_split_column"
        $arrSplitCol = UCase$(sVal)
      Case "arrivo_unixms_column"
        $arrUnixCol = UCase$(sVal)
      Case "tempo_split_column"
        $tempoSplitCol = UCase$(sVal)
      Case "tempo_ms_column"
        $tempoMsCol = UCase$(sVal)
    End Select
  Next

  If sCredPath = "" Or $documentId = "" Or $sheetName = "" Or $eqCol = "" Then Return False
  If Not Exist(sCredPath) Then Return False

  Return ParseCredentials(sCredPath)
End

Private Function ParseCredentials(sPath As String) As Boolean
  ' Estrae client_email e private_key dal JSON del service account.
  ' Salva la private_key in ~/.cache/brrm/sheet-privkey.pem (chmod 600) cosi'
  ' openssl la puo' usare per firmare i JWT senza ulteriore IO sul file utente.
  Dim sJson As String
  Dim sKey As String
  Dim sCacheDir As String

  sJson = ""
  Try sJson = File.Load(sPath)
  If sJson = "" Then Return False

  Dim cred As Variant
  cred = Null
  Try cred = JSON.Decode(sJson)
  If IsNull(cred) Then Return False
  $clientEmail = ""
  sKey = ""
  Try $clientEmail = CStr(cred["client_email"])
  Try sKey = CStr(cred["private_key"])
  If $clientEmail = "" Or sKey = "" Then Return False

  sCacheDir = User.Home &/ ".cache/brrm"
  If Not Exist(sCacheDir) Then Try Mkdir sCacheDir
  $privKeyPath = sCacheDir &/ "sheet-privkey.pem"
  Try File.Save($privKeyPath, sKey)
  If Error Then
    Return False
  Endif
  Try Chmod $privKeyPath To "rw-------"
  Return True
End

' --- status indicator ------------------------------------------------------

Private Sub SetStatus(connected As Boolean, Optional detail As String)
  Try FMain.LabelSheet.Visible = True
  If connected Then
    Try FMain.LabelSheet.Background = &H00CC00&
    Try FMain.LabelSheet.Text = "SHEET OK"
    If detail = "" Then detail = "Foglio sincronizzato"
  Else
    Try FMain.LabelSheet.Background = &HCC0000&
    Try FMain.LabelSheet.Text = "SHEET FAIL"
    If detail = "" Then detail = "Errore di scrittura sul foglio"
  Endif
  Try FMain.LabelSheet.Tooltip = detail & gb.NewLine & "Documento: " & $documentId & gb.NewLine & "Foglio: " & $sheetName & " (coda: " & $queue.Count & ")"
End

' --- state machine entrypoint ---------------------------------------------

Private Sub StartProbe()
  ' Verifica iniziale: GET dei metadata del foglio. Esercita sia auth che
  ' accesso al documento. L'esito setta lo status.
  $busy = True
  If $accessToken = "" Or $tokenExpiry <= NowEpoch() Then
    $state = "probe-token"
    StartTokenRequest()
  Else
    $state = "probe"
    DoProbe()
  Endif
End

Private Sub ProcessNext()
  If $queue.Count = 0 Then Return
  If $busy Then Return
  $curNumero = $queue[0]
  $busy = True
  If $accessToken = "" Or $tokenExpiry <= NowEpoch() Then
    $state = "token"
    StartTokenRequest()
  Else
    $state = "scan"
    StartScanRequest()
  Endif
End

' --- token (JWT → access_token) -------------------------------------------

Private Sub StartTokenRequest()
  Dim sHeader, sClaim, sJwt, sSig, sBody As String
  Dim iNow As Long

  iNow = NowEpoch()
  sHeader = Base64URLStr("{\"alg\":\"RS256\",\"typ\":\"JWT\"}")
  sClaim = "{\"iss\":\"" & $clientEmail & "\","
  sClaim &= "\"scope\":\"https://www.googleapis.com/auth/spreadsheets\","
  sClaim &= "\"aud\":\"https://oauth2.googleapis.com/token\","
  sClaim &= "\"exp\":" & CStr(iNow + 3600) & ","
  sClaim &= "\"iat\":" & CStr(iNow) & "}"
  sClaim = Base64URLStr(sClaim)

  sSig = SignWithOpenSSL(sHeader & "." & sClaim)
  If sSig = "" Then
    $busy = False
    SetStatus(False, "Errore firma JWT: openssl non disponibile?")
    ScheduleRetry()
    Return
  Endif
  sJwt = sHeader & "." & sClaim & "." & sSig

  sBody = "grant_type=" & URLEncode("urn:ietf:params:oauth:grant-type:jwt-bearer")
  sBody &= "&assertion=" & URLEncode(sJwt)

  $http.URL = "https://oauth2.googleapis.com/token"
  $http.Async = True
  $http.Timeout = 10
  Try $http.Post("application/x-www-form-urlencoded", sBody)
  If Error Then
    $busy = False
    SetStatus(False, "Errore richiesta token: " & Error.Text)
    ScheduleRetry()
  Endif
End

Private Sub HandleTokenResponse()
  Dim sBody As String
  Dim iNow As Long
  Dim expIn As Long

  If $http.Code <> 200 Then
    sBody = ""
    Try sBody = ReadAll($http)
    $busy = False
    SetStatus(False, "Token HTTP " & $http.Code)
    ScheduleRetry()
    Return
  Endif

  sBody = ""
  Try sBody = ReadAll($http)
  Dim tok As Variant
  tok = Null
  Try tok = JSON.Decode(sBody)
  $accessToken = ""
  expIn = 0
  If Not IsNull(tok) Then
    Try $accessToken = CStr(tok["access_token"])
    Try expIn = CLong(tok["expires_in"])
  Endif
  If $accessToken = "" Then
    $busy = False
    SetStatus(False, "Token: campo access_token mancante")
    ScheduleRetry()
    Return
  Endif
  iNow = NowEpoch()
  ' Sottrai 60s di margine per evitare race su scadenza
  $tokenExpiry = iNow + Max(60, expIn - 60)
  $backoffSec = 1

  ' Continua nello stato successivo
  If $state = "probe-token" Then
    $state = "probe"
    DoProbe()
  Else
    $state = "scan"
    StartScanRequest()
  Endif
End

' --- probe -----------------------------------------------------------------

Private Sub DoProbe()
  $http.URL = "https://sheets.googleapis.com/v4/spreadsheets/" & URLEncode($documentId) & "?fields=properties.title,sheets.properties.title"
  $http.Async = True
  $http.Timeout = 10
  Try $http.Get(["Authorization: Bearer " & $accessToken])
  If Error Then
    $busy = False
    SetStatus(False, "Errore probe: " & Error.Text)
    ScheduleRetry()
  Endif
End

Private Sub HandleProbeResponse()
  Dim sBody As String
  Dim sTitle As String
  Dim resp As Variant
  $busy = False
  sBody = ""
  Try sBody = ReadAll($http)
  If $http.Code = 200 Then
    sTitle = ""
    resp = Null
    Try resp = JSON.Decode(sBody)
    If Not IsNull(resp) Then
      Try sTitle = CStr(resp["properties"]["title"])
    Endif
    If sTitle = "" Then sTitle = "?"
    SetStatus(True, "Probe OK — " & sTitle)
    $backoffSec = 1
    If $queue.Count > 0 Then ProcessNext()
  Else
    SetStatus(False, "Probe HTTP " & $http.Code & " — controlla document_id e permessi del service account")
    ScheduleRetry()
  Endif
End

' --- scan (find row by equipaggio) ----------------------------------------

Private Sub StartScanRequest()
  Dim sUrl As String
  sUrl = "https://sheets.googleapis.com/v4/spreadsheets/" & URLEncode($documentId)
  sUrl &= "/values/" & URLEncode($sheetName & "!" & $eqCol & ":" & $eqCol)
  $http.URL = sUrl
  $http.Async = True
  $http.Timeout = 10
  Try $http.Get(["Authorization: Bearer " & $accessToken])
  If Error Then
    $busy = False
    SetStatus(False, "Errore scan: " & Error.Text)
    ScheduleRetry()
  Endif
End

Private Sub HandleScanResponse()
  ' La response values.get e' del tipo:
  '   {"range":"...","majorDimension":"ROWS","values":[["42"],["99"],[],...]}
  ' Colonna vuota → manca il campo "values". Riga vuota → array vuoto [].
  Dim sBody As String
  Dim resp As Variant
  Dim iRow As Integer
  Dim sVal As String
  Dim iCount As Integer
  Dim sNum As String

  If $http.Code = 401 Then
    $accessToken = ""
    $tokenExpiry = 0
    $busy = False
    ScheduleRetry()
    Return
  Else If $http.Code <> 200 Then
    $busy = False
    SetStatus(False, "Scan HTTP " & $http.Code)
    ScheduleRetry()
    Return
  Endif

  sBody = ""
  Try sBody = ReadAll($http)
  resp = Null
  Try resp = JSON.Decode(sBody)
  $curRow = -1
  iCount = 0
  sNum = CStr($curNumero)
  If Not IsNull(resp) Then
    Dim values As Variant
    values = Null
    Try values = resp["values"]
    If Not IsNull(values) Then
      iCount = values.Count
      For iRow = 0 To iCount - 1
        sVal = ""
        Try sVal = Trim$(CStr(values[iRow][0]))
        If sVal = sNum Then
          $curRow = iRow + 1
          Break
        Endif
      Next
    Endif
  Endif
  If $curRow = -1 Then $curRow = iCount + 1
  $state = "write"
  StartWriteRequest()
End



' --- write (batchUpdate) --------------------------------------------------

Private Sub StartWriteRequest()
  Dim sPayload As String
  sPayload = ""
  Try sPayload = BuildBatchPayload()
  If Error Then
    $busy = False
    SetStatus(False, "Errore costruzione payload: " & Error.Text)
    ScheduleRetry()
    Return
  Endif
  $http.URL = "https://sheets.googleapis.com/v4/spreadsheets/" & URLEncode($documentId) & "/values:batchUpdate"
  $http.Async = True
  $http.Timeout = 10
  Try $http.Post("application/json", sPayload, ["Authorization: Bearer " & $accessToken])
  If Error Then
    $busy = False
    SetStatus(False, "Errore write: " & Error.Text)
    ScheduleRetry()
  Endif
End

Private Sub HandleWriteResponse()
  If $http.Code = 401 Then
    $accessToken = ""
    $tokenExpiry = 0
    $busy = False
    ScheduleRetry()
    Return
  Else If $http.Code <> 200 Then
    $busy = False
    SetStatus(False, "Write HTTP " & $http.Code & " su eq " & $curNumero)
    ScheduleRetry()
    Return
  Endif

  ' Successo: rimuovi dalla coda, eventualmente processa il prossimo
  Try $queue.Remove(0)
  $busy = False
  SetStatus(True, "Eq " & $curNumero & " aggiornato (riga " & $curRow & ")")
  $backoffSec = 1
  If $queue.Count > 0 Then ProcessNext()
End

' --- payload construction --------------------------------------------------

Private Function BuildBatchPayload() As String
  Dim parts As New String[]
  Dim dPart As Date
  Dim dArr As Date
  Dim deltaMs As Long
  Dim totalSec As Long
  Dim mm As Long
  Dim ss As Long
  Dim msec As Long

  dPart = FMain.ReturnPartenza($curNumero)
  dArr = FMain.ReturnArrivo($curNumero)

  ' Equipaggio (scrivilo sempre: idempotente)
  parts.Add(MakeRange1($eqCol, CStr($curNumero)))

  ' Partenza split (h,m,s,ms). Valori numerici raw: la conversione da
  ' Date.fraction a millisecondi e' semanticamente corretta (.1 sec → 100,
  ' .001 sec → 1), Sheets si occupa della formattazione di visualizzazione.
  If $partSplitCol Then
    If dPart = 0 Then
      parts.Add(MakeRangeN($partSplitCol, 4, ["", "", "", ""]))
    Else
      parts.Add(MakeRangeN($partSplitCol, 4, [CStr(Hour(dPart)), CStr(Minute(dPart)), CStr(Second(dPart)), CStr(MillisOf(dPart))]))
    Endif
  Endif

  ' Partenza UNIX ms (singola colonna)
  If $partUnixCol Then
    If dPart = 0 Then
      parts.Add(MakeRange1($partUnixCol, ""))
    Else
      parts.Add(MakeRange1($partUnixCol, CStr(DateToUnixMs(dPart))))
    Endif
  Endif

  ' Arrivo split
  If $arrSplitCol Then
    If dArr = 0 Then
      parts.Add(MakeRangeN($arrSplitCol, 4, ["", "", "", ""]))
    Else
      parts.Add(MakeRangeN($arrSplitCol, 4, [CStr(Hour(dArr)), CStr(Minute(dArr)), CStr(Second(dArr)), CStr(MillisOf(dArr))]))
    Endif
  Endif

  ' Arrivo UNIX ms
  If $arrUnixCol Then
    If dArr = 0 Then
      parts.Add(MakeRange1($arrUnixCol, ""))
    Else
      parts.Add(MakeRange1($arrUnixCol, CStr(DateToUnixMs(dArr))))
    Endif
  Endif

  ' Tempo (durata): solo se entrambi presenti, sennò vuoto.
  ' Sottrazione di interi (ms-since-midnight): zero rischio di precisione.
  If dPart <> 0 And dArr <> 0 Then
    deltaMs = MsInDay(dArr) - MsInDay(dPart)
    If deltaMs < 0 Then deltaMs = deltaMs + 86400000   ' arrivo dopo mezzanotte
    totalSec = deltaMs \ 1000
    mm = totalSec \ 60
    ss = totalSec Mod 60
    msec = deltaMs Mod 1000
    If $tempoSplitCol Then
      parts.Add(MakeRangeN($tempoSplitCol, 3, [CStr(mm), CStr(ss), CStr(msec)]))
    Endif
    If $tempoMsCol Then
      parts.Add(MakeRange1($tempoMsCol, CStr(deltaMs)))
    Endif
  Else
    ' Mancano i dati per il tempo: pulisci le celle (potrebbero esistere da prima)
    If $tempoSplitCol Then parts.Add(MakeRangeN($tempoSplitCol, 3, ["", "", ""]))
    If $tempoMsCol Then parts.Add(MakeRange1($tempoMsCol, ""))
  Endif

  Return "{\"valueInputOption\":\"USER_ENTERED\",\"data\":[" & parts.Join(",") & "]}"
End

Private Function MakeRange1(col As String, value As String) As String
  ' {"range":"Sheet!A5","values":[["..."]]}
  Return "{\"range\":\"" & JsonEscape($sheetName) & "!" & col & CStr($curRow) & "\",\"values\":[[\"" & JsonEscape(value) & "\"]]}"
End

Private Function MakeRangeN(startCol As String, n As Integer, values As String[]) As String
  ' {"range":"Sheet!B5:E5","values":[["a","b","c","d"]]}
  Dim endCol As String
  Dim vals As New String[]
  Dim i As Integer
  endCol = ColumnPlusN(startCol, n - 1)
  For i = 0 To values.Max
    vals.Add("\"" & JsonEscape(values[i]) & "\"")
  Next
  Return "{\"range\":\"" & JsonEscape($sheetName) & "!" & startCol & CStr($curRow) & ":" & endCol & CStr($curRow) & "\",\"values\":[[" & vals.Join(",") & "]]}"
End

Private Function ColumnPlusN(col As String, n As Integer) As String
  ' A+1=B, B+1=C, Z+1=AA, AA+1=AB. Sheets supporta colonne fino a ZZZ.
  Dim val As Integer
  Dim i As Integer
  Dim out As String
  Dim r As Integer
  val = 0
  For i = 1 To Len(col)
    val = val * 26 + (Asc(Mid$(col, i, 1)) - Asc("A") + 1)
  Next
  val = val + n
  out = ""
  While val > 0
    r = (val - 1) Mod 26
    out = Chr(Asc("A") + r) & out
    val = (val - 1) \ 26
  Wend
  Return out
End

' --- HTTP event handlers ---------------------------------------------------

Public Sub Http_Finished()
  Select Case $state
    Case "token", "probe-token"
      HandleTokenResponse()
    Case "probe"
      HandleProbeResponse()
    Case "scan"
      HandleScanResponse()
    Case "write"
      HandleWriteResponse()
  End Select
End

Public Sub Http_Error()
  Dim wasState As String = $state
  $busy = False
  SetStatus(False, "Errore di rete su " & wasState)
  ScheduleRetry()
End


' --- retry / scheduling ----------------------------------------------------

Private Sub ScheduleRetry()
  If Not $enabled Then Return
  If $backoffSec < 60 Then $backoffSec = $backoffSec * 2
  If $backoffSec > 60 Then $backoffSec = 60
  $hRetry.Delay = $backoffSec * 1000
  $hRetry.Start
End

Public Sub RetryTimer_Timer()
  $hRetry.Stop
  If Not $enabled Then Return
  If $queue.Count > 0 Then
    ProcessNext()
  Else
    ' Nessuna coda: ritenta solo il probe per rinfrescare lo status
    If Not $busy Then StartProbe()
  Endif
End

' --- helpers: JWT signing --------------------------------------------------

Private Function SignWithOpenSSL(sData As String) As String
  ' Firma sData con la private key (RSA-SHA256) usando openssl CLI. Ritorna
  ' la firma base64url-encoded, o "" se openssl non è disponibile.
  Dim sFileIn, sFileOut, sSig As String
  sFileIn = Temp$()
  sFileOut = Temp$()
  Try File.Save(sFileIn, sData)
  ' Nota: openssl 3 non accetta più -in con dgst; il file di input va come
  ' argomento posizionale.
  Shell "openssl dgst -sha256 -sign " & Shell$($privKeyPath) & " -out " & Shell$(sFileOut) & " " & Shell$(sFileIn) Wait
  sSig = ""
  Try sSig = File.Load(sFileOut)
  Try Kill sFileIn
  Try Kill sFileOut
  If sSig = "" Then Return ""
  Return Base64URLStr(sSig)
End

' --- helpers: base64url / json / time / http body --------------------------

Public Function Base64URLStr(s As String) As String
  Dim b64 As String
  b64 = Base64$(s)
  b64 = Replace(b64, "+", "-")
  b64 = Replace(b64, "/", "_")
  b64 = Replace(b64, "=", "")
  Return b64
End

Public Function URLEncode(s As String) As String
  ' Pure-Gambas URL-encoder (RFC 3986 unreserved + replace altri con %HH).
  Dim out As String
  Dim i As Integer
  Dim c As String
  Dim code As Integer
  out = ""
  For i = 1 To Len(s)
    c = Mid$(s, i, 1)
    code = Asc(c)
    Dim safe As Boolean
    safe = False
    If code >= Asc("A") And code <= Asc("Z") Then safe = True
    If code >= Asc("a") And code <= Asc("z") Then safe = True
    If code >= Asc("0") And code <= Asc("9") Then safe = True
    If c = "-" Or c = "_" Or c = "." Or c = "~" Then safe = True
    If safe Then
      out &= c
    Else
      out &= "%" & UCase$(Hex$(code, 2))
    Endif
  Next
  Return out
End

Public Function JsonEscape(s As String) As String
  ' Escape minimi per stringhe JSON: \, ", e newline. Sufficiente per i
  ' nostri payload (numeri equipaggio, nomi foglio senza chars esotici).
  Dim out As String = s
  out = Replace(out, "\\", "\\\\")
  out = Replace(out, Chr(34), "\\\"")
  out = Replace(out, Chr(10), "\\n")
  out = Replace(out, Chr(13), "")
  Return out
End



Private Function ReadAll(h As HttpClient) As String
  ' Legge tutto il body della risposta in una stringa.
  Dim sOut As String
  Dim sChunk As String
  sOut = ""
  While Lof(h) > 0
    sChunk = ""
    Try Read #h, sChunk, Lof(h)
    If sChunk = "" Then Break
    sOut &= sChunk
  Wend
  Return sOut
End

Private Function NowEpoch() As Long
  ' Secondi dall'epoch UTC. Math intera pura: giorni_locali_dall'epoch * 86400
  ' + ora locale in secondi + offset TZ (POSIX: negativo per fusi a est).
  Dim t As Date = Now
  Return DaysFromEpoch(Year(t), Month(t), Day(t)) * 86400 + Hour(t) * 3600 + Minute(t) * 60 + Second(t) + CLong(System.TimeZone)
End

Private Function DateToUnixMs(d As Date) As Long
  ' Converte (data odierna + ora di d) in UNIX ms (UTC). Tutto int.
  ' System.TimeZone e' in secondi a ovest di UTC (POSIX): CEST = -7200,
  ' quindi UNIX_ms = local_ms + System.TimeZone * 1000 (l'addendo e'
  ' negativo per fusi a est, e ci porta dal locale all'UTC).
  '
  ' Cross-midnight: partenze/arrivi sono Date time-only. Se il time-of-day
  ' di `d` e' successivo a quello attuale, l'evento e' avvenuto IERI
  ' (assunzione gara < 24h). Sottraggo un giorno cosi' l'UNIX ms assoluto
  ' scritto sul foglio resta coerente con la durata calcolata via delta.
  Dim t As Date = Now
  Dim daysEpoch As Long = DaysFromEpoch(Year(t), Month(t), Day(t))
  Dim msEvent As Long = MsInDay(d)
  If msEvent > MsInDay(t) Then daysEpoch = daysEpoch - 1
  Return daysEpoch * 86400000 + msEvent + CLong(System.TimeZone) * 1000
End

Public Function MsInDay(d As Date) As Long
  ' Millisecondi trascorsi da mezzanotte locale, 0..86399999.
  Return Hour(d) * 3600000 + Minute(d) * 60000 + Second(d) * 1000 + MillisOf(d)
End

Public Function DaysFromEpoch(y As Long, m As Long, d As Long) As Long
  ' Algoritmo civil_to_days di Howard Hinnant: giorni dal 1970-01-01.
  ' Aritmetica intera pura, esatta per qualsiasi data gregoriana.
  Dim era, yoe, mAdj, doy, doe As Long
  If m <= 2 Then y = y - 1
  If y >= 0 Then era = y \ 400 Else era = (y - 399) \ 400
  yoe = y - era * 400
  If m > 2 Then mAdj = m - 3 Else mAdj = m + 9
  doy = (153 * mAdj + 2) \ 5 + d - 1
  doe = yoe * 365 + yoe \ 4 - yoe \ 100 + doy
  Return era * 146097 + doe - 719468
End

Public Function MillisOf(d As Date) As Integer
  ' Frazione di secondo in millisecondi (0-999). Format$(d, "uuu")
  ' restituisce stringa vuota quando i ms sono 0 (verificato su 3.20 e
  ' su master), quindi CInt() su quel risultato lancia Type mismatch.
  ' Pre-controllo esplicito invece di TRY+default (vedi MsInDay in FMain).
  Dim sMs As String = Format$(d, "uuu")
  If sMs = "" Then Return 0
  Return CInt(sMs)
End

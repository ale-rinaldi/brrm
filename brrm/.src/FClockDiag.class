' Modal diagnostica del clock interno. Legge i dati cache da FMain
' (popolati da DIAG/PONG/ID) e li renderizza in forma leggibile, con una
' breve spiegazione di ogni valore. Refresh live ~1s finche' aperta:
' chiede a FMain di inviare "@" e ri-renderizza.

Public Sub Form_Open()
  FClockDiag.Center()
  TimerDiag.Start()
  Render()
End

Public Sub TimerDiag_Timer()
  Try FMain.RequestDiag()
  Render()
End

Public Sub ButtonRefresh_Click()
  Try FMain.RequestDiag()
  Try FMain.RequestId()
  Render()
End

Public Sub ButtonClose_Click()
  Me.Close
End

Public Sub Form_Close()
  TimerDiag.Stop
End

Private Function FmtUtcLocal(unixSec As Long) As String
  ' unix (UTC, secondi) -> data/ora locale leggibile
  Return Format$(MTime.UnixMsToDate(unixSec * 1000), "yyyy-mm-dd hh:nn:ss")
End

Private Function FmtDurata(ms As Long) As String
  ' Scarto leggibile a qualsiasi ordine di grandezza (un RTC mai sincronizzato
  ' puo' distare anni dal PC): s / min / h / giorni.
  Dim sg As String = "+"
  Dim a As Long = ms
  If a < 0 Then
    sg = "-"
    a = -a
  Endif
  If a < 60000 Then Return sg & Format$(a / 1000, "0.0") & " s"
  If a < 3600000 Then Return sg & Format$(a / 60000, "0.0") & " min"
  If a < 86400000 Then Return sg & Format$(a / 3600000, "0.0") & " h"
  Return sg & Format$(a / 86400000, "0") & " giorni"
End

Private Sub Render()
  ' Header sorgente con colore coerente con la label di stato
  Select Case FMain.ClockSrc
    Case "G"
      LblSrc.Text = "Sorgente: GPS / PPS  (massima precisione)"
      LblSrc.Background = &H00CC00&
      LblSrc.Foreground = &HFFFFFF&
    Case "R"
      LblSrc.Text = "Sorgente: RTC  (oscillatore locale, ~ms)"
      LblSrc.Background = &HCCCC00&
      LblSrc.Foreground = &H000000&
    Case "N"
      LblSrc.Text = "Sorgente: nessun tempo valido"
      LblSrc.Background = &HCC8800&
      LblSrc.Foreground = &HFFFFFF&
    Case Else
      LblSrc.Text = "Sorgente: --  (in attesa dati)"
      LblSrc.Background = &H888888&
      LblSrc.Foreground = &HFFFFFF&
  End Select

  Dim s As String
  Dim d As String[] = MClock.ParseLine(FMain.ClockDiagRaw)

  If d <> Null And If d[0] = "D" Then
    ' D = [tag, unix, src, dev_tcnt, nmea_ms, fix, sat, hdop, alt, persi, since_pps, since_rtc, uptime]
    Dim sFix As String
    If d[5] = "A" Then
      sFix = "valido (posizione e ora affidabili)"
    Else
      sFix = "NON valido (niente posizione/ora dal GPS)"
    Endif

    s = "GPS\n"
    s &= "  Fix:            " & d[5] & " - " & sFix & "\n"
    s &= "  Satelliti:      " & d[6] & " agganciati\n"
    s &= "  HDOP:           " & d[7] & " - qualita' del fix (piu' basso e' meglio)\n"
    s &= "  Quota:          " & d[8] & " m\n"
    s &= "  Ritardo NMEA:   " & d[4] & " ms - ritardo dell'RMC dopo il PPS\n"
    s &= "  NMEA persi:     " & d[9] & " - secondi senza una frase RMC valida\n"
    s &= "\n"
    s &= "Base dei tempi\n"
    s &= "  Dev. TCNT@PPS:  " & d[3] & " tick - scarto del timer dal secondo (0 = perfetto, +-1 ok)\n"
    s &= "  Ultimo PPS:     " & d[10] & " s fa\n"
    s &= "  Scrittura RTC:  " & d[11] & " s fa - ultimo allineamento al ms del DS3231\n"
    s &= "\n"
    s &= "Tempo\n"
    s &= "  unix:           " & d[1] & "\n"
    s &= "  live (pong):    " & FMain.ClockTimeLive & "\n"
    s &= "  Uptime:         " & d[12] & " s - da ultimo avvio dell'Arduino\n"
  Else
    s = "Nessun dato diagnostico ricevuto.\n"
    s &= "Premi \"Aggiorna\", oppure verifica il collegamento dell'Arduino.\n"
    s &= "\n"
    s &= "Tempo\n"
    s &= "  live (pong):    " & FMain.ClockTimeLive & "\n"
  Endif

  ' GPS / RTC assoluti: campi aggiuntivi nella stessa riga D (firmware esteso).
  ' Col firmware vecchio la D ha solo 12 campi -> non disponibili.
  s &= "\n"
  s &= "GPS / RTC assoluti\n"
  If d <> Null And If d[0] = "D" And If d.Count >= 17 Then
    Dim bGps As Boolean = (d[13] = "1")
    Dim bRtc As Boolean = (d[15] = "1")
    Dim lGps As Long = CLong(d[14])
    Dim lRtc As Long = CLong(d[16])
    Dim lPc As Long = MTime.DateToUnixMs(Now)
    If bGps Then s &= "  GPS:   " & FmtUtcLocal(lGps) & "  (fix valido)\n" Else s &= "  GPS:   -- nessun fix\n"
    ' L'RTC ha SEMPRE un orario (l'oscillatore gira anche se non sincronizzato):
    ' lo mostriamo comunque, cosi' un RTC da impostare e' subito evidente.
    s &= "  RTC:   " & FmtUtcLocal(lRtc)
    If bRtc Then s &= "  (sincronizzato)\n" Else s &= "  (NON sincronizzato - orario non affidabile)\n"
    s &= "  PC:    " & Format$(Now, "yyyy-mm-dd hh:nn:ss.uuu") & "  (orologio locale)\n"
    If bGps Then s &= "  Scarto GPS-RTC: " & FmtDurata((lGps - lRtc) * 1000) & "\n"
    If bGps Then s &= "  Scarto GPS-PC:  " & FmtDurata(lGps * 1000 - lPc) & "\n"
    s &= "  Scarto RTC-PC:  " & FmtDurata(lRtc * 1000 - lPc) & "\n"
  Else
    s &= "  non disponibili (firmware Arduino senza diagnostica estesa)\n"
  Endif

  s &= "\n"
  s &= "Link:  " & FMain.ClockDevice & "   (firmware " & FMain.ClockFwVer & ")"

  TxtBody.Text = s
End

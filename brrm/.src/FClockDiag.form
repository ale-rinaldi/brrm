# Gambas Form File 3.0

{ Form Form
  MoveScaled(0,0,92,80)
  Text = ("Diagnostica clock")
  Arrangement = Arrange.Vertical
  Margin = True
  Spacing = True
  { LblSrc Label
    MoveScaled(1,1,90,6)
    Alignment = Align.Center
    Font = Font["+4"]
    Text = ("—")
  }
  { TxtBody TextArea
    MoveScaled(1,8,90,58)
    Expand = True
    ReadOnly = True
    Wrap = True
    Font = Font["Monospace"]
    Text = ("")
  }
  { PanelBtns Panel
    MoveScaled(1,68,90,6)
    Arrangement = Arrange.Horizontal
    Spacing = True
    { ButtonRefresh Button
      MoveScaled(0,0,18,5)
      Text = ("Aggiorna")
    }
    { PanelSpacer Panel
      MoveScaled(19,0,50,5)
      Expand = True
    }
    { ButtonClose Button
      MoveScaled(70,0,18,5)
      Text = ("Chiudi")
    }
  }
  { TimerDiag #Timer
    #X = 600
    #Y = 320
    Delay = 1000
  }
}

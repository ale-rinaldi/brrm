' Gambas class file

prow AS Integer
partenze AS NEW Date[10000]
arrivi AS NEW Date[10000]
startposindex AS Integer
stopposindex AS Integer
posingrid AS NEW Integer[10000]
CurrAct AS String
numingrid AS NEW Integer[10000]
ChangingN AS Integer
FotON AS Boolean
INV1 AS Integer
INV2 AS Integer

' --- Align (sync via web, RECEIVER) ---
Private $alignEnabled As Boolean
Private $alignUrl As String
Private $alignUser As String
Private $alignPass As String
Private $alignSession As String
Private $alignLastSeq As Long
Private $alignBuffer As String
Private $alignBackoffSec As Integer
Private $alignWantReconnect As Boolean
Private $hAlignHttp As HttpClient

' --- Google Sheets (writer, opzionale) ---
Private $sheet As CSheet

PUBLIC SUB _new()

END

PUBLIC SUB SerialPort1_Read()

DIM s AS String
TRY READ #SerialPort1, s, Lof(SerialPort1)
IF Error THEN
  TRY SerialPort1.Close   ' Timer4 lo riaprira quando torna disponibile
  RETURN
ENDIF
IF FotON = TRUE THEN
BArrivi.Add(Format$(Time, "hh:nn:ss.uuu"))
ENDIF

END

PUBLIC FUNCTION FindArduinoDevice() AS String
  ' Ritorna il primo /dev/ttyUSB* o /dev/ttyACM* disponibile, o "" se nessuno.
  DIM aFiles AS String[]
  DIM sFile AS String
  aFiles = Dir("/dev", "ttyUSB*")
  FOR EACH sFile IN aFiles
    RETURN "/dev/" & sFile
  NEXT
  aFiles = Dir("/dev", "ttyACM*")
  FOR EACH sFile IN aFiles
    RETURN "/dev/" & sFile
  NEXT
  RETURN ""
END

PRIVATE SUB SetArduinoStatus(bConnected AS Boolean)
  IF bConnected THEN
    LabelArduino.Background = &H00CC00&
    LabelArduino.Foreground = &HFFFFFF&
    LabelArduino.Text = "ARDUINO OK"
  ELSE
    LabelArduino.Background = &HCC0000&
    LabelArduino.Foreground = &HFFFFFF&
    LabelArduino.Text = "NO ARDUINO"
  ENDIF
END

PUBLIC SUB AtomicSave(sPath AS String, sContent AS String)
  ' Scrittura atomica: scrive in <path>.tmp, poi rinomina su <path>.
  ' Il Move di Gambas usa rename(2) POSIX che e' atomico nello stesso
  ' filesystem - quindi <path> contiene sempre o il vecchio o il nuovo
  ' contenuto, mai un troncato. Su ext4 (default Debian) l'ordine
  ' data/metadata e' garantito anche in caso di power cut.
  DIM sTmp AS String
  sTmp = sPath & ".tmp"
  File.Save(sTmp, sContent)
  Move sTmp DownTo sPath
END

Private Sub AlignLoadConfig() As Boolean
  ' Carica ~/.config/brrm/align.conf (key=value, # commento). Tutti i campi
  ' richiesti: url, username, password. Default per session: "default".
  Dim sPath As String
  Dim sLine As String
  Dim sKey As String
  Dim sVal As String
  Dim iEq As Integer
  sPath = User.Home &/ ".config/brrm/align.conf"
  $alignSession = "default"
  If Not Exist(sPath) Then Return False
  For Each sLine In Split(File.Load(sPath), gb.NewLine)
    sLine = Trim$(sLine)
    If sLine = "" Then Continue
    If Left$(sLine, 1) = "#" Then Continue
    iEq = InStr(sLine, "=")
    If iEq < 2 Then Continue
    sKey = LCase$(Trim$(Left$(sLine, iEq - 1)))
    sVal = Trim$(Mid$(sLine, iEq + 1))
    Select Case sKey
      Case "url"
        $alignUrl = sVal
      Case "username"
        $alignUser = sVal
      Case "password"
        $alignPass = sVal
      Case "session"
        $alignSession = sVal
    End Select
  Next
  Return ($alignUrl <> "" And $alignUser <> "" And $alignPass <> "")
End

Public Sub AlignReinit()
  ' Chiamato dalla form Settings dopo aver scritto il config: chiude
  ' lo stream corrente e fa ripartire AlignInit da zero.
  TimerAlignWatchdog.Stop
  If $hAlignHttp Then
    Try $hAlignHttp.Stop
    $hAlignHttp = Null
  Endif
  $alignWantReconnect = False
  $alignUrl = ""
  $alignUser = ""
  $alignPass = ""
  $alignSession = ""
  AlignInit()
End

Public Sub AlignInit()
  ' Punto di ingresso: chiamato da Form_Open. Se non configurato, no-op.
  $alignEnabled = AlignLoadConfig()
  If Not $alignEnabled Then
    LabelSync.Visible = False
    Return
  Endif
  $alignLastSeq = 0
  Try $alignLastSeq = CLong(Trim$(File.Load(User.Home &/ ".brrm-align-lastseq")))
  $alignBuffer = ""
  $alignBackoffSec = 1
  $alignWantReconnect = False
  ' Niente stato prematuro: label nascosta finche' non abbiamo un esito
  ' definitivo (primo chunk = SYNC OK; oppure errore/disconnessione = FAIL).
  LabelSync.Visible = False
  AlignStartStream()
End

Private Sub AlignSetStatus(connected As Boolean, Optional detail As String)
  ' Una qualsiasi chiamata a SetStatus rende visibile l'indicatore.
  ' Il `detail` finisce nel tooltip per troubleshooting.
  LabelSync.Visible = True
  If connected Then
    LabelSync.Background = &H00CC00&
    LabelSync.Text = "SYNC OK"
    If detail = "" Then detail = "Stream connesso"
  Else
    LabelSync.Background = &HCC0000&
    LabelSync.Text = "SYNC FAIL"
    If detail = "" Then detail = "Errore di sincronizzazione"
  Endif
  LabelSync.Tooltip = detail & gb.NewLine & "URL: " & $alignUrl & gb.NewLine & "Session: " & $alignSession & gb.NewLine & "Ultimo seq ricevuto: " & $alignLastSeq
End

Private Sub AlignStartStream()
  ' Apre la connessione SSE long-lived. _Read fira per ogni chunk, _Finished
  ' quando il server o la rete chiudono (→ schedula riconnessione).
  If Not $alignEnabled Then Return
  TimerAlignWatchdog.Stop
  If $hAlignHttp Then
    Try $hAlignHttp.Stop
    $hAlignHttp = Null
  Endif
  $alignBuffer = ""
  $hAlignHttp = New HttpClient As "AlignHttp"
  $hAlignHttp.URL = $alignUrl & "/stream?session=" & $alignSession & "&since=" & CStr($alignLastSeq)
  $hAlignHttp.Auth = Net.AuthBasic
  $hAlignHttp.User = $alignUser
  $hAlignHttp.Password = $alignPass
  $hAlignHttp.Async = True
  $hAlignHttp.Timeout = 0   ' stream long-lived, niente timeout
  Try $hAlignHttp.Get()
  If Error Then
    AlignSetStatus(False, "Errore apertura stream: " & Error.Text)
    AlignScheduleReconnect()
    Return
  Endif
  ' Watchdog: 15s di silenzio → riconnetti (keepalive server e' ogni 10s)
  $alignWantReconnect = False
  TimerAlignWatchdog.Delay = 15000
  TimerAlignWatchdog.Start
End

Public Sub AlignHttp_Read()
  ' Chunk SSE ricevuto: accumula nel buffer ed estrai i blocchi completi
  ' (delimitati da "\n\n"). Reset del watchdog ad ogni chunk.
  Dim sChunk As String
  Dim iSep As Integer
  Dim sBlock As String
  sChunk = ""
  Try Read #$hAlignHttp, sChunk, Lof($hAlignHttp)
  If sChunk = "" Then Return
  ' Normalizza CRLF → LF per parsing semplice
  sChunk = Replace(sChunk, Chr(13), "")
  $alignBuffer &= sChunk
  TimerAlignWatchdog.Stop
  TimerAlignWatchdog.Delay = 15000
  $alignWantReconnect = False
  TimerAlignWatchdog.Start
  AlignSetStatus(True, "Stream attivo")
  $alignBackoffSec = 1
  Do
    iSep = InStr($alignBuffer, "\n\n")
    If iSep = 0 Then Break
    sBlock = Left$($alignBuffer, iSep - 1)
    $alignBuffer = Mid$($alignBuffer, iSep + 2)
    AlignProcessBlock(sBlock)
  Loop
End

Public Sub AlignHttp_Finished()
  ' Server o rete hanno chiuso lo stream — riconnetti con backoff.
  AlignSetStatus(False, "Stream chiuso (HTTP " & $hAlignHttp.Code & "), riconnessione in corso")
  AlignScheduleReconnect()
End

Public Sub AlignHttp_Error()
  AlignSetStatus(False, "Errore di rete sullo stream")
  AlignScheduleReconnect()
End

Private Sub AlignScheduleReconnect()
  ' Backoff esponenziale 1→2→4→…→60s. TimerAlignWatchdog viene riusato
  ' come single-shot per il delay (distinto dal watchdog via flag).
  If Not $alignEnabled Then Return
  TimerAlignWatchdog.Stop
  If $alignBackoffSec < 60 Then $alignBackoffSec = $alignBackoffSec * 2
  If $alignBackoffSec > 60 Then $alignBackoffSec = 60
  TimerAlignWatchdog.Delay = $alignBackoffSec * 1000
  $alignWantReconnect = True
  TimerAlignWatchdog.Start
End

Public Sub TimerAlignWatchdog_Timer()
  TimerAlignWatchdog.Stop
  If $alignWantReconnect Then
    $alignWantReconnect = False
    AlignStartStream()
    Return
  Endif
  ' Watchdog scaduto (15s senza dati) → tratta come disconnessione
  AlignSetStatus(False, "Nessun dato dallo stream per 15s (keepalive perso)")
  AlignScheduleReconnect()
End

Private Sub AlignProcessBlock(sBlock As String)
  ' Un blocco SSE puo' contenere righe "event:", "data:", commenti (":"),
  ' "id:", "retry:". Estrae solo event+data e li passa ad AlignApplyEvent.
  Dim sLine As String
  Dim sEventType As String
  Dim sData As String
  sEventType = ""
  sData = ""
  For Each sLine In Split(sBlock, "\n")
    If sLine = "" Then Continue
    If Left$(sLine, 1) = ":" Then Continue   ' commento SSE
    If Left$(sLine, 7) = "event: " Then
      sEventType = Mid$(sLine, 8)
    Else If Left$(sLine, 6) = "data: " Then
      If sData = "" Then
        sData = Mid$(sLine, 7)
      Else
        sData = sData & "\n" & Mid$(sLine, 7)
      Endif
    Endif
  Next
  If sData = "" Then Return
  AlignApplyEvent(sEventType, sData)
End

Private Function JsonGetInt(s As String, key As String) As Long
  ' Parser super-semplice per JSON flat: cerca "key": e legge il numero.
  Dim i As Integer
  Dim iStart As Integer
  Dim iEnd As Integer
  Dim sNeedle As String
  sNeedle = Chr(34) & key & Chr(34) & ":"
  i = InStr(s, sNeedle)
  If i = 0 Then Return 0
  iStart = i + Len(sNeedle)
  While iStart <= Len(s) And Mid$(s, iStart, 1) = " "
    Inc iStart
  Wend
  iEnd = iStart
  While iEnd <= Len(s) And (Mid$(s, iEnd, 1) Like "[0-9-]")
    Inc iEnd
  Wend
  If iEnd = iStart Then Return 0
  Return CLong(Mid$(s, iStart, iEnd - iStart))
End

Private Function JsonGetStr(s As String, key As String) As String
  ' Parser super-semplice per JSON flat: cerca "key": e legge la stringa
  ' fra virgolette. Null → "". Assume nessun escape interno (sufficiente per
  ' i nostri payload: orario HH:MM:SS.zzz, ts_origine ISO8601).
  Dim i As Integer
  Dim iStart As Integer
  Dim iEnd As Integer
  Dim sNeedle As String
  sNeedle = Chr(34) & key & Chr(34) & ":"
  i = InStr(s, sNeedle)
  If i = 0 Then Return ""
  i = i + Len(sNeedle)
  While i <= Len(s) And Mid$(s, i, 1) = " "
    Inc i
  Wend
  If Mid$(s, i, 4) = "null" Then Return ""
  If Mid$(s, i, 1) <> Chr(34) Then Return ""
  iStart = i + 1
  iEnd = InStr(s, Chr(34), iStart)
  If iEnd = 0 Then Return ""
  Return Mid$(s, iStart, iEnd - iStart)
End

Private Sub AlignApplyEvent(sEventType As String, sData As String)
  ' Applica un evento SSE allo stato locale. Idempotente: scarta seq gia' visti.
  Dim iSeq As Long
  Dim iNumero As Integer
  Dim sOrario As String
  Dim dPartenza As Date
  Dim iMinSeq As Long

  Select Case sEventType
    Case "meta"
      ' Gap detection: se la TTL server ha mangiato eventi sotto la nostra
      ' last_seq, allinea last_seq a min_seq-1 cosi' accettiamo lo snapshot.
      iMinSeq = JsonGetInt(sData, "min_seq")
      If iMinSeq > 0 And If $alignLastSeq < iMinSeq - 1 Then
        $alignLastSeq = iMinSeq - 1
        Try AtomicSave(User.Home &/ ".brrm-align-lastseq", CStr($alignLastSeq))
      Endif

    Case "event"
      iSeq = JsonGetInt(sData, "seq")
      If iSeq <= $alignLastSeq Then Return
      iNumero = JsonGetInt(sData, "numero")
      If iNumero <= 0 Or iNumero >= 10000 Then Return
      sOrario = JsonGetStr(sData, "orario")
      Timer1.Stop
      If sOrario = "" Then
        ' orario=null → annullamento partenza
        partenze[iNumero] = 0
      Else
        dPartenza = 0
        Try dPartenza = sOrario
        If dPartenza <> 0 Then
          partenze[iNumero] = dPartenza
          If LEquipaggi.Find(iNumero) < 0 Then LEquipaggi.Add(iNumero)
        Endif
      Endif
      $alignLastSeq = iSeq
      Try AtomicSave(User.Home &/ ".brrm-align-lastseq", CStr($alignLastSeq))
      UpgradeSessionFile()
      Timer1.Start
      If $sheet Then $sheet.UpdateForEquipaggio(iNumero)

    ' "keepalive" e altri tipi: nessuna azione (il reset del watchdog avviene
    ' gia' in AlignHttp_Read per qualsiasi chunk ricevuto).
  End Select
End

PUBLIC SUB UpgradeSessionFile()
  ' Formato v1: prima riga = magic header, righe successive numero|partenza|arrivo.
  ' Campi vuoti = nessun dato. Str$() rende le date locale-indipendenti.
  DIM Counter AS Integer
  DIM iEqui AS Integer
  DIM sFileOut AS String
  DIM sPart AS String
  DIM sArr AS String

  sFileOut = "brrm-session v1" & gb.NewLine
  FOR Counter = 0 TO LEquipaggi.Count - 1
    iEqui = 0
    TRY iEqui = LEquipaggi[Counter].Text
    IF iEqui <= 0 THEN CONTINUE
    sPart = ""
    IF partenze[iEqui] <> 0 THEN sPart = Str$(partenze[iEqui])
    sArr = ""
    IF arrivi[iEqui] <> 0 THEN sArr = Str$(arrivi[iEqui])
    sFileOut &= iEqui & "|" & sPart & "|" & sArr & gb.NewLine
  NEXT
  AtomicSave(User.Home &/ ".brrm-session", sFileOut)
END


PUBLIC SUB SetPartenza(Equipaggio AS Integer, Partenza AS Date)

  Timer1.Stop
  partenze[Equipaggio] = Partenza
  UpgradeSessionFile()
  Timer1.Start
  IF $sheet THEN $sheet.UpdateForEquipaggio(Equipaggio)
END

PUBLIC SUB ReturnArrivo(Numero AS Integer) AS Date
  
  RETURN arrivi[Numero]
  
END

PUBLIC SUB ReturnPartenza(Numero AS Integer) AS Date
  
  RETURN partenze[Numero]
  
END

PUBLIC SUB SetupGridHeader()
  ' Configurazione fissa dell'header (riga 0). Idempotente: chiamabile
  ' tutte le volte che serve. Necessario richiamarla dopo IMPORTA perche'
  ' Message.Info + altri eventi Qt resettano le proprieta' delle celle.
  GridView1.Columns.Count = 4
  GridView1.Rows.Count = Max(GridView1.Rows.Count, 1)
  GridView1.Columns[0].Width = GridView1.Width - 500
  GridView1.Columns[1].Width = 150
  GridView1.Columns[2].Width = 150
  GridView1.Columns[3].Width = 150
  GridView1[0, 0].Background = &H000000&
  GridView1[0, 1].Background = &H000000&
  GridView1[0, 2].Background = &H000000&
  GridView1[0, 3].Background = &H000000&
  GridView1[0, 0].Foreground = &HFF9999&
  GridView1[0, 1].Foreground = &HFFFFFF&
  GridView1[0, 2].Foreground = &HFFFFFF&
  GridView1[0, 3].Foreground = &HFF9999&
  GridView1[0, 0].Text = "Equipaggio"
  GridView1[0, 1].Text = "Partenza"
  GridView1[0, 2].Text = "Arrivo"
  GridView1[0, 3].Text = "Tempo"
END

PUBLIC SUB Form_Open()
DIM sTest AS String
DIM aTest AS String[]
DIM aTest2 AS String[]
DIM iEqui AS Integer
DIM iLoaded AS Integer
FotON = TRUE
FMain.Center()
SetupGridHeader()
TRY SerialPort1.Open
' Loader formato v1: scarta silenziosamente se l'header non e' atteso.
sTest = ""
IF Exist(User.Home &/ ".brrm-session") THEN sTest = File.Load(User.Home &/ ".brrm-session")
aTest = Split(sTest, gb.NewLine)
IF aTest.Count >= 1 AND IF aTest[0] = "brrm-session v1" THEN
  FOR iEqui = 1 TO aTest.Max
    aTest2 = Split(Trim$(aTest[iEqui]), "|")
    IF aTest2.Count < 3 THEN CONTINUE
    iLoaded = 0
    TRY iLoaded = CInt(aTest2[0])
    IF iLoaded <= 0 OR iLoaded >= 10000 THEN CONTINUE
    LEquipaggi.Add(iLoaded)
    IF aTest2[1] <> "" THEN TRY partenze[iLoaded] = aTest2[1]
    IF aTest2[2] <> "" THEN TRY arrivi[iLoaded] = aTest2[2]
  NEXT
ENDIF
Timer1.Start()
AlignInit()
$sheet = New CSheet
$sheet.Init()
END

Public Sub SheetReinit()
  ' Chiamato da FSettings dopo salvataggio config.
  If $sheet Then $sheet.Reinit()
End

PUBLIC SUB Timer1_Timer()
' Guard: ogni Message dialog (Question/Info/Error) resetta il formatting
' delle celle del row 0. Ricontrolliamo qui e ri-applichiamo se serve.
IF GridView1[0, 0].Background <> &H000000& THEN SetupGridHeader()
DIM concorrente AS Integer
DIM asd AS Date
DIM asdd AS String
DIM aAsd AS String[]
DIM posgrid AS Integer
DIM indice AS Integer
DIM totale AS Integer
DIM Counter AS Integer
totale = 0
indice = 0
asdd = ""
totale = LEquipaggi.Count
Counter = 0
GridView1.Rows.Count = totale + 1
WHILE Counter < totale 
TRY concorrente = LEquipaggi[Counter].Text
GridView1[Counter + 1, 0].Text = concorrente
IF partenze[concorrente] <> 0 AND arrivi[concorrente] <> 0 THEN
asd = arrivi[concorrente] - partenze[concorrente]
asdd = asd
ENDIF  
IF partenze[concorrente] <> 0 AND arrivi[concorrente] = 0 THEN 
asd = Time - partenze[concorrente]
asdd = asd
ENDIF 
IF partenze[concorrente] = 0 AND arrivi[concorrente] = 0 THEN 
  LEquipaggi.Remove(LEquipaggi.Find(concorrente))
  UpgradeSessionFile()
  totale = totale - 1
  GridView1.Rows.Count = totale + 1
  ' Counter NON viene incrementato: il prossimo equipaggio si e' spostato
  ' nella posizione corrente. Skippiamo il resto del body (parsing asdd).
  CONTINUE
ENDIF 
IF partenze[concorrente] = 0 AND arrivi[concorrente] <> 0 THEN 
asdd = "NO DATI PARTENZA"
ENDIF 
aAsd = Split(asdd, ".")
asdd = ""
TRY asdd = aAsd[0] & "." & PadMillis(aAsd[1])
IF asdd = "" THEN
asdd = aAsd[0]
ENDIF
aAsd = Split(asdd, ":")
asdd = ""
TRY asdd = aAsd[1] & ":" & aAsd[2]
IF asdd = "" THEN 
asdd = aAsd[0]
ENDIF 
TRY GridView1[Counter + 1, 1].Text = partenze[concorrente]
TRY GridView1[Counter + 1, 2].Text = arrivi[concorrente]
TRY GridView1[Counter + 1, 3].Text = asdd
indice = indice + 1
Counter = Counter + 1
WEND
indice = 0
Counter = 0
WHILE Counter < LEquipaggi.Count
IF arrivi[LEquipaggi[Counter].Text] = 0 THEN 
Label2.Text = LEquipaggi[Counter].Text
indice = 1
BREAK 
ENDIF 
Counter = Counter + 1
WEND 
IF indice = 0 THEN 
Label2.Text = "/"
ENDIF 
END

PUBLIC SUB Button1_Click()
DIM Counter AS Integer
IF Message.Question("Sei sicuro?", "Sì", "No") = 1 THEN 
IF Message.Question("Sei DAVVERO sicuro??? Poi non pentirti eh, non puoi più annullare ciò che stai per fare!", "Sì, dai non rompere e fammi resettare!!!", "No no!!! Argh, cosa stavo per fare! Per fortuna mi hai avvertito!") = 1
Timer1.Stop
LEquipaggi.Clear
Counter = 0
WHILE Counter < 1000
partenze[Counter] = 0
arrivi[Counter] = 0
Counter = Counter + 1
WEND 
UpgradeSessionFile()
ENDIF 
ENDIF 
Timer1.Start
END

PUBLIC SUB EditOrder(Order AS String)
  
  DIM aOrdine AS String[]
  DIM iEqui AS Integer
  DIM Number AS Integer
  Timer1.Stop
  LEquipaggi.Clear
  aOrdine = Split(Order, "-")
  GridView1.Rows.Count = aOrdine.Count + 1
  Number = 0
  FOR EACH iEqui IN aOrdine
  LEquipaggi.Add(iEqui)
  NEXT 
  startposindex = 1
  stopposindex = 1
  Timer1.Start
END


PUBLIC SUB Button5_Click()

IF CurrAct = "annarr" THEN 
  GridView1.Background = &H0FFFFFF&
  GridView1.Mouse = 0
  CurrAct = ""
  ELSE 
CurrAct = "annarr"
GridView1.Background = &H00FFFF7F&
GridView1.Mouse = 2
END IF
END

PUBLIC SUB Button4_Click()
IF CurrAct = "invarr1" THEN 
  GridView1.Background = &H0FFFFFF&
  GridView1.Mouse = 0
  CurrAct = ""
  ELSE IF CurrAct = "invarr2"
    GridView1.Background = &H0FFFFFF&
  GridView1.Mouse = 0
  CurrAct = ""
  ELSE 
  CurrAct = "invarr1"
GridView1.Background = &H00FFFF7F&
GridView1.Mouse = 2
ENDIF 
END

PUBLIC SUB Button6_Click()
  ' Export CSV: numero,hh,mm,ss,mmm (millis con 3 cifre zero-padded a destra)
  DIM Counter AS Integer
  DIM iEqui AS Integer
  DIM tDur AS Date
  DIM sDur AS String
  DIM aByColon AS String[]
  DIM aByDot AS String[]
  DIM sH AS String
  DIM sM AS String
  DIM sS AS String
  DIM sMs AS String
  DIM sOut AS String
  DIM sPath AS String

  FOR Counter = 0 TO LEquipaggi.Count - 1
    iEqui = 0
    TRY iEqui = LEquipaggi[Counter].Text
    IF iEqui = 0 THEN CONTINUE
    IF partenze[iEqui] = 0 OR arrivi[iEqui] = 0 THEN CONTINUE
    tDur = arrivi[iEqui] - partenze[iEqui]
    sDur = CStr(tDur)                  ' formato "hh:nn:ss.zzz" o "hh:nn:ss"
    aByColon = Split(sDur, ":")
    IF aByColon.Count < 3 THEN CONTINUE
    sH = aByColon[0]
    sM = aByColon[1]
    aByDot = Split(aByColon[2], ".")
    sS = aByDot[0]
    IF aByDot.Count > 1 THEN
      sMs = aByDot[1]
    ELSE
      sMs = "0"
    ENDIF
    sOut = sOut & iEqui & "," & sH & "," & sM & "," & sS & "," & PadMillis(sMs) & "\n"
  NEXT

  Dialog.Title = "Salva risultati gara"
  Dialog.Filter = ["*.csv", "File CSV"]
  Dialog.Path = User.Home &/ "brrm-arrivi.csv"
  IF Dialog.SaveFile() THEN RETURN     ' utente ha annullato
  sPath = Dialog.Path
  IF LCase$(File.Ext(sPath)) <> "csv" THEN sPath = sPath & ".csv"
  TRY File.Save(sPath, sOut)
  IF Error THEN Message.Error("Impossibile salvare il file: " & Error.Text)
END

PUBLIC FUNCTION PadMillis(s AS String) AS String
  ' Pad a destra con zeri a esattamente 3 cifre. "7" -> "700", "07" -> "070".
  SELECT CASE Len(s)
    CASE 0
      RETURN "000"
    CASE 1
      RETURN s & "00"
    CASE 2
      RETURN s & "0"
    CASE 3
      RETURN s
    CASE ELSE
      RETURN Left$(s, 3)
  END SELECT
END

PUBLIC SUB ButtonImporta_Click()
  ' Importa orari di partenza da CSV (formato esportato da brrm-partenza:
  ' numero,hh,mm,ss,mmm su ogni riga).
  DIM sPath AS String
  DIM aLines AS String[]
  DIM sLine AS String
  DIM aFields AS String[]
  DIM iEqui AS Integer
  DIM sDateStr AS String
  DIM dPart AS Date
  DIM iImportati AS Integer

  Dialog.Title = "Importa orari di partenza"
  Dialog.Filter = ["*.csv", "File CSV"]
  Dialog.Path = User.Home &/ "brrm-partenze.csv"
  IF Dialog.OpenFile() THEN RETURN     ' utente ha annullato
  sPath = Dialog.Path
  IF NOT Exist(sPath) THEN
    Message.Error("File non trovato: " & sPath)
    RETURN
  ENDIF

  Timer1.Stop
  aLines = Split(File.Load(sPath), "\n")
  FOR EACH sLine IN aLines
    sLine = Trim$(sLine)
    IF sLine = "" THEN CONTINUE
    aFields = Split(sLine, ",")
    IF aFields.Count < 5 THEN CONTINUE
    iEqui = 0
    TRY iEqui = CInt(Trim$(aFields[0]))
    IF iEqui <= 0 OR iEqui >= 10000 THEN CONTINUE
    sDateStr = Trim$(aFields[1]) & ":" & Trim$(aFields[2]) & ":" & Trim$(aFields[3]) & "." & PadMillis(Trim$(aFields[4]))
    dPart = 0
    TRY dPart = sDateStr
    IF dPart = 0 THEN CONTINUE
    partenze[iEqui] = dPart
    IF LEquipaggi.Find(iEqui) < 0 THEN LEquipaggi.Add(iEqui)
    iImportati = iImportati + 1
  NEXT

  UpgradeSessionFile()
  Timer1.Start
  Message.Info(iImportati & " orari di partenza importati.")
END

PUBLIC SUB twoDecs(number AS String) AS String
  DIM lol AS String
IF Len(number) = 0 THEN 
RETURN "00"
ELSE IF Len(number) < 2 THEN 
RETURN number & "0"
ELSE IF Len(number) > 2 THEN 
RETURN Left$(number, -1)
END IF
RETURN number
END


PUBLIC SUB GridView1_Click()
DIM pt1 AS Date
DIM pt2 AS Date
  IF GridView1.Row > 0 THEN 
  IF CurrAct = "part" THEN 
  Timer1.Stop
  ChangingN = LEquipaggi[GridView1.Row - 1].Text
  FPartenza.Show
  GridView1.Background = &H0FFFFFF&
  GridView1.Mouse = 0
    CurrAct = ""
    Timer1.Start
  END IF
    
  IF CurrAct = "annpart" THEN
  DIM iAnnPartNum AS Integer
  iAnnPartNum = LEquipaggi[GridView1.Row - 1].Text
  IF Message.Question("Sei sicuro di voler annullare la partenza dell'equipaggio numero " & iAnnPartNum & "?", "Sì", "No") = 1 THEN
  Timer1.Stop
  partenze[iAnnPartNum] = 0
  IF $sheet THEN $sheet.UpdateForEquipaggio(iAnnPartNum)
  ENDIF
    GridView1.Background = &H0FFFFFF&
  GridView1.Mouse = 0
  CurrAct = ""
  Timer1.Start
  END IF

    IF CurrAct = "annarr" THEN
    DIM iAnnArrNum AS Integer
    iAnnArrNum = LEquipaggi[GridView1.Row - 1].Text
    IF Message.Question("Sei sicuro di voler annullare l'arrivo dell'equipaggio numero " & iAnnArrNum & "?", "Sì", "No") = 1 THEN
  Timer1.Stop
  arrivi[iAnnArrNum] = 0
  IF $sheet THEN $sheet.UpdateForEquipaggio(iAnnArrNum)
  ENDIF
    GridView1.Background = &H0FFFFFF&
  GridView1.Mouse = 0
  CurrAct = ""
  Timer1.Start
  END IF
  
    IF CurrAct = "invarr2" THEN

  INV2 = LEquipaggi[GridView1.Row - 1].Text
  IF Message.Question("Sei sicuro di voler invertire gli arrivi degli equipaggi " & INV1 & " e " & INV2 & "?", "Sì", "No") = 1 THEN
 Timer1.Stop
  pt1 = arrivi[INV1]
  pt2 = arrivi[INV2]
  arrivi[INV2] = pt1
  arrivi[INV1] = pt2
  IF $sheet THEN
    $sheet.UpdateForEquipaggio(INV1)
    $sheet.UpdateForEquipaggio(INV2)
  ENDIF
  ENDIF
    GridView1.Background = &H0FFFFFF&
  GridView1.Mouse = 0
  CurrAct = ""
  Timer1.Start
  END IF
  
  IF CurrAct = "invarr1" THEN
  INV1 = LEquipaggi[GridView1.Row - 1].Text
  CurrAct = "invarr2"
    GridView1.Background = &H007FFFFF&
    GridView1.Mouse = 2
  END IF

  IF CurrAct = "modnum" THEN
    DIM iOld AS Integer
    DIM sNew AS String
    DIM iNew AS Integer
    iOld = LEquipaggi[GridView1.Row - 1].Text
    Timer1.Stop
    sNew = InputBox("Nuovo numero per l'equipaggio " & iOld & ":", "Cambia numero")
    IF sNew <> "" THEN
      iNew = 0
      TRY iNew = CInt(Trim$(sNew))
      IF iNew <= 0 OR iNew >= 10000 THEN
        Message.Error("Numero non valido. Deve essere fra 1 e 9999.")
      ELSE IF iNew = iOld THEN
        ' no-op
      ELSE IF LEquipaggi.Find(iNew) >= 0 THEN
        Message.Error("L'equipaggio " & iNew & " esiste già: non posso assegnare lo stesso numero a due righe.")
      ELSE
        ChangeNumero(iOld, iNew)
      ENDIF
    ENDIF
    Timer1.Start
    GridView1.Background = &H0FFFFFF&
    GridView1.Mouse = 0
    CurrAct = ""
  END IF

ENDIF
UpgradeSessionFile()
END


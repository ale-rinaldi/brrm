' Gambas class file

' Stati di interazione (CurrAct). I pulsanti di azione "contestuale" su
' griglia (Annulla partenza, Annulla arrivo, Inverti, Cambia numero) settano
' un valore qui; GridView1_Click esegue l'azione corrispondente al click.
Private Const ACT_NONE As String = ""
Private Const ACT_ANNPART As String = "annpart"
Private Const ACT_ANNARR As String = "annarr"
Private Const ACT_INVARR1 As String = "invarr1"
Private Const ACT_INVARR2 As String = "invarr2"
Private Const ACT_MODNUM As String = "modnum"

' Limite massimo numero equipaggio (e dimensione array statici).
Private Const MAX_NUMERO As Integer = 10000

Private partenze As New Date[MAX_NUMERO]
Private arrivi As New Date[MAX_NUMERO]
Private CurrAct As String
Private FotON As Boolean
Private INV1 As Integer
Private INV2 As Integer

' Flag di shutdown: serve a evitare race tra Form_Close (distrugge i
' widget) e Timer4_Timer (che dopo un WAIT 0.1 potrebbe ancora chiamare
' SetArduinoStatus e toccare LabelArduino gia' invalido).
Private $shuttingDown As Boolean

' --- Arduino (gestito dinamicamente per workaround bug Gambas) ---
' SerialPort.Open su un oggetto gia' chiuso non riarma il listener
' di _Read. Ricreiamo l'oggetto a ogni riconnessione e riattacchiamo
' gli event handler con Object.Attach($hSerial, Me, "Arduino").
Private $hSerial As SerialPort

' --- Align (sync via web, RECEIVER) ---
Private $alignEnabled As Boolean
Private $alignUrl As String
Private $alignUser As String
Private $alignPass As String
Private $alignSessionConfig As String
Private $alignLastSession As Long
Private $alignLastSeq As Long
Private $alignBuffer As String
Private $alignBackoffSec As Integer
Private $alignWantReconnect As Boolean
Private $hAlignHttp As HttpClient

' --- Layout responsivo (Form_Resize) ---
' Catturati al primo Form_Resize (post-creazione). $rsDesigned protegge il
' setup one-shot. La GridView cresce in entrambe le direzioni, il blocco
' inferiore (bottoni + IN ARRIVO + status bar) e' ancorato al fondo,
' alcuni widget anche al lato destro (colonna 4 + Impostazioni).
Private $rsDesigned As Boolean
Private $rsDesignW As Integer
Private $rsDesignH As Integer
Private $rsOrigGridW As Integer
Private $rsOrigGridH As Integer
Private $rsBtmCtrl As Object[]
Private $rsBtmOrigTop As New Integer[]
Private $rsRgtCtrl As Object[]
Private $rsRgtOrigLeft As New Integer[]

' --- Google Sheets (writer, opzionale) ---
Private $sheet As CSheet

PUBLIC SUB _new()

END

PUBLIC SUB Arduino_Read()

DIM s AS String
DIM iLof AS Integer
iLof = 0
TRY iLof = Lof($hSerial)
IF Error THEN
  ArduinoClose()
  RETURN
ENDIF
TRY READ #$hSerial, s, iLof
IF Error THEN
  ArduinoClose()
  RETURN
ENDIF
IF FotON = TRUE THEN
BArrivi.Add(Format$(Time, "hh:nn:ss.uuu"))
ENDIF

END

PRIVATE SUB SetArduinoStatus(bConnected AS Boolean)
  ' Durante shutdown LabelArduino puo' essere gia' distrutto: ritorno
  ' subito per evitare "Invalid object" (race con Timer4_Timer in WAIT).
  IF $shuttingDown THEN RETURN
  IF bConnected THEN
    LabelArduino.Background = &H00CC00&
    LabelArduino.Foreground = &HFFFFFF&
    LabelArduino.Text = "ARDUINO OK"
  ELSE
    LabelArduino.Background = &HCC0000&
    LabelArduino.Foreground = &HFFFFFF&
    LabelArduino.Text = "NO ARDUINO"
  ENDIF
END

PUBLIC SUB ConfermaScartoOrario(che AS String) AS Boolean
  ' Conferma per chiudere senza salvare un dialog che contiene un orario
  ' volatile (es. cattura fotocellula). Ritorna True se l'utente conferma
  ' lo scarto. Usata da FArrivo/FPartenza sul pulsante Annulla.
  DIM sCosa AS String
  IF che = "" THEN
    sCosa = "L'orario"
  ELSE
    sCosa = "L'orario di " & che
  ENDIF
  RETURN Message.Question("Sei sicuro di voler annullare l'inserimento? " & sCosa & " verrà perso definitivamente.", "Annulla l'inserimento", "Continua a inserire") = 1
END

Private Sub AlignLoadConfig() As Boolean
  ' Carica ~/.config/brrm/align.conf (key=value, # commento). Tutti i campi
  ' richiesti: url, username, password. Default per session: "default".
  Dim sPath As String
  Dim sLine As String
  Dim sKey As String
  Dim sVal As String
  Dim iEq As Integer
  sPath = User.Home &/ ".config/brrm/align.conf"
  $alignSessionConfig = "default"
  If Not Exist(sPath) Then Return False
  For Each sLine In Split(File.Load(sPath), gb.NewLine)
    sLine = Trim$(sLine)
    If sLine = "" Then Continue
    If Left$(sLine, 1) = "#" Then Continue
    iEq = InStr(sLine, "=")
    If iEq < 2 Then Continue
    sKey = LCase$(Trim$(Left$(sLine, iEq - 1)))
    sVal = Trim$(Mid$(sLine, iEq + 1))
    Select Case sKey
      Case "url"
        $alignUrl = sVal
      Case "username"
        $alignUser = sVal
      Case "password"
        $alignPass = sVal
      Case "session"
        $alignSessionConfig = sVal
    End Select
  Next
  Return ($alignUrl <> "" And $alignUser <> "" And $alignPass <> "")
End

Public Sub AlignReinit()
  ' Chiamato dalla form Settings dopo aver scritto il config: chiude
  ' lo stream corrente e fa ripartire AlignInit da zero.
  TimerAlignWatchdog.Stop
  If $hAlignHttp Then
    Try $hAlignHttp.Stop
    $hAlignHttp = Null
  Endif
  $alignWantReconnect = False
  $alignUrl = ""
  $alignUser = ""
  $alignPass = ""
  $alignSessionConfig = ""
  $alignLastSession = 0
  AlignInit()
End

Public Sub AlignInit()
  ' Punto di ingresso: chiamato da Form_Open. Se non configurato, no-op.
  $alignEnabled = AlignLoadConfig()
  If Not $alignEnabled Then
    LabelSync.Visible = False
    Return
  Endif
  $alignLastSession = 0
  $alignLastSeq = 0
  LoadAlignState()
  $alignBuffer = ""
  $alignBackoffSec = 1
  $alignWantReconnect = False
  ' Niente stato prematuro: label nascosta finche' non abbiamo un esito
  ' definitivo (primo chunk = SYNC OK; oppure errore/disconnessione = FAIL).
  LabelSync.Visible = False
  AlignStartStream()
End

Private Sub LoadAlignState()
  ' Carica (session, seq) dal file arrivo-align-state. Se non esiste,
  ' migra dal vecchio arrivo-align-lastseq (solo seq, session_id=0:
  ' qualunque evento con session_id>=1 sara' "successivo", che e' il
  ' comportamento giusto).
  Dim sStatePath As String
  Dim sLegacyPath As String
  Dim r As Long[]
  sStatePath = User.Home &/ ".local/share/brrm/arrivo-align-state"
  sLegacyPath = User.Home &/ ".local/share/brrm/arrivo-align-lastseq"

  If Exist(sStatePath) Then
    r = MAlignSync.DecodeStateFile(File.Load(sStatePath))
    If r <> Null Then
      $alignLastSession = r[0]
      $alignLastSeq = r[1]
      Return
    Endif
    $alignLastSession = 0
    $alignLastSeq = 0
  Endif

  If Exist(sLegacyPath) Then
    Try $alignLastSeq = CLong(Trim$(File.Load(sLegacyPath)))
    $alignLastSession = 0
    SaveAlignState()
    Try Kill sLegacyPath
  Endif
End

Private Sub SaveAlignState()
  MFile.AtomicSave(User.Home &/ ".local/share/brrm/arrivo-align-state", MAlignSync.EncodeStateFile($alignLastSession, $alignLastSeq))
End

Private Sub AlignSetStatus(connected As Boolean, Optional detail As String)
  ' Una qualsiasi chiamata a SetStatus rende visibile l'indicatore.
  ' Il `detail` finisce nel tooltip per troubleshooting.
  LabelSync.Visible = True
  If connected Then
    LabelSync.Background = &H00CC00&
    LabelSync.Text = "SYNC OK"
    If detail = "" Then detail = "Stream connesso"
  Else
    LabelSync.Background = &HCC0000&
    LabelSync.Text = "SYNC FAIL"
    If detail = "" Then detail = "Errore di sincronizzazione"
  Endif
  LabelSync.Tooltip = detail & gb.NewLine & "URL: " & $alignUrl & gb.NewLine & "Session: " & $alignSessionConfig & gb.NewLine & "Ultimo (sess, seq): (" & CStr($alignLastSession) & ", " & CStr($alignLastSeq) & ")"
End

Private Sub AlignStartStream()
  ' Apre la connessione SSE long-lived. _Read fira per ogni chunk, _Finished
  ' quando il server o la rete chiudono (→ schedula riconnessione).
  If Not $alignEnabled Then Return
  TimerAlignWatchdog.Stop
  If $hAlignHttp Then
    Try $hAlignHttp.Stop
    $hAlignHttp = Null
  Endif
  $alignBuffer = ""
  $hAlignHttp = New HttpClient As "AlignHttp"
  $hAlignHttp.URL = $alignUrl & "/stream?session=" & $alignSessionConfig & "&since_sess=" & CStr($alignLastSession) & "&since=" & CStr($alignLastSeq)
  $hAlignHttp.Auth = Net.AuthBasic
  $hAlignHttp.User = $alignUser
  $hAlignHttp.Password = $alignPass
  $hAlignHttp.Async = True
  $hAlignHttp.Timeout = 0   ' stream long-lived, niente timeout
  Try $hAlignHttp.Get()
  If Error Then
    AlignSetStatus(False, "Errore apertura stream: " & Error.Text)
    AlignScheduleReconnect()
    Return
  Endif
  ' Watchdog: 15s di silenzio → riconnetti (keepalive server e' ogni 10s)
  $alignWantReconnect = False
  TimerAlignWatchdog.Delay = 15000
  TimerAlignWatchdog.Start
End

Public Sub AlignHttp_Read()
  ' Chunk SSE ricevuto: accumula nel buffer ed estrai i blocchi completi
  ' (delimitati da "\n\n"). Reset del watchdog ad ogni chunk.
  Dim sChunk As String
  Dim iSep As Integer
  Dim sBlock As String
  sChunk = ""
  Try Read #$hAlignHttp, sChunk, Lof($hAlignHttp)
  If sChunk = "" Then Return
  ' Normalizza CRLF → LF per parsing semplice
  sChunk = Replace(sChunk, Chr(13), "")
  $alignBuffer &= sChunk
  TimerAlignWatchdog.Stop
  TimerAlignWatchdog.Delay = 15000
  $alignWantReconnect = False
  TimerAlignWatchdog.Start
  AlignSetStatus(True, "Stream attivo")
  $alignBackoffSec = 1
  Do
    iSep = InStr($alignBuffer, "\n\n")
    If iSep = 0 Then Break
    sBlock = Left$($alignBuffer, iSep - 1)
    $alignBuffer = Mid$($alignBuffer, iSep + 2)
    AlignProcessBlock(sBlock)
  Loop
End

Public Sub AlignHttp_Finished()
  ' Server o rete hanno chiuso lo stream — riconnetti con backoff.
  AlignSetStatus(False, "Stream chiuso (HTTP " & $hAlignHttp.Code & "), riconnessione in corso")
  AlignScheduleReconnect()
End

Public Sub AlignHttp_Error()
  AlignSetStatus(False, "Errore di rete sullo stream")
  AlignScheduleReconnect()
End

Private Sub AlignScheduleReconnect()
  ' Backoff esponenziale 1→2→4→…→60s. TimerAlignWatchdog viene riusato
  ' come single-shot per il delay (distinto dal watchdog via flag).
  If Not $alignEnabled Then Return
  TimerAlignWatchdog.Stop
  If $alignBackoffSec < 60 Then $alignBackoffSec = $alignBackoffSec * 2
  If $alignBackoffSec > 60 Then $alignBackoffSec = 60
  TimerAlignWatchdog.Delay = $alignBackoffSec * 1000
  $alignWantReconnect = True
  TimerAlignWatchdog.Start
End

Public Sub TimerAlignWatchdog_Timer()
  TimerAlignWatchdog.Stop
  If $alignWantReconnect Then
    $alignWantReconnect = False
    AlignStartStream()
    Return
  Endif
  ' Watchdog scaduto (15s senza dati) → tratta come disconnessione
  AlignSetStatus(False, "Nessun dato dallo stream per 15s (keepalive perso)")
  AlignScheduleReconnect()
End

Private Sub AlignProcessBlock(sBlock As String)
  ' Un blocco SSE puo' contenere righe "event:", "data:", commenti (":"),
  ' "id:", "retry:". Estrae solo event+data e li passa ad AlignApplyEvent.
  Dim sLine As String
  Dim sEventType As String
  Dim sData As String
  sEventType = ""
  sData = ""
  For Each sLine In Split(sBlock, "\n")
    If sLine = "" Then Continue
    If Left$(sLine, 1) = ":" Then Continue   ' commento SSE
    If Left$(sLine, 7) = "event: " Then
      sEventType = Mid$(sLine, 8)
    Else If Left$(sLine, 6) = "data: " Then
      If sData = "" Then
        sData = Mid$(sLine, 7)
      Else
        sData = sData & "\n" & Mid$(sLine, 7)
      Endif
    Endif
  Next
  If sData = "" Then Return
  AlignApplyEvent(sEventType, sData)
End

Private Sub AlignApplyEvent(sEventType As String, sData As String)
  ' Applica un evento SSE allo stato locale. Idempotente: scarta seq gia' visti.
  Dim iSeq As Long
  Dim iSess As Long
  Dim iNumero As Integer
  Dim sOrario As String
  Dim dPartenza As Date
  Dim iMinSess As Long
  Dim iMinSeq As Long
  Dim bGap As Boolean
  Dim ev As Variant

  ev = Null
  Try ev = JSON.Decode(sData)
  If IsNull(ev) Then Return

  Select Case sEventType
    Case "meta"
      ' Gap detection lessicografica. Se la cache server e' avanzata oltre
      ' la nostra (last_session, last_seq) - 1, allineiamo per accettare
      ' lo snapshot.
      iMinSess = 0
      iMinSeq = 0
      Try iMinSess = CLong(ev["min_sess"])
      Try iMinSeq = CLong(ev["min_seq"])
      If iMinSess > 0 And If iMinSeq > 0 Then
        bGap = False
        If $alignLastSession < iMinSess Then
          bGap = True
        Else If $alignLastSession = iMinSess And If $alignLastSeq < iMinSeq - 1 Then
          bGap = True
        Endif
        If bGap Then
          $alignLastSession = iMinSess
          $alignLastSeq = iMinSeq - 1
          SaveAlignState()
        Endif
      Endif

    Case "event"
      iSess = 0
      iSeq = 0
      Try iSess = CLong(ev["session_id"])
      Try iSeq = CLong(ev["seq"])
      ' Dedup lessicografica: scarta se (sess, seq) <= (last_sess, last_seq).
      If iSess < $alignLastSession Then Return
      If iSess = $alignLastSession And If iSeq <= $alignLastSeq Then Return

      iNumero = 0
      Try iNumero = CInt(ev["numero"])
      If iNumero <= 0 Or iNumero >= MAX_NUMERO Then Return
      sOrario = ""
      Try sOrario = CStr(ev["orario"])
      Timer1.Stop
      If sOrario = "" Then
        partenze[iNumero] = 0
      Else
        dPartenza = 0
        Try dPartenza = sOrario
        If dPartenza <> 0 Then
          partenze[iNumero] = dPartenza
          If LEquipaggi.Find(iNumero) < 0 Then LEquipaggi.Add(iNumero)
        Endif
      Endif
      $alignLastSession = iSess
      $alignLastSeq = iSeq
      SaveAlignState()
      UpgradeSessionFile()
      Timer1.Start
      If $sheet Then $sheet.UpdateForEquipaggio(iNumero)

    ' "keepalive" e altri tipi: nessuna azione (il reset del watchdog avviene
    ' gia' in AlignHttp_Read per qualsiasi chunk ricevuto).
  End Select
End

PUBLIC SUB UpgradeSessionFile()
  ' Formato v1: prima riga = magic header, righe successive numero|partenza|arrivo.
  ' Campi vuoti = nessun dato. FormatDateMs preserva i ms (Str$ li scartava).
  DIM Counter AS Integer
  DIM iEqui AS Integer
  DIM sFileOut AS String
  DIM sPart AS String
  DIM sArr AS String

  sFileOut = "brrm-session v1" & gb.NewLine
  FOR Counter = 0 TO LEquipaggi.Count - 1
    iEqui = 0
    TRY iEqui = LEquipaggi[Counter].Text
    IF iEqui <= 0 THEN CONTINUE
    sPart = ""
    IF partenze[iEqui] <> 0 THEN sPart = MTime.FormatDateMs(partenze[iEqui])
    sArr = ""
    IF arrivi[iEqui] <> 0 THEN sArr = MTime.FormatDateMs(arrivi[iEqui])
    sFileOut &= iEqui & "|" & sPart & "|" & sArr & gb.NewLine
  NEXT
  MFile.AtomicSave(User.Home &/ ".local/share/brrm/arrivo-session", sFileOut)
END

PUBLIC SUB SetPartenza(Equipaggio AS Integer, Partenza AS Date)

  Timer1.Stop
  partenze[Equipaggio] = Partenza
  UpgradeSessionFile()
  Timer1.Start
  IF $sheet THEN $sheet.UpdateForEquipaggio(Equipaggio)
END

PUBLIC SUB ReturnArrivo(Numero AS Integer) AS Date
  
  RETURN arrivi[Numero]
  
END

PUBLIC SUB ReturnPartenza(Numero AS Integer) AS Date
  
  RETURN partenze[Numero]
  
END

PUBLIC SUB SetupGridHeader()
  ' Configurazione fissa dell'header (riga 0). Idempotente: chiamabile
  ' tutte le volte che serve. Necessario richiamarla dopo IMPORTA perche'
  ' Message.Info + altri eventi Qt resettano le proprieta' delle celle.
  GridView1.Columns.Count = 4
  GridView1.Rows.Count = Max(GridView1.Rows.Count, 1)
  GridView1.Columns[0].Width = GridView1.Width - 500
  GridView1.Columns[1].Width = 150
  GridView1.Columns[2].Width = 150
  GridView1.Columns[3].Width = 150
  GridView1[0, 0].Background = &H000000&
  GridView1[0, 1].Background = &H000000&
  GridView1[0, 2].Background = &H000000&
  GridView1[0, 3].Background = &H000000&
  GridView1[0, 0].Foreground = &HFF9999&
  GridView1[0, 1].Foreground = &HFFFFFF&
  GridView1[0, 2].Foreground = &HFFFFFF&
  GridView1[0, 3].Foreground = &HFF9999&
  GridView1[0, 0].Text = "Equipaggio"
  GridView1[0, 1].Text = "Partenza"
  GridView1[0, 2].Text = "Arrivo"
  GridView1[0, 3].Text = "Tempo"
END

Public Sub Form_Resize()
  ' Layout responsivo: GridView cresce sia in larghezza che in altezza,
  ' tutto il blocco sotto (button area + status bar) e' ancorato al
  ' bordo inferiore, e i bottoni della colonna 4 + Impostazioni sono
  ' ancorati al bordo destro.
  '
  ' Il design iniziale (dimensioni form, dimensioni grid, posizioni
  ' originali dei widget) viene catturato al primo Form_Resize, perche'
  ' Form_Open viene chiamato prima che Width/Height riflettano il
  ' MoveScaled del form-file. Min-size = design size (non scendiamo
  ' mai sotto il layout originale, che e' gia' denso).
  Dim i As Integer
  Dim c As Control
  Dim dW, dH As Integer

  If Not $rsDesigned Then
    $rsDesignW = Me.Width
    $rsDesignH = Me.Height
    $rsOrigGridW = GridView1.Width
    $rsOrigGridH = GridView1.Height
    $rsBtmCtrl = [Button2, Button3, Button4, Button5, Button6, Button7, Button8, Button9, Button10, Button1, ButtonImporta, ButtonChangeNum, Label1, Label2, LabelArduino, LabelSync, LabelSheet, ButtonSettings]
    $rsRgtCtrl = [Button6, Button7, Button8, ButtonImporta, Button1, ButtonSettings]
    For Each c In $rsBtmCtrl
      $rsBtmOrigTop.Add(c.Top)
    Next
    For Each c In $rsRgtCtrl
      $rsRgtOrigLeft.Add(c.Left)
    Next
    Me.MinW = $rsDesignW
    Me.MinH = $rsDesignH
    $rsDesigned = True
    Return
  Endif

  dW = Me.Width - $rsDesignW
  dH = Me.Height - $rsDesignH
  If dW < 0 Then dW = 0
  If dH < 0 Then dH = 0

  GridView1.Width = $rsOrigGridW + dW
  GridView1.Height = $rsOrigGridH + dH

  For i = 0 To $rsBtmCtrl.Max
    c = $rsBtmCtrl[i]
    c.Top = $rsBtmOrigTop[i] + dH
  Next
  For i = 0 To $rsRgtCtrl.Max
    c = $rsRgtCtrl[i]
    c.Left = $rsRgtOrigLeft[i] + dW
  Next
End

PUBLIC SUB Form_Open()
DIM sTest AS String
DIM aLines AS String[]
DIM aFields AS String[]
DIM iEqui AS Integer
DIM iNum AS Integer
FotON = TRUE
FMain.Center()
SetupGridHeader()
' Loader formato v1: scarta silenziosamente se l'header non e' atteso.
sTest = ""
IF Exist(User.Home &/ ".local/share/brrm/arrivo-session") THEN sTest = File.Load(User.Home &/ ".local/share/brrm/arrivo-session")
aLines = Split(sTest, gb.NewLine)
IF aLines.Count >= 1 AND IF aLines[0] = "brrm-session v1" THEN
  FOR iEqui = 1 TO aLines.Max
    aFields = Split(Trim$(aLines[iEqui]), "|")
    IF aFields.Count < 3 THEN CONTINUE
    iNum = 0
    TRY iNum = CInt(aFields[0])
    IF iNum <= 0 OR iNum >= MAX_NUMERO THEN CONTINUE
    LEquipaggi.Add(iNum)
    IF aFields[1] <> "" THEN TRY partenze[iNum] = aFields[1]
    IF aFields[2] <> "" THEN TRY arrivi[iNum] = aFields[2]
  NEXT
ENDIF
Timer1.Start()
AlignInit()
$sheet = New CSheet
$sheet.Init()
END

Public Sub SheetReinit()
  ' Chiamato da FSettings dopo salvataggio config.
  If $sheet Then $sheet.Reinit()
End

PUBLIC SUB Timer1_Timer()
' Guard: ogni Message dialog (Question/Info/Error) resetta il formatting
' delle celle del row 0. Ricontrolliamo qui e ri-applichiamo se serve.
IF GridView1[0, 0].Background <> &H000000& THEN SetupGridHeader()
DIM concorrente AS Integer
DIM sDisplay AS String
DIM totale AS Integer
DIM Counter AS Integer
DIM deltaMs AS Long
DIM tArrivo AS Date
DIM indice AS Integer
totale = LEquipaggi.Count
Counter = 0
GridView1.Rows.Count = totale + 1
WHILE Counter < totale
TRY concorrente = LEquipaggi[Counter].Text
GridView1[Counter + 1, 0].Text = concorrente
sDisplay = ""
IF partenze[concorrente] = 0 AND arrivi[concorrente] = 0 THEN
  LEquipaggi.Remove(LEquipaggi.Find(concorrente))
  UpgradeSessionFile()
  totale = totale - 1
  GridView1.Rows.Count = totale + 1
  ' Counter NON viene incrementato: il prossimo equipaggio si e' spostato
  ' nella posizione corrente.
  CONTINUE
ENDIF
IF partenze[concorrente] = 0 THEN
  sDisplay = "NO DATI PARTENZA"
ELSE
  ' Durata in ms come differenza intera. Display "minuti:secondi.millis"
  ' dove minuti possono superare 60 (es. 188:43.333 per 3h 08m 43s 333ms).
  IF arrivi[concorrente] <> 0 THEN
    tArrivo = arrivi[concorrente]
  ELSE
    tArrivo = Time
  ENDIF
  deltaMs = MTime.MsInDay(tArrivo) - MTime.MsInDay(partenze[concorrente])
  IF deltaMs < 0 THEN deltaMs = deltaMs + 86400000
  sDisplay = CStr(deltaMs \ 60000) & ":" & Format$((deltaMs \ 1000) MOD 60, "00") & "." & Format$(deltaMs MOD 1000, "000")
ENDIF
TRY GridView1[Counter + 1, 1].Text = ""
IF partenze[concorrente] <> 0 THEN TRY GridView1[Counter + 1, 1].Text = MTime.FormatDateMs(partenze[concorrente])
TRY GridView1[Counter + 1, 2].Text = ""
IF arrivi[concorrente] <> 0 THEN TRY GridView1[Counter + 1, 2].Text = MTime.FormatDateMs(arrivi[concorrente])
TRY GridView1[Counter + 1, 3].Text = sDisplay
Counter = Counter + 1
WEND
indice = 0
Counter = 0
WHILE Counter < LEquipaggi.Count
IF arrivi[LEquipaggi[Counter].Text] = 0 THEN 
Label2.Text = LEquipaggi[Counter].Text
indice = 1
BREAK 
ENDIF 
Counter = Counter + 1
WEND 
IF indice = 0 THEN 
Label2.Text = "/"
ENDIF 
END

PUBLIC SUB Button1_Click()
DIM Counter AS Integer
IF Message.Question("Sei sicuro?", "Sì", "No") = 1 THEN 
IF Message.Question("Sei DAVVERO sicuro??? Poi non pentirti eh, non puoi più annullare ciò che stai per fare!", "Sì, dai non rompere e fammi resettare!!!", "No no!!! Argh, cosa stavo per fare! Per fortuna mi hai avvertito!") = 1
Timer1.Stop
LEquipaggi.Clear
Counter = 0
WHILE Counter < MAX_NUMERO
partenze[Counter] = 0
arrivi[Counter] = 0
Counter = Counter + 1
WEND 
UpgradeSessionFile()
ENDIF 
ENDIF 
Timer1.Start
END

PUBLIC SUB EditOrder(Order AS String)
  
  DIM aOrdine AS String[]
  DIM iEqui AS Integer
  DIM Number AS Integer
  Timer1.Stop
  LEquipaggi.Clear
  aOrdine = Split(Order, "-")
  GridView1.Rows.Count = aOrdine.Count + 1
  Number = 0
  FOR EACH iEqui IN aOrdine
  LEquipaggi.Add(iEqui)
  NEXT 
  Timer1.Start
END

PUBLIC SUB Button5_Click()

IF CurrAct = ACT_ANNARR THEN 

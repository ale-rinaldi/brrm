Private Sub ChangeNumero(oldNum As Integer, newNum As Integer)
  ' Rinomina la riga: porta sia la partenza che l'arrivo al nuovo numero,
  ' preservando la posizione nell'ordine equipaggi. Operazione locale: NON
  ' viene propagata via sync (canale upstream non esiste in brrm).
  Dim idx As Integer
  Dim dPart As Date
  Dim dArr As Date
  dPart = partenze[oldNum]
  dArr = arrivi[oldNum]
  partenze[newNum] = dPart
  arrivi[newNum] = dArr
  partenze[oldNum] = 0
  arrivi[oldNum] = 0
  idx = LEquipaggi.Find(oldNum)
  If idx >= 0 Then
    LEquipaggi[idx].Text = newNum
  Else
    LEquipaggi.Add(newNum)
  Endif
  UpgradeSessionFile()
  If $sheet Then
    $sheet.UpdateForEquipaggio(oldNum)   ' clear vecchia riga
    $sheet.UpdateForEquipaggio(newNum)   ' scrivi nuova riga
  Endif
End

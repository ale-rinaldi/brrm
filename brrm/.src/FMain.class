PUBLIC SUB Button6_Click()
  ' Export CSV completo (stessi campi che scriviamo su Sheets):
  '   numero,
  '   partenza_hh,partenza_mm,partenza_ss,partenza_ms,partenza_unix_ms,
  '   arrivo_hh,arrivo_mm,arrivo_ss,arrivo_ms,arrivo_unix_ms,
  '   tempo_mm,tempo_ss,tempo_ms,tempo_total_ms
  ' tempo_mm e' minuti totali (puo' essere >= 60, come su Sheets).
  ' Esporta tutti gli equipaggi presenti in lista. Per le righe con
  ' partenza o arrivo mancanti, le rispettive colonne (e quelle tempo,
  ' se manca uno dei due) sono lasciate vuote.
  DIM Counter AS Integer
  DIM iEqui AS Integer
  DIM dPart AS Date
  DIM dArr AS Date
  DIM iPartMs AS Integer
  DIM iArrMs AS Integer
  DIM delta AS Long
  DIM sOut AS String
  DIM sPath AS String

  sOut = "numero,partenza_hh,partenza_mm,partenza_ss,partenza_ms,partenza_unix_ms,arrivo_hh,arrivo_mm,arrivo_ss,arrivo_ms,arrivo_unix_ms,tempo_mm,tempo_ss,tempo_ms,tempo_total_ms\n"

  FOR Counter = 0 TO LEquipaggi.Count - 1
    iEqui = 0
    TRY iEqui = LEquipaggi[Counter].Text
    IF iEqui = 0 THEN CONTINUE
    sOut &= iEqui & ","
    IF partenze[iEqui] = 0 THEN
      sOut &= ",,,,,"
    ELSE
      dPart = partenze[iEqui]
      iPartMs = MTime.MillisOf(dPart)
      sOut &= Hour(dPart) & "," & Minute(dPart) & "," & Second(dPart) & "," & Format$(iPartMs, "000") & "," & MTime.DateToUnixMs(dPart) & ","
    ENDIF
    IF arrivi[iEqui] = 0 THEN
      sOut &= ",,,,,"
    ELSE
      dArr = arrivi[iEqui]
      iArrMs = MTime.MillisOf(dArr)
      sOut &= Hour(dArr) & "," & Minute(dArr) & "," & Second(dArr) & "," & Format$(iArrMs, "000") & "," & MTime.DateToUnixMs(dArr) & ","
    ENDIF
    IF partenze[iEqui] = 0 OR arrivi[iEqui] = 0 THEN
      sOut &= ",,,\n"
    ELSE
      delta = MTime.MsInDay(arrivi[iEqui]) - MTime.MsInDay(partenze[iEqui])
      IF delta < 0 THEN delta = delta + 86400000   ' arrivo dopo mezzanotte
      sOut &= (delta \ 60000) & "," & ((delta \ 1000) MOD 60) & "," & Format$(delta MOD 1000, "000") & "," & delta & "\n"
    ENDIF
  NEXT

  Dialog.Title = "Salva risultati gara"
  Dialog.Filter = ["*.csv", "File CSV"]
  Dialog.Path = User.Home &/ "brrm-arrivi.csv"
  IF Dialog.SaveFile() THEN RETURN     ' utente ha annullato
  sPath = Dialog.Path
  IF LCase$(File.Ext(sPath)) <> "csv" THEN sPath = sPath & ".csv"
  TRY File.Save(sPath, sOut)
  IF Error THEN Message.Error("Impossibile salvare il file: " & Error.Text)
END

PUBLIC SUB ButtonImporta_Click()
  ' Importa orari di partenza da CSV (formato esportato da brrm-partenza:
  ' numero,partenza_hh,partenza_mm,partenza_ss,partenza_ms,partenza_unix_ms;
  ' colonne >5 vengono ignorate, righe con primo campo non numerico — incluso
  ' l'header — vengono saltate automaticamente dal TRY CInt + check <= 0).
  DIM sPath AS String
  DIM aLines AS String[]
  DIM sLine AS String
  DIM aFields AS String[]
  DIM iEqui AS Integer
  DIM sDateStr AS String
  DIM dPart AS Date
  DIM iImportati AS Integer

  Dialog.Title = "Importa orari di partenza"
  Dialog.Filter = ["*.csv", "File CSV"]
  Dialog.Path = User.Home &/ "brrm-partenze.csv"
  IF Dialog.OpenFile() THEN RETURN     ' utente ha annullato
  sPath = Dialog.Path
  IF NOT Exist(sPath) THEN
    Message.Error("File non trovato: " & sPath)
    RETURN
  ENDIF

  Timer1.Stop
  aLines = Split(File.Load(sPath), "\n")
  FOR EACH sLine IN aLines
    sLine = Trim$(sLine)
    IF sLine = "" THEN CONTINUE
    aFields = Split(sLine, ",")
    IF aFields.Count < 5 THEN CONTINUE
    iEqui = 0
    TRY iEqui = CInt(Trim$(aFields[0]))
    IF iEqui <= 0 OR iEqui >= MAX_NUMERO THEN CONTINUE
    sDateStr = Trim$(aFields[1]) & ":" & Trim$(aFields[2]) & ":" & Trim$(aFields[3]) & "." & MTime.PadMillis(Trim$(aFields[4]))
    dPart = 0
    TRY dPart = sDateStr
    IF dPart = 0 THEN CONTINUE
    partenze[iEqui] = dPart
    IF LEquipaggi.Find(iEqui) < 0 THEN LEquipaggi.Add(iEqui)
    iImportati = iImportati + 1
  NEXT

  UpgradeSessionFile()
  Timer1.Start
  Message.Info(iImportati & " orari di partenza importati.")
END

PUBLIC SUB GridView1_Click()
DIM pt1 AS Date
DIM pt2 AS Date
  IF GridView1.Row > 0 THEN
  IF CurrAct = ACT_ANNPART THEN
  DIM iAnnPartNum AS Integer
  iAnnPartNum = LEquipaggi[GridView1.Row - 1].Text
  IF Message.Question("Sei sicuro di voler annullare la partenza dell'equipaggio numero " & iAnnPartNum & "?", "Sì", "No") = 1 THEN
  Timer1.Stop
  partenze[iAnnPartNum] = 0
  IF $sheet THEN $sheet.UpdateForEquipaggio(iAnnPartNum)
  ENDIF
    GridView1.Background = &H0FFFFFF&
  GridView1.Mouse = 0
  CurrAct = ACT_NONE
  Timer1.Start
  END IF

    IF CurrAct = ACT_ANNARR THEN
    DIM iAnnArrNum AS Integer
    iAnnArrNum = LEquipaggi[GridView1.Row - 1].Text
    IF Message.Question("Sei sicuro di voler annullare l'arrivo dell'equipaggio numero " & iAnnArrNum & "?", "Sì", "No") = 1 THEN
  Timer1.Stop
  arrivi[iAnnArrNum] = 0
  IF $sheet THEN $sheet.UpdateForEquipaggio(iAnnArrNum)
  ENDIF
    GridView1.Background = &H0FFFFFF&
  GridView1.Mouse = 0
  CurrAct = ACT_NONE
  Timer1.Start
  END IF
  
    IF CurrAct = ACT_INVARR2 THEN

  INV2 = LEquipaggi[GridView1.Row - 1].Text
  IF Message.Question("Sei sicuro di voler invertire gli arrivi degli equipaggi " & INV1 & " e " & INV2 & "?", "Sì", "No") = 1 THEN
 Timer1.Stop
  pt1 = arrivi[INV1]
  pt2 = arrivi[INV2]
  arrivi[INV2] = pt1
  arrivi[INV1] = pt2
  IF $sheet THEN
    $sheet.UpdateForEquipaggio(INV1)
    $sheet.UpdateForEquipaggio(INV2)
  ENDIF
  ENDIF
    GridView1.Background = &H0FFFFFF&
  GridView1.Mouse = 0
  CurrAct = ACT_NONE
  Timer1.Start
  END IF
  
  IF CurrAct = ACT_INVARR1 THEN
  INV1 = LEquipaggi[GridView1.Row - 1].Text
  CurrAct = ACT_INVARR2
    GridView1.Background = &H007FFFFF&
    GridView1.Mouse = 2
  END IF

  IF CurrAct = ACT_MODNUM THEN
    DIM iOld AS Integer
    DIM sNew AS String
    DIM iNew AS Integer
    iOld = LEquipaggi[GridView1.Row - 1].Text
    Timer1.Stop
    sNew = InputBox("Nuovo numero per l'equipaggio " & iOld & ":", "Cambia numero")
    IF sNew <> "" THEN
      iNew = 0
      TRY iNew = CInt(Trim$(sNew))
      IF iNew <= 0 OR iNew >= MAX_NUMERO THEN
        Message.Error("Numero non valido. Deve essere fra 1 e 9999.")
      ELSE IF iNew = iOld THEN
        ' no-op
      ELSE IF LEquipaggi.Find(iNew) >= 0 THEN
        Message.Error("L'equipaggio " & iNew & " esiste già: non posso assegnare lo stesso numero a due righe.")
      ELSE
        ChangeNumero(iOld, iNew)
      ENDIF
    ENDIF
    Timer1.Start
    GridView1.Background = &H0FFFFFF&
    GridView1.Mouse = 0
    CurrAct = ACT_NONE
  END IF

ENDIF
UpgradeSessionFile()
END


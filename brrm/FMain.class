' Gambas class file

prow AS Integer
partenze AS NEW Date[10000]
arrivi AS NEW Date[10000]
startposindex AS Integer
stopposindex AS Integer
posingrid AS NEW Integer[10000]
CurrAct AS String
numingrid AS NEW Integer[10000]
ChangingN AS Integer
FotON AS Boolean
INV1 AS Integer
INV2 AS Integer

PUBLIC SUB _new()

END

PUBLIC SUB SerialPort1_Read()
  
DIM s AS String
READ #SerialPort1, s, Lof(SerialPort1)
IF FotON = TRUE THEN
BArrivi.Add(Time)
ENDIF 
   
  
END

PUBLIC SUB UpgradeSessionFile()
  DIM Counter AS Integer
  DIM FileOut AS String
  Counter = 0
  TRY Counter = LEquipaggi[0].Text
  IF Counter <> 0 THEN 
  FileOut = LEquipaggi[0].Text & " " & partenze[LEquipaggi[0].Text] & " " & arrivi[LEquipaggi[0].Text]
  Counter = 1
  WHILE Counter < LEquipaggi.Count
  FileOut = FileOut & "-" & LEquipaggi[Counter].Text & " " & partenze[LEquipaggi[Counter].Text] & " " & arrivi[LEquipaggi[Counter].Text]
  Counter = Counter + 1
  WEND 
  ENDIF 
  FileOut = Trim$(FileOut)
  SHELL "echo " & FileOut & " > ~/.brrm-session"

END


PUBLIC SUB SetPartenza(Equipaggio AS Integer, Partenza AS Date)
  
  Timer1.Stop
  partenze[Equipaggio] = Partenza
  UpgradeSessionFile()
  Timer1.Start
END

PUBLIC SUB ReturnArrivo(Numero AS Integer) AS Date
  
  RETURN arrivi[Numero]
  
END

PUBLIC SUB ReturnPartenza(Numero AS Integer) AS Date
  
  RETURN partenze[Numero]
  
END

PUBLIC SUB Form_Open()
DIM sTest AS String
DIM aTest AS String[]
DIM aTest2 AS String[]
FotON = TRUE
FMain.Center()
GridView1.Columns.Count = 4
GridView1.Rows.Count = 1
GridView1.Columns[0].Width = GridView1.Width - 500

GridView1.Columns[1].Width = 150
GridView1.Columns[2].Width = 150
GridView1.Columns[3].Width = 150
GridView1[0, 0].BackColor = &H000000&
GridView1[0, 1].BackColor = &H000000&
GridView1[0, 2].BackColor = &H000000&
GridView1[0, 3].BackColor = &H000000&
GridView1[0, 0].ForeColor = &HFF9999&
GridView1[0, 1].ForeColor = &HFFFFFF&
GridView1[0, 2].ForeColor = &HFFFFFF&
GridView1[0, 3].ForeColor = &HFF9999&
GridView1[0, 0].Text = "Equipaggio"
GridView1[0, 1].Text = "Partenza"
GridView1[0, 2].Text = "Arrivo"
GridView1[0, 3].Text = "Tempo"
TRY SerialPort1.Open
IF SerialPort1.Status = 0 THEN 
Message("ARDUINO Error")
ENDIF
SHELL "cat ~/.brrm-session" TO sTest
sTest = Trim$(sTest)
aTest = Split(sTest, "-")
FOR EACH sTest IN aTest
aTest2 = Split(sTest, " ")
LEquipaggi.Add(aTest2[0])
partenze[aTest2[0]] = aTest2[1]
arrivi[aTest2[0]] = aTest2[2]
NEXT 
Timer1.Start()
END 

PUBLIC SUB Timer1_Timer()
DIM concorrente AS Integer
DIM asd AS Date
DIM asdd AS String
DIM aAsd AS String[]
DIM posgrid AS Integer
DIM indice AS Integer
DIM totale AS Integer
DIM Counter AS Integer
totale = 0
indice = 0
asdd = ""
totale = LEquipaggi.Count
Counter = 0
GridView1.Rows.Count = totale + 1
WHILE Counter < totale 
TRY concorrente = LEquipaggi[Counter].Text
GridView1[Counter + 1, 0].Text = concorrente
IF partenze[concorrente] <> 0 AND arrivi[concorrente] <> 0 THEN
asd = arrivi[concorrente] - partenze[concorrente]
asdd = asd
ENDIF  
IF partenze[concorrente] <> 0 AND arrivi[concorrente] = 0 THEN 
asd = Time - partenze[concorrente]
asdd = asd
ENDIF 
IF partenze[concorrente] = 0 AND arrivi[concorrente] = 0 THEN 
LEquipaggi.Remove(LEquipaggi.Find(concorrente))
UpgradeSessionFile()
ENDIF 
IF partenze[concorrente] = 0 AND arrivi[concorrente] <> 0 THEN 
asdd = "NO DATI PARTENZA"
ENDIF 
aAsd = Split(asdd, ".")
asdd = ""
TRY asdd = aAsd[0] & "." & twoDecs(aAsd[1])
IF asdd = "" THEN 
asdd = aAsd[0]
ENDIF 
aAsd = Split(asdd, ":")
asdd = ""
TRY asdd = aAsd[1] & ":" & aAsd[2]
IF asdd = "" THEN 
asdd = aAsd[0]
ENDIF 
TRY GridView1[Counter + 1, 1].Text = partenze[concorrente]
TRY GridView1[Counter + 1, 2].Text = arrivi[concorrente]
TRY GridView1[Counter + 1, 3].Text = asdd
indice = indice + 1
Counter = Counter + 1
WEND
indice = 0
Counter = 0
WHILE Counter < LEquipaggi.Count
IF arrivi[LEquipaggi[Counter].Text] = 0 THEN 
Label2.Text = LEquipaggi[Counter].Text
indice = 1
BREAK 
ENDIF 
Counter = Counter + 1
WEND 
IF indice = 0 THEN 
Label2.Text = "/"
ENDIF 
END

PUBLIC SUB Button1_Click()
DIM Counter AS Integer
IF Message.Question("Sei sicuro?", "Sì", "No") = 1 THEN 
IF Message.Question("Sei DAVVERO sicuro??? Poi non pentirti eh, non puoi più annullare ciò che stai per fare!", "Sì, dai non rompere e fammi resettare!!!", "No no!!! Argh, cosa stavo per fare! Per fortuna mi hai avvertito!") = 1
Timer1.Stop
LEquipaggi.Clear
Counter = 0
WHILE Counter < 1000
partenze[Counter] = 0
arrivi[Counter] = 0
Counter = Counter + 1
WEND 
UpgradeSessionFile()
ENDIF 
ENDIF 
Timer1.Start
END

PUBLIC SUB EditOrder(Order AS String)
  
  DIM aOrdine AS String[]
  DIM iEqui AS Integer
  DIM Number AS Integer
  Timer1.Stop
  LEquipaggi.Clear
  aOrdine = Split(Order, "-")
  GridView1.Rows.Count = aOrdine.Count + 1
  Number = 0
  FOR EACH iEqui IN aOrdine
  LEquipaggi.Add(iEqui)
  NEXT 
  startposindex = 1
  stopposindex = 1
  Timer1.Start
END


PUBLIC SUB Button5_Click()

IF CurrAct = "annarr" THEN 
  GridView1.BackColor = &H0FFFFFF&
  GridView1.Mouse = 0
  CurrAct = ""
  ELSE 
CurrAct = "annarr"
GridView1.BackColor = &H00FFFF7F&
GridView1.Mouse = 2
END IF
END

PUBLIC SUB Button4_Click()
IF CurrAct = "invarr1" THEN 
  GridView1.BackColor = &H0FFFFFF&
  GridView1.Mouse = 0
  CurrAct = ""
  ELSE IF CurrAct = "invarr2"
    GridView1.BackColor = &H0FFFFFF&
  GridView1.Mouse = 0
  CurrAct = ""
  ELSE 
  CurrAct = "invarr1"
GridView1.BackColor = &H00FFFF7F&
GridView1.Mouse = 2
ENDIF 
END

PUBLIC SUB Button6_Click()

  DIM Counter AS Integer
  DIM FileAddress AS String
  DIM FileOut AS String
  DIM TTempo AS Date
  DIM sTempo AS String
  DIM sUseful AS String
  DIM sMinutes AS String
  DIM aUseful AS String[]
  DIM sSeconds AS String
  DIM sCents AS String
  Counter = 0
  TRY Counter = LEquipaggi[0].Text
  IF Counter <> 0 THEN 
  Counter = 0
  WHILE Counter <= LEquipaggi.Count
  TRY TTempo = arrivi[LEquipaggi[Counter].Text] - partenze[LEquipaggi[Counter].Text]
  sTempo = TTempo
  
  aUseful = Split(sTempo, ":")
  sMinutes = aUseful[1]
  sUseful = aUseful[2]
  aUseful = Split(sUseful, ".")
  sSeconds = aUseful[0]
  TRY sCents = aUseful[1]
  
TRY FileOut = FileOut & "\n'" & LEquipaggi[Counter].Text & "','" & sMinutes & "','" & sSeconds & "','" & twoDecs(sCents) & "'"
  Counter = Counter + 1
  WEND 
  ENDIF 
  FileOut = Trim$(FileOut)

SHELL "zenity --title=\"Seleziona dove salvare il file CSV\" --file-selection --save  --confirm-overwrite --text=\"Seleziona dove salvare il file CSV\"" TO FileAddress
FileAddress = Trim$(FileAddress)
IF LCase$(Right$(FileAddress, 4)) <> ".csv" THEN 
FileAddress = FileAddress & ".csv"
ENDIF 
SHELL "echo \"" & FileOut & "\" > " & FileAddress

END

PUBLIC SUB twoDecs(number AS String) AS String
  DIM lol AS String
IF Len(number) = 0 THEN 
RETURN "00"
ELSE IF Len(number) < 2 THEN 
RETURN number & "0"
ELSE IF Len(number) > 2 THEN 
RETURN Left$(number, -1)
END IF
RETURN number
END


PUBLIC SUB GridView1_Click()
DIM pt1 AS Date
DIM pt2 AS Date
  IF GridView1.Row > 0 THEN 
  IF CurrAct = "part" THEN 
  Timer1.Stop
  ChangingN = LEquipaggi[GridView1.Row - 1].Text
  FPartenza.Show
  GridView1.BackColor = &H0FFFFFF&
  GridView1.Mouse = 0
    CurrAct = ""
    Timer1.Start
  END IF
    
  IF CurrAct = "annpart" THEN 
  IF Message.Question("Sei sicuro di voler annullare la partenza dell'equipaggio numero " & LEquipaggi[GridView1.Row - 1].Text & "?", "Sì", "No") = 1 THEN 
  Timer1.Stop
  partenze[LEquipaggi[GridView1.Row - 1].Text] = 0
  ENDIF 
    GridView1.BackColor = &H0FFFFFF&
  GridView1.Mouse = 0
  CurrAct = ""
  Timer1.Start
  END IF
  
    IF CurrAct = "annarr" THEN 
    IF Message.Question("Sei sicuro di voler annullare l'arrivo dell'equipaggio numero " & LEquipaggi[GridView1.Row - 1].Text & "?", "Sì", "No") = 1 THEN 
  Timer1.Stop
  arrivi[LEquipaggi[GridView1.Row - 1].Text] = 0
  ENDIF 
    GridView1.BackColor = &H0FFFFFF&
  GridView1.Mouse = 0
  CurrAct = ""
  Timer1.Start
  END IF
  
    IF CurrAct = "invarr2" THEN 
    
  INV2 = LEquipaggi[GridView1.Row - 1].Text
  IF Message.Question("Sei sicuro di voler invertire gli arrivi degli equipaggi " & INV1 & " e " & INV2 & "?", "Sì", "No") = 1 THEN 
 Timer1.Stop
  pt1 = arrivi[INV1]
  pt2 = arrivi[INV2]
  arrivi[INV2] = pt1
  arrivi[INV1] = pt2
  ENDIF 
    GridView1.BackColor = &H0FFFFFF&
  GridView1.Mouse = 0
  CurrAct = ""
  Timer1.Start
  END IF
  
  IF CurrAct = "invarr1" THEN 
  INV1 = LEquipaggi[GridView1.Row - 1].Text
  CurrAct = "invarr2"
    GridView1.BackColor = &H007FFFFF&
    GridView1.Mouse = 2
  END IF
  
ENDIF
UpgradeSessionFile()
END


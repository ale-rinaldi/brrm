' Gambas class file


PUBLIC SUB Button2_Click()
DIM num AS Integer
DIM p1 AS Integer
DIM p2 AS Integer
IF Listbox1.Index > 0 THEN
num = Listbox1.Index
p1 = Listbox1[num].Text
p2 = Listbox1[num - 1].Text
Listbox1[num - 1].Text = p1
Listbox1[num].Text = p2
Listbox1.Index = Listbox1.Index - 1
ENDIF
END



PUBLIC SUB Button3_Click()
DIM num AS Integer
DIM p1 AS Integer
DIM p2 AS Integer
IF Listbox1.Index < Listbox1.Count - 1 THEN
num = Listbox1.Index
p1 = Listbox1[num].Text
p2 = Listbox1[num + 1].Text
Listbox1[num + 1].Text = p1
Listbox1[num].Text = p2
Listbox1.Index = Listbox1.Index + 1
ENDIF
END

PUBLIC SUB Form_Open()
DIM counter AS Integer
Listbox1.Clear()
counter = 0
WHILE counter < FMain.EntryCount()
ListBox1.Add(FMain.EntryNumeroAt(counter))
counter = counter + 1
WEND
END

PUBLIC SUB Button6_Click()
  ' CREA: aggiunge un equipaggio senza orari (entry vuota). Il numero viene
  ' committato alla lista di FMain solo con OK (Button5 -> EditOrder).
  DIM sNum AS String
  DIM iNum AS Integer
  DIM k AS Integer
  sNum = InputBox("Numero del nuovo equipaggio:", "Crea equipaggio")
  IF Trim$(sNum) = "" THEN RETURN
  iNum = 0
  TRY iNum = CInt(Trim$(sNum))
  IF iNum <= 0 OR iNum >= 10000 THEN
    Message.Error("Numero non valido. Deve essere fra 1 e 9999.")
    RETURN
  ENDIF
  FOR k = 0 TO ListBox1.Count - 1
    IF ListBox1[k].Text = CStr(iNum) THEN
      Message.Error("L'equipaggio " & iNum & " è già in lista.")
      RETURN
    ENDIF
  NEXT
  ListBox1.Add(CStr(iNum))
END

PUBLIC SUB Button4_Click()
  ' RIMUOVI: toglie l'equipaggio selezionato. Lo scarto degli orari avviene
  ' col commit in FMain.EditOrder (le entry non piu' in lista sono eliminate).
  IF ListBox1.Index >= 0 THEN ListBox1.Remove(ListBox1.Index)
END

PUBLIC SUB Button5_Click()

  DIM sOut AS String
DIM counter AS Integer
counter = 1
IF Listbox1.Count > 0 THEN
 sOut = Listbox1[0].Text
WHILE counter < Listbox1.Count
sOut = sOut & "-" & Listbox1[counter].Text
counter = counter + 1
WEND
END IF
FMain.EditOrder(sOut)
FOrdine.Hide
END

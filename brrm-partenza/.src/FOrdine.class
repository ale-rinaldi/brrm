' Gambas class file


PUBLIC SUB Button2_Click()
DIM num AS Integer
DIM p1 AS Integer
DIM p2 AS Integer
IF Listbox1.Index > 0 THEN 
num = Listbox1.Index
p1 = Listbox1[num].Text
p2 = Listbox1[num - 1].Text
Listbox1[num - 1].Text = p1
Listbox1[num].Text = p2
Listbox1.Index = Listbox1.Index - 1
ENDIF
END

PUBLIC SUB Button1_Click()
DIM numero AS Integer
numero = 0
TRY numero = TextBox1.Text
IF numero <> 0 THEN 
IF Listbox1.Find(TextBox1.Text) < 0 THEN 
Listbox1.Add(TextBox1.Text)
ELSE 
Message("Numero già presente!")
END IF
END IF
TextBox1.Clear
END

PUBLIC SUB Button3_Click()
DIM num AS Integer
DIM p1 AS Integer
DIM p2 AS Integer
IF Listbox1.Index < Listbox1.Count - 1 THEN 
num = Listbox1.Index
p1 = Listbox1[num].Text
p2 = Listbox1[num + 1].Text
Listbox1[num + 1].Text = p1
Listbox1[num].Text = p2
Listbox1.Index = Listbox1.Index + 1
ENDIF
END

PUBLIC SUB Form_Open()
FOrdine.Center()
  TextBox1.Text = ""

END

PUBLIC SUB Button4_Click()

  Listbox1.Remove(Listbox1.Index)
END

PUBLIC SUB Button5_Click()

  DIM sOut AS String
DIM counter AS Integer
counter = 1
IF Listbox1.Count > 0 THEN 
 sOut = Listbox1[0].Text
WHILE counter < Listbox1.Count
sOut = sOut & "-" & Listbox1[counter].Text
counter = counter + 1
WEND 
END IF
FMain.EditOrder(sOut)
FOrdine.Hide
END

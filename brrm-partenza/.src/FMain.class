Public Sub Button6_Click()
  ' Export CSV: numero,hh,mm,ss,mmm (orario di partenza). Estratti da
  ' Hour/Minute/Second/Format$(uuu) — int puri, niente CStr che trunca i ms.
  Dim Counter As Integer
  Dim iEqui As Integer
  Dim tPart As Date
  Dim iHr As Integer
  Dim iMn As Integer
  Dim iSec As Integer
  Dim iMillis As Integer
  Dim sOut As String
  Dim sPath As String

  For Counter = 0 To LEquipaggi.Count - 1
    iEqui = 0
    Try iEqui = LEquipaggi[Counter].Text
    If iEqui = 0 Then Continue
    If partenze[iEqui] = 0 Then Continue
    tPart = partenze[iEqui]
    iHr = Hour(tPart)
    iMn = Minute(tPart)
    iSec = Second(tPart)
    iMillis = 0
    Try iMillis = CInt(Format$(tPart, "uuu"))
    sOut = sOut & iEqui & "," & iHr & "," & iMn & "," & iSec & "," & Format$(iMillis, "000") & "\n"
  Next

  Dialog.Title = "Salva orari partenza"
  Dialog.Filter = ["*.csv", "File CSV"]
  Dialog.Path = User.Home &/ "brrm-partenze.csv"
  If Dialog.SaveFile() Then Return
  sPath = Dialog.Path
  If LCase$(File.Ext(sPath)) <> "csv" Then sPath = sPath & ".csv"
  Try File.Save(sPath, sOut)
  If Error Then Message.Error("Impossibile salvare il file: " & Error.Text)
End

Public Function PadMillis(s As String) As String
  ' Pad a destra con zeri a esattamente 3 cifre. "7" -> "700", "07" -> "070".
  Select Case Len(s)
    Case 0
      Return "000"
    Case 1
      Return s & "00"
    Case 2
      Return s & "0"
    Case 3
      Return s
    Case Else
      Return Left$(s, 3)
  End Select
End

Public Sub GridView1_Click()
Dim pt1 As Date
Dim pt2 As Date
  If GridView1.Row > 0 Then 
  If CurrAct = "part" Then 
  Timer1.Stop
  ChangingN = LEquipaggi[GridView1.Row - 1].Text
  FPartenza.Show
  GridView1.Background = &H0FFFFFF&
  GridView1.Mouse = 0
    CurrAct = ""
    Timer1.Start
  End If
    
  If CurrAct = "annpart" Then 
  If Message.Question("Sei sicuro di voler annullare la partenza dell'equipaggio numero " & LEquipaggi[GridView1.Row - 1].Text & "?", "Sì", "No") = 1 Then 
  Timer1.Stop
  Dim iAnnNum As Integer = LEquipaggi[GridView1.Row - 1].Text
  partenze[iAnnNum] = 0
  AlignEnqueue(iAnnNum, 0)
  Endif 
    GridView1.Background = &H0FFFFFF&
  GridView1.Mouse = 0
  CurrAct = ""
  Timer1.Start
  End If
  
    If CurrAct = "annarr" Then 
    If Message.Question("Sei sicuro di voler annullare l'arrivo dell'equipaggio numero " & LEquipaggi[GridView1.Row - 1].Text & "?", "Sì", "No") = 1 Then 
  Timer1.Stop
  arrivi[LEquipaggi[GridView1.Row - 1].Text] = 0
  Endif 
    GridView1.Background = &H0FFFFFF&
  GridView1.Mouse = 0
  CurrAct = ""
  Timer1.Start
  End If
  
    If CurrAct = "invarr2" Then 
    
  INV2 = LEquipaggi[GridView1.Row - 1].Text
  If Message.Question("Sei sicuro di voler invertire gli arrivi degli equipaggi " & INV1 & " e " & INV2 & "?", "Sì", "No") = 1 Then 
 Timer1.Stop
  pt1 = arrivi[INV1]
  pt2 = arrivi[INV2]
  arrivi[INV2] = pt1
  arrivi[INV1] = pt2
  Endif 
    GridView1.Background = &H0FFFFFF&
  GridView1.Mouse = 0
  CurrAct = ""
  Timer1.Start
  End If
  
  If CurrAct = "invarr1" Then
  INV1 = LEquipaggi[GridView1.Row - 1].Text
  CurrAct = "invarr2"
    GridView1.Background = &H007FFFFF&
    GridView1.Mouse = 2
  End If

  If CurrAct = "modnum" Then
    Dim iOld As Integer
    Dim sNew As String
    Dim iNew As Integer
    iOld = LEquipaggi[GridView1.Row - 1].Text
    If partenze[iOld] = 0 Then
      Message.Error("L'equipaggio " & iOld & " non ha un orario di partenza da spostare.")
    Else
      Timer1.Stop
      sNew = InputBox("Nuovo numero per l'equipaggio " & iOld & " (partenza " & partenze[iOld] & "):", "Cambia numero")
      If sNew <> "" Then
        iNew = 0
        Try iNew = CInt(Trim$(sNew))
        If iNew <= 0 Or iNew >= 10000 Then
          Message.Error("Numero non valido. Deve essere fra 1 e 9999.")
        Else If iNew = iOld Then
          ' no-op
        Else If LEquipaggi.Find(iNew) >= 0 Then
          Message.Error("L'equipaggio " & iNew & " esiste già: non posso assegnare lo stesso numero a due partenze.")
        Else
          ChangeNumero(iOld, iNew)
        Endif
      Endif
      Timer1.Start
    Endif
    GridView1.Background = &H0FFFFFF&
    GridView1.Mouse = 0
    CurrAct = ""
  End If

  If CurrAct = "invpart2" Then
    INV2 = LEquipaggi[GridView1.Row - 1].Text
    If INV2 = INV1 Then
      Message.Error("Non posso invertire un equipaggio con se stesso.")
    Else If Message.Question("Sei sicuro di voler invertire le partenze degli equipaggi " & INV1 & " e " & INV2 & "?", "Sì", "No") = 1 Then
      Timer1.Stop
      InvertiPartenze(INV1, INV2)
      Timer1.Start
    Endif
    GridView1.Background = &H0FFFFFF&
    GridView1.Mouse = 0
    CurrAct = ""
  End If

  If CurrAct = "invpart1" Then
    INV1 = LEquipaggi[GridView1.Row - 1].Text
    CurrAct = "invpart2"
    GridView1.Background = &H007FFFFF&
    GridView1.Mouse = 2
  End If

Endif
UpgradeSessionFile()
End


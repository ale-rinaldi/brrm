Public Sub SetArrivo(Numero As Integer, Orario As Date) 

Timer1.Stop
arrivi[Numero] = Orario
Timer1.Start
  UpgradeSessionFile()
  
End 


Public Sub Timer3_Timer()

  If FArrivo.Visible = False And BArrivi.Count > 0 And FPartenza.Visible = False And CurrAct = "" Then 
  FArrivo.Show
  FArrivo.setOrario(BArrivi[0].Text)
  BArrivi.Remove(0)
  Endif  

End

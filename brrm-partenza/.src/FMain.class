  UpgradeSessionFile()
  
End 


Public Sub Timer3_Timer()

  If FArrivo.Visible = False And BArrivi.Count > 0 And FPartenza.Visible = False And CurrAct = ACT_NONE Then 
  FArrivo.Show
  FArrivo.setOrario(BArrivi[0].Text)
  BArrivi.Remove(0)
  Endif  

End

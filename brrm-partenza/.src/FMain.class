' Gambas class file

' Stati di interazione (CurrAct). I pulsanti di azione "contestuale" su
' griglia (Annulla partenza, Inverti partenze, Cambia numero) settano un
' valore qui; GridView1_Click esegue l'azione corrispondente al click.
Private Const ACT_NONE As String = ""
Private Const ACT_ANNPART As String = "annpart"
Private Const ACT_INVPART1 As String = "invpart1"
Private Const ACT_INVPART2 As String = "invpart2"
Private Const ACT_MODNUM As String = "modnum"

' Limite massimo numero equipaggio (e dimensione array statici).
Private Const MAX_NUMERO As Integer = 10000

' Unica fonte di verita': lista ordinata di equipaggi (numero + partenza).
' L'ordine di partenza e' l'indice nell'array. Sostituisce il ListBox nascosto
' LEquipaggi + l'array partenze[] indicizzato per numero.
Private $entries As New CEntry[]
Private CurrAct As String
Private FotON As Boolean
Private INV1 As Integer
Private INV2 As Integer

' --- Arduino (gestito dinamicamente per workaround bug Gambas) ---
' SerialPort.Open su un oggetto gia' chiuso (.Close) non riarma il
' listener di _Read: status diventa 1, ma gli eventi non firano piu'.
' Ricreiamo l'oggetto a ogni riconnessione e riattacchiamo gli event
' handler con Object.Attach($hSerial, Me, "Arduino").
Private $hSerial As SerialPort

' --- Align (sync via web) ---
Private $alignEnabled As Boolean
Private $alignUrl As String
Private $alignUser As String
Private $alignPass As String
Private $alignSessionConfig As String
Private $alignSeq As Long
Private $alignSession As Long
Private $alignOutbox As New String[]
Private $alignBusy As Boolean
Private $alignProbing As Boolean
Private $alignBackoffSec As Integer
Private $hAlignHttp As HttpClient

' --- Layout responsivo (Form_Resize) ---
' Stesso meccanismo di brrm/FMain: cattura design al primo Form_Resize,
' GridView cresce in entrambe le direzioni, button area + status bar
' ancorati al fondo, colonna 4 + Impostazioni ancorati a destra.
Private $rsDesigned As Boolean
Private $rsDesignW As Integer
Private $rsDesignH As Integer
Private $rsOrigGridW As Integer
Private $rsOrigGridH As Integer
Private $rsBtmCtrl As Object[]
Private $rsBtmOrigTop As New Integer[]
Private $rsRgtCtrl As Object[]
Private $rsRgtOrigLeft As New Integer[]

' Flag di shutdown: vedi brrm/FMain.class. Evita race tra Form_Close e
' TimerArduino_Timer in WAIT.
Private $shuttingDown As Boolean

' Stato Arduino precedente: usato da SetArduinoStatus per loggare solo
' le transizioni online <-> offline (TimerArduino chiama ogni 2s e non
' vogliamo spammare il registro). Init valore = False, quindi il primo
' "ARDUINO OK" generera' un log "arduino_online".
Private $arduinoOnline As Boolean

' --- Hardware clock (modalita' internal) ---
Private $hwMode As String           ' "legacy" | "internal"
Private $serialBuf As String        ' buffer di riga (modalita' internal)
Private $lastPongMs As Long         ' Timer*1000 dell'ultimo pong
Public ClockSrc As String           ' "G"/"R"/"N"/"" (per label e modal)
Public ClockTimeLive As String      ' "<unix>.<ms>" dall'ultimo pong
Public ClockDiagRaw As String       ' ultima riga "D..." ricevuta
Public ClockFwVer As String         ' versione firmware ("Y<ver>")
Public ClockDevice As String        ' device path corrente

Public Sub _new()

End

' --- Accesso alla lista equipaggi ($entries) -------------------------------
' Le entry sono l'unica fonte di verita'. Ricerca per numero lineare: gli
' equipaggi sono al massimo qualche centinaio, il costo e' trascurabile.

Private Function FindIndex(Numero As Integer) As Integer
  Dim i As Integer
  For i = 0 To $entries.Max
    If $entries[i].Numero = Numero Then Return i
  Next
  Return -1
End

Private Function FindEntry(Numero As Integer) As CEntry
  Dim idx As Integer
  idx = FindIndex(Numero)
  If idx < 0 Then Return Null
  Return $entries[idx]
End

Private Function PartenzaOf(Numero As Integer) As Date
  Dim e As CEntry
  e = FindEntry(Numero)
  If e = Null Then Return 0
  Return e.Partenza
End

Private Sub ClearPartenza(Numero As Integer)
  Dim e As CEntry
  e = FindEntry(Numero)
  If e <> Null Then e.Partenza = 0
End

' Ritorna la entry per Numero, creandola (vuota, in coda) se assente.
Public Function EnsureEntry(Numero As Integer) As CEntry
  Dim e As CEntry
  e = FindEntry(Numero)
  If e <> Null Then Return e
  e = New CEntry
  e.Numero = Numero
  $entries.Add(e)
  Return e
End

Public Function HasEntry(Numero As Integer) As Boolean
  Return FindIndex(Numero) >= 0
End

Public Function EntryCount() As Integer
  Return $entries.Count
End

Public Function EntryNumeroAt(Indice As Integer) As Integer
  Return $entries[Indice].Numero
End

Public Sub Form_Resize()
  ' Vedi commento omonimo in brrm/FMain.class per la logica generale.
  Dim i As Integer
  Dim c As Control
  Dim dW, dH As Integer

  If Not $rsDesigned Then
    $rsDesignW = Me.Width
    $rsDesignH = Me.Height
    $rsOrigGridW = GridView1.Width
    $rsOrigGridH = GridView1.Height
    ' brrm-partenza non ha Label1/Label2 (niente IN ARRIVO) ne' LabelSheet
    $rsBtmCtrl = [ButtonAnnullaPart, ButtonChangeNum, ButtonInvert, ButtonSettings, ButtonEsporta, ButtonFotON, ButtonFotOFF, ButtonReset, ButtonPartenza, ButtonOrdine, LabelArduino, LabelSync]
    $rsRgtCtrl = [ButtonEsporta, ButtonFotON, ButtonFotOFF, ButtonReset, ButtonSettings]
    For Each c In $rsBtmCtrl
      $rsBtmOrigTop.Add(c.Top)
    Next
    For Each c In $rsRgtCtrl
      $rsRgtOrigLeft.Add(c.Left)
    Next
    Me.MinW = $rsDesignW
    Me.MinH = $rsDesignH
    $rsDesigned = True
    Return
  Endif

  dW = Me.Width - $rsDesignW
  dH = Me.Height - $rsDesignH
  If dW < 0 Then dW = 0
  If dH < 0 Then dH = 0

  GridView1.Width = $rsOrigGridW + dW
  GridView1.Height = $rsOrigGridH + dH

  For i = 0 To $rsBtmCtrl.Max
    c = $rsBtmCtrl[i]
    c.Top = $rsBtmOrigTop[i] + dH
  Next
  For i = 0 To $rsRgtCtrl.Max
    c = $rsRgtCtrl[i]
    c.Left = $rsRgtOrigLeft[i] + dW
  Next
End

Public Sub Arduino_Read()

Dim s As String
Dim iLof As Integer
iLof = 0
Try iLof = Lof($hSerial)
If Error Then
  ArduinoClose()
  Return
Endif
Try Read #$hSerial, s, iLof
If Error Then
  ArduinoClose()
  Return
Endif
If $hwMode = "internal" Then
  HandleInternalBytes(s)
  Return
Endif
Dim sNow As String = Format$(Time, "hh:nn:ss.uuu")
If FotON = True Then
  BPartenze.Add(sNow)
  Try MLog.Write("fotocellula", "source=arduino orario=" & sNow)
Else
  Try MLog.Write("fotocellula_ignorata", "source=arduino motivo=FotOFF orario=" & sNow)
Endif

End

Private Sub SetArduinoStatus(bConnected As Boolean)
  ' Durante shutdown LabelArduino puo' essere gia' distrutto.
  If $shuttingDown Then Return
  ' Log solo sulle transizioni di stato (TimerArduino chiama ogni 2s)
  If bConnected <> $arduinoOnline Then
    $arduinoOnline = bConnected
    If bConnected Then
      Try MLog.Write("arduino_online", "")
    Else
      Try MLog.Write("arduino_offline", "")
    Endif
  Endif
  If bConnected Then
    LabelArduino.Background = &H00CC00&
    LabelArduino.Foreground = &HFFFFFF&
    LabelArduino.Text = "ARDUINO OK"
  Else
    LabelArduino.Background = &HCC0000&
    LabelArduino.Foreground = &HFFFFFF&
    LabelArduino.Text = "NO ARDUINO"
  Endif
End

Private Sub SetClockLabel(st As Integer)
  If $shuttingDown Then Return
  Dim bOnline As Boolean = (st <> MClock.HW_ABSENT)
  If bOnline <> $arduinoOnline Then
    $arduinoOnline = bOnline
    If bOnline Then Try MLog.Write("arduino_online", "") Else Try MLog.Write("arduino_offline", "")
  Endif
  LabelArduino.Background = MClock.LabelBg(st)
  LabelArduino.Foreground = MClock.LabelFg(st)
  LabelArduino.Text = MClock.LabelText(st)
End

Public Sub TimerArduino_Timer()
  ' Reconnect/status check: ogni 2s verifica che la porta sia aperta
  ' E che il device file esista ancora (rileva USB disconnect hardware).
  Dim sDevice As String
  Dim bOk As Boolean = False
  If $hSerial <> Null Then
    If $hSerial.Status >= 1 And Exist($hSerial.PortName) Then bOk = True
  Endif
  If $hwMode = "internal" Then
    If bOk Then
      Try Print #$hSerial, MClock.CMD_PING
    Endif
    Dim age As Long
    If $lastPongMs = 0 Then age = 999999 Else age = MTimerNowMs() - $lastPongMs
    Dim st As Integer = MClock.LabelState(Exist(ClockDevice) Or bOk, bOk, age, ClockSrc)
    SetClockLabel(st)
    If Not bOk Then
      ArduinoClose()
      Wait 0.1
      If $shuttingDown Then Return
      Dim sDev As String = MFile.FindArduinoDevice()
      If sDev <> "" Then
        ClockDevice = sDev
        ArduinoOpen(sDev)
      Endif
    Endif
    Return
  Endif
  If bOk Then
    SetArduinoStatus(True)
    Return
  Endif
  ' Non connesso: distruggi l'oggetto e ricrea uno nuovo al prossimo Open.
  ' Senza ricreazione, SerialPort.Open su istanza riusata non riarma il
  ' listener di _Read (bug Gambas 3.20).
  ArduinoClose()
  Wait 0.1
  ' Form_Close puo' essere passato durante WAIT: niente reopen ne' UI.
  If $shuttingDown Then Return
  sDevice = MFile.FindArduinoDevice()
  If sDevice = "" Then
    SetArduinoStatus(False)
    Return
  Endif
  SetArduinoStatus(ArduinoOpen(sDevice))
End

Private Function ArduinoOpen(sDevice As String) As Boolean
  ' Crea un nuovo SerialPort dynamic, attacca gli event handler con
  ' prefix "Arduino" e apre. Workaround bug Gambas 3.20.
  ArduinoClose()
  $hSerial = New SerialPort
  Object.Attach($hSerial, Me, "Arduino")
  $hSerial.PortName = sDevice
  If $hwMode = "internal" Then
    $hSerial.Speed = 115200
  Else
    $hSerial.Speed = 9600
  Endif
  $serialBuf = ""
  ClockSrc = ""
  $hSerial.Parity = SerialPort.None
  $hSerial.DataBits = 8
  $hSerial.StopBits = 1
  $hSerial.FlowControl = SerialPort.None
  Try $hSerial.Open
  If Error Then
    ArduinoClose()
    Return False
  Endif
  Return ($hSerial.Status >= 1)
End

Private Sub ArduinoClose()
  If $hSerial <> Null Then
    Try $hSerial.Close
    $hSerial = Null
  Endif
End

Private Sub HandleInternalBytes(sChunk As String)
  Dim iNl As Integer
  Dim sLine As String
  $serialBuf &= sChunk
  Do
    iNl = InStr($serialBuf, Chr(10))
    If iNl = 0 Then Break
    sLine = Left$($serialBuf, iNl - 1)
    $serialBuf = Mid$($serialBuf, iNl + 1)
    DispatchClockLine(Trim$(sLine))
  Loop
  ' Protezione anti-crescita se non arrivano newline
  If Len($serialBuf) > 256 Then $serialBuf = ""
End

Private Sub DispatchClockLine(sLine As String)
  Dim r As String[] = MClock.ParseLine(sLine)
  If r = Null Then Return
  Select Case r[0]
    Case "P"
      HandlePassage(r)
    Case "K"
      $lastPongMs = MTimerNowMs()
      ClockSrc = r[1]
      If r.Count >= 4 Then ClockTimeLive = r[2] & "." & r[3] Else ClockTimeLive = ""
    Case "D"
      ClockDiagRaw = sLine
    Case "Y"
      ClockFwVer = r[1]
    Case "W"
      Try MLog.Write("clock_desync", "nmea=" & r[1] & " ref=" & r[2])
  End Select
End

Private Function MTimerNowMs() As Long
  ' Riferimento monotono in ms per l'eta' del pong (Timer = secondi Float).
  Return CLong(Timer * 1000)
End

Private Sub HandlePassage(r As String[])
  ' r = ["P", unix, ms, src]. Converte UTC->locale e instrada come partenza.
  Dim unixMs As Long = CLong(r[1]) * 1000 + CLong(r[2])
  Dim dFull As Date = MTime.UnixMsToDate(unixMs)
  ' Date time-only "hh:nn:ss.uuu" per restare compatibili col flusso
  ' BPartenze -> FPartenza.setOrario (che si aspetta solo l'orario).
  Dim dLocal As Date = Time(Hour(dFull), Minute(dFull), Second(dFull), MTime.MillisOf(dFull))
  Dim sNow As String = MTime.FormatDateMs(dLocal)
  If FotON Then
    BPartenze.Add(sNow)
    Try MLog.Write("fotocellula", "source=clock orario=" & sNow & " unixms=" & CStr(unixMs) & " src=" & r[3])
  Else
    Try MLog.Write("fotocellula_ignorata", "source=clock motivo=FotOFF orario=" & sNow)
  Endif
End

Public Sub LabelArduino_MouseUp()
  If $hwMode <> "internal" Then Return
  RequestId()
  RequestDiag()
  FClockDiag.Show
End

Public Sub RequestDiag()
  If $hSerial <> Null And If $hSerial.Status >= 1 Then Try Print #$hSerial, MClock.CMD_DIAG
End

Public Sub RequestId()
  If $hSerial <> Null And If $hSerial.Status >= 1 Then Try Print #$hSerial, MClock.CMD_ID
End

Public Sub LoadHardwareConfig()
  $hwMode = MFile.LoadHardwareMode()
End

Public Sub HardwareReinit()
  ' Rilegge la modalita', resetta lo stato e forza la riconnessione al
  ' baud corretto. La label viene ricalcolata al prossimo TimerArduino.
  LoadHardwareConfig()
  ClockSrc = ""
  ClockDiagRaw = ""
  ClockFwVer = ""
  $lastPongMs = 0
  ArduinoClose()
  If $hwMode = "internal" Then
    TimerArduino.Delay = 1000
  Else
    TimerArduino.Delay = 2000
  Endif
End

Public Sub Form_Close()
  ' Stop dei timer e chiusura SerialPort prima che la form muoia:
  ' senza questo, se il fd del SerialPort e' in stato HUP (device
  ' staccato), il loop _Read/TimerArduino-reopen continua durante la fase
  ' di shutdown tenendo il processo appeso al 100% CPU.
  ' $shuttingDown va settato PRIMA degli Stop: un TimerArduino_Timer in WAIT
  ' potrebbe risvegliarsi proprio in questo istante.
  $shuttingDown = True
  Try TimerGrid.Stop
  Try TimerBlink.Stop
  Try TimerPartenzaQueue.Stop
  Try TimerArduino.Stop
  Try TimerAlign.Stop
  Try TimerAlignHeartbeat.Stop
  ArduinoClose()
  Try MLog.Write("app_stop", "")
  Try MLog.Close()
End

Public Sub ConfermaScartoOrario(che As String) As Boolean
  ' Conferma per chiudere senza salvare un dialog che contiene un orario
  ' volatile (es. cattura fotocellula). Ritorna True se l'utente conferma
  ' lo scarto. Usata da FPartenza sul pulsante Annulla.
  Dim sCosa As String
  If che = "" Then
    sCosa = "L'orario"
  Else
    sCosa = "L'orario di " & che
  Endif
  Return Message.Question("Sei sicuro di voler annullare l'inserimento? " & sCosa & " verrà perso definitivamente.", "Annulla l'inserimento", "Continua a inserire") = 1
End

Private Sub AlignLoadConfig() As Boolean
  Dim sPath As String
  Dim sLine As String
  Dim sKey As String
  Dim sVal As String
  Dim iEq As Integer
  sPath = User.Home &/ ".config/brrm/align.conf"
  $alignSessionConfig = "default"
  If Not Exist(sPath) Then Return False
  For Each sLine In Split(File.Load(sPath), gb.NewLine)
    sLine = Trim$(sLine)
    If sLine = "" Then Continue
    If Left$(sLine, 1) = "#" Then Continue
    iEq = InStr(sLine, "=")
    If iEq < 2 Then Continue
    sKey = LCase$(Trim$(Left$(sLine, iEq - 1)))
    sVal = Trim$(Mid$(sLine, iEq + 1))
    Select Case sKey
      Case "url"
        $alignUrl = sVal
      Case "username"
        $alignUser = sVal
      Case "password"
        $alignPass = sVal
      Case "session"
        $alignSessionConfig = sVal
    End Select
  Next
  Return ($alignUrl <> "" And $alignUser <> "" And $alignPass <> "")
End

Public Sub LogReinit()
  ' Chiamato da FSettings dopo salvataggio log.conf: chiude il file di
  ' log corrente (se aperto), rilegge la config e riapre se enabled.
  Try MLog.Close()
  MLog.Init()
End

Public Sub AlignReinit()
  ' Chiamato dalla form Settings dopo aver scritto il config: chiude
  ' la sessione corrente e fa ripartire AlignInit da zero, in modo che
  ' nuovi URL/credenziali abbiano effetto senza riavviare l'app.
  TimerAlign.Stop
  TimerAlignHeartbeat.Stop
  If $hAlignHttp Then
    Try $hAlignHttp.Stop
    $hAlignHttp = Null
  Endif
  $alignBusy = False
  $alignProbing = False
  $alignUrl = ""
  $alignUser = ""
  $alignPass = ""
  $alignSessionConfig = ""
  $alignSession = 0
  AlignInit()
End

Public Sub AlignInit()
  Dim sLine As String
  $alignEnabled = AlignLoadConfig()
  If Not $alignEnabled Then
    LabelSync.Visible = False
    Return
  Endif
  $alignSession = 0
  $alignSeq = 0
  LoadAlignState()
  $alignOutbox = New String[]
  If Exist(User.Home &/ ".local/share/brrm/partenza-align-outbox") Then
    For Each sLine In Split(File.Load(User.Home &/ ".local/share/brrm/partenza-align-outbox"), gb.NewLine)
      sLine = Trim$(sLine)
      If sLine <> "" Then $alignOutbox.Add(sLine)
    Next
  Endif
  $hAlignHttp = New HttpClient As "AlignHttp"
  $alignBackoffSec = 1
  ' Niente stato prematuro: label nascosta finche' il probe non da' un esito.
  LabelSync.Visible = False
  ' Heartbeat: probe periodico ogni 30s per rilevare network drop silenziosi
  ' anche quando l'utente non sta facendo partenze. Il timer fa skip quando
  ' c'e' gia' una richiesta in volo (busy) o eventi pendenti in outbox.
  TimerAlignHeartbeat.Delay = 30000
  TimerAlignHeartbeat.Start
  AlignProbe()
End

Private Sub LoadAlignState()
  ' Carica (session, seq) dal file partenza-align-state. Se non esiste,
  ' migra dal vecchio partenza-align-seq (e genera subito un session_id,
  ' altrimenti il seq migrato > 0 non triggererebbe la regola "nuovo
  ' session_id quando seq riparte da 1").
  Dim sStatePath As String
  Dim sLegacyPath As String
  sStatePath = User.Home &/ ".local/share/brrm/partenza-align-state"
  sLegacyPath = User.Home &/ ".local/share/brrm/partenza-align-seq"

  If Exist(sStatePath) Then
    Dim r As Long[]
    r = MAlignSync.DecodeStateFile(File.Load(sStatePath))
    If r <> Null Then
      $alignSession = r[0]
      $alignSeq = r[1]
      Return
    Endif
    ' File corrotto: tratta come assente.
    $alignSession = 0
    $alignSeq = 0
  Endif

  If Exist(sLegacyPath) Then
    Dim iLegacySeq As Long
    iLegacySeq = 0
    Try iLegacySeq = CLong(Trim$(File.Load(sLegacyPath)))
    $alignSeq = iLegacySeq
    $alignSession = MAlignSync.NextSessionId(0)
    SaveAlignState()
    Try Kill sLegacyPath
  Endif
End

Private Sub SaveAlignState()
  Dim sState As String
  sState = MAlignSync.EncodeStateFile($alignSession, $alignSeq)
  MFile.AtomicSave(User.Home &/ ".local/share/brrm/partenza-align-state", sState)
End

Private Sub AlignProbe()
  ' GET /ping autenticato: testa rete+credenziali senza side-effect sul server.
  ' L'esito (success/fail) rende visibile LabelSync col colore appropriato.
  If Not $alignEnabled Then Return
  If $alignBusy Then Return
  $alignBusy = True
  $alignProbing = True
  $hAlignHttp.URL = $alignUrl & "/ping"
  $hAlignHttp.Auth = Net.AuthBasic
  $hAlignHttp.User = $alignUser
  $hAlignHttp.Password = $alignPass
  $hAlignHttp.Async = True
  $hAlignHttp.Timeout = 5
  Try $hAlignHttp.Get()
  If Error Then
    $alignBusy = False
    $alignProbing = False
    AlignSetStatus(False, "Errore avvio probe: " & Error.Text)
    AlignScheduleRetry()
  Endif
End

Private Sub AlignSetStatus(connected As Boolean, Optional detail As String)
  ' Una qualsiasi chiamata a SetStatus rende visibile l'indicatore: significa
  ' che abbiamo un esito definitivo da mostrare all'utente. Il `detail` finisce
  ' nel tooltip per troubleshooting senza ingombrare la UI.
  LabelSync.Visible = True
  If connected Then
    LabelSync.Background = &H00CC00&
    LabelSync.Text = "SYNC OK"
    If detail = "" Then detail = "Sincronizzazione attiva"
  Else
    LabelSync.Background = &HCC0000&
    LabelSync.Text = "SYNC FAIL"
    If detail = "" Then detail = "Errore di sincronizzazione"
  Endif
  LabelSync.Tooltip = detail & gb.NewLine & "URL: " & $alignUrl & gb.NewLine & "Session: " & $alignSessionConfig & gb.NewLine & "Run id: " & CStr($alignSession) & gb.NewLine & "Seq: " & CStr($alignSeq)
End

Public Sub AlignEnqueue(numero As Integer, orarioOrZero As Date)
  ' Accoda un evento di partenza per sync. orarioOrZero=0 -> annullamento.
  If Not $alignEnabled Then Return
  Dim sOrarioJson As String
  Dim sTsOrigine As String
  Dim sEvent As String
  ' Genera un nuovo session_id se il seq sta per passare da 0 a 1
  ' (fresh start o reset esterno del file di state).
  If $alignSeq = 0 Then
    $alignSession = MAlignSync.NextSessionId($alignSession)
  Endif
  $alignSeq = $alignSeq + 1
  If orarioOrZero = 0 Then
    sOrarioJson = "null"
  Else
    sOrarioJson = Chr(34) & MTime.FormatDateMs(orarioOrZero) & Chr(34)
  Endif
  sTsOrigine = Format$(Now, "yyyy-mm-ddThh:nn:ss.zzz") & "Z"
  sEvent = "{" & Chr(34) & "session_id" & Chr(34) & ":" & $alignSession
  sEvent &= "," & Chr(34) & "seq" & Chr(34) & ":" & $alignSeq
  sEvent &= "," & Chr(34) & "type" & Chr(34) & ":" & Chr(34) & "partenza" & Chr(34)
  sEvent &= "," & Chr(34) & "numero" & Chr(34) & ":" & numero
  sEvent &= "," & Chr(34) & "orario" & Chr(34) & ":" & sOrarioJson
  sEvent &= "," & Chr(34) & "ts_origine" & Chr(34) & ":" & Chr(34) & sTsOrigine & Chr(34)
  sEvent &= "}"
  $alignOutbox.Add(sEvent)
  SaveAlignState()
  MFile.AtomicSave(User.Home &/ ".local/share/brrm/partenza-align-outbox", $alignOutbox.Join(gb.NewLine))
  AlignTrySend()
End

Private Sub AlignTrySend()
  ' Avvia POST del primo evento in outbox, se possibile.
  If Not $alignEnabled Then Return
  If $alignBusy Then Return
  If $alignOutbox.Count = 0 Then Return
  $alignBusy = True
  $hAlignHttp.URL = $alignUrl & "/events?session=" & $alignSessionConfig
  $hAlignHttp.Auth = Net.AuthBasic
  $hAlignHttp.User = $alignUser
  $hAlignHttp.Password = $alignPass
  $hAlignHttp.Async = True
  $hAlignHttp.Timeout = 5
  Try $hAlignHttp.Post("application/json", $alignOutbox[0])
  If Error Then
    $alignBusy = False
    AlignSetStatus(False)
    AlignScheduleRetry()
  Endif
End

Public Sub AlignHttp_Finished()
  $alignBusy = False
  If $alignProbing Then
    $alignProbing = False
    If $hAlignHttp.Code = 200 Then
      AlignSetStatus(True, "Probe OK")
      $alignBackoffSec = 1
      ' Probe OK → drena eventuali eventi pendenti nell'outbox.
      If $alignOutbox.Count > 0 Then AlignTrySend()
    Else
      AlignSetStatus(False, "Probe fallito: HTTP " & $hAlignHttp.Code)
      AlignScheduleRetry()
    Endif
    Return
  Endif
  If $hAlignHttp.Code = 200 Or $hAlignHttp.Code = 201 Then
    Try $alignOutbox.Remove(0)
    Try MFile.AtomicSave(User.Home &/ ".local/share/brrm/partenza-align-outbox", $alignOutbox.Join(gb.NewLine))
    AlignSetStatus(True, "Ultimo evento (seq=" & $alignSeq & ") sincronizzato")
    $alignBackoffSec = 1
    ' Se ci sono altri eventi pending, spedisci subito il prossimo
    If $alignOutbox.Count > 0 Then AlignTrySend()
  Else
    AlignSetStatus(False, "POST fallito: HTTP " & $hAlignHttp.Code & " (" & $alignOutbox.Count & " eventi in coda)")
    AlignScheduleRetry()
  Endif
End

Public Sub AlignHttp_Error()
  $alignBusy = False
  If $alignProbing Then $alignProbing = False
  AlignSetStatus(False, "Errore di rete (timeout o server irraggiungibile)")
  AlignScheduleRetry()
End

Private Sub AlignScheduleRetry()
  ' Single-shot timer: scatta dopo $alignBackoffSec secondi e ritenta.
  If $alignBackoffSec < 60 Then $alignBackoffSec = $alignBackoffSec * 2
  If $alignBackoffSec > 60 Then $alignBackoffSec = 60
  TimerAlign.Stop
  TimerAlign.Delay = $alignBackoffSec * 1000
  TimerAlign.Start
End

Public Sub TimerAlign_Timer()
  ' Retry condiviso: se ho eventi pendenti, riprova il POST; altrimenti
  ' probe (cosi' lo stato SYNC OK/FAIL riflette la situazione corrente
  ' anche quando l'outbox e' vuoto).
  TimerAlign.Stop
  If Not $alignEnabled Then Return
  If $alignOutbox.Count > 0 Then
    AlignTrySend()
  Else
    AlignProbe()
  Endif
End

Public Sub TimerAlignHeartbeat_Timer()
  ' Probe periodico per rilevare rete morta in stato idle. Skip se:
  '   - una richiesta e' gia' in volo ($alignBusy): non doppiamo traffico
  '   - ci sono eventi pendenti: AlignTrySend fara' gia' da heartbeat naturale
  '   - TimerAlign e' attivo (siamo in backoff dopo un fail): aspettiamo il retry
  If Not $alignEnabled Then Return
  If $alignBusy Then Return
  If $alignOutbox.Count > 0 Then Return
  If TimerAlign.Enabled Then Return
  AlignProbe()
End

Public Sub UpgradeSessionFile()
  ' Formato v1: prima riga = magic header, righe successive numero|partenza.
  Dim Counter As Integer
  Dim e As CEntry
  Dim sFileOut As String
  Dim sPart As String

  sFileOut = "brrm-partenza-session v1" & gb.NewLine
  For Counter = 0 To $entries.Max
    e = $entries[Counter]
    If e.Numero <= 0 Then Continue
    sPart = ""
    If e.Partenza <> 0 Then sPart = MTime.FormatDateMs(e.Partenza)
    sFileOut &= e.Numero & "|" & sPart & gb.NewLine
  Next
  MFile.AtomicSave(User.Home &/ ".local/share/brrm/partenza-session", sFileOut)
End

Public Sub SetPartenza(Equipaggio As Integer, Partenza As Date)
  Dim e As CEntry
  TimerGrid.Stop
  e = EnsureEntry(Equipaggio)
  e.Partenza = Partenza
  UpgradeSessionFile()
  AlignEnqueue(Equipaggio, Partenza)
  TimerGrid.Start
End

Public Sub ReturnPartenza(Numero As Integer) As Date

  Return PartenzaOf(Numero)

End

Public Sub SetupGridHeader()
  ' Configurazione fissa dell'header (riga 0). Idempotente.
  GridView1.Columns.Count = 2
  GridView1.Rows.Count = Max(GridView1.Rows.Count, 1)
  GridView1.Columns[0].Width = GridView1.Width - 150
  GridView1.Columns[1].Width = 140
  GridView1[0, 0].Background = &H000000&
  GridView1[0, 1].Background = &H000000&
  GridView1[0, 0].Foreground = &HFFFFFF&
  GridView1[0, 1].Foreground = &HFFFFFF&
  GridView1[0, 0].Text = "Equipaggio"
  GridView1[0, 1].Text = "Partenza"
End

Public Sub Form_Open()
Dim sTest As String
Dim aLines As String[]
Dim aFields As String[]
Dim iEqui As Integer
Dim iNum As Integer
Dim e As CEntry
FotON = True
FMain.Center()
SetupGridHeader()
MLog.Init()
Try MLog.Write("app_start", "ruolo=partenza")
' Loader formato v1: scarta silenziosamente se l'header non e' atteso.
sTest = ""
If Exist(User.Home &/ ".local/share/brrm/partenza-session") Then sTest = File.Load(User.Home &/ ".local/share/brrm/partenza-session")
aLines = Split(sTest, gb.NewLine)
If aLines.Count >= 1 And If aLines[0] = "brrm-partenza-session v1" Then
  For iEqui = 1 To aLines.Max
    aFields = Split(Trim$(aLines[iEqui]), "|")
    If aFields.Count < 2 Then Continue
    iNum = 0
    Try iNum = CInt(aFields[0])
    If iNum <= 0 Or iNum >= MAX_NUMERO Then Continue
    e = EnsureEntry(iNum)
    If aFields[1] <> "" Then Try e.Partenza = aFields[1]
  Next
Endif
TimerGrid.Start()
LoadHardwareConfig()
AlignInit()
End 

Public Sub TimerGrid_Timer()
' Guard: ricontrolla header e riapplica se Message dialog l'ha resettato.
If GridView1[0, 0].Background <> &H000000& Then SetupGridHeader()
Dim e As CEntry
Dim concorrente As Integer
Dim sDisplay As String
Dim indice As Integer
Dim totale As Integer
Dim Counter As Integer
totale = 0
indice = 0
sDisplay = ""
totale = $entries.Count
Counter = 0
GridView1.Rows.Count = totale + 1
While Counter < totale 
e = $entries[Counter]
concorrente = e.Numero
GridView1[Counter + 1, 0].Text = concorrente
' Nessuna auto-rimozione: le entry vuote restano in lista (rimozione
' esplicita dalla schermata Modifica ordine).
If e.Partenza <> 0 Then
sDisplay = MTime.FormatDateMs(e.Partenza)
Else
sDisplay = ""
Endif

Try GridView1[Counter + 1, 1].Text = sDisplay
indice = indice + 1
Counter = Counter + 1
Wend
End

Public Sub ButtonReset_Click()
  ' RESET locale-only: NON propaga via sync. Razionale: il reset in
  ' partenza si fa tipicamente a inizio gara o per correggere errori di
  ' setup; non vogliamo cancellare anche gli arrivi gia' acquisiti su
  ' brrm/arrivo. Ogni postazione gestisce il proprio reset.
  If Message.Question("Sei sicuro?", "Sì", "No") <> 1 Then Return
  If Message.Question("Sei DAVVERO sicuro??? Poi non pentirti eh, non puoi più annullare ciò che stai per fare!", "Sì, dai non rompere e fammi resettare!!!", "No no!!! Argh, cosa stavo per fare! Per fortuna mi hai avvertito!") <> 1 Then Return
  TimerGrid.Stop
  $entries.Clear
  UpgradeSessionFile()
  TimerGrid.Start
  Try MLog.Write("reset", "")
End

Public Sub EditOrder(Order As String)
  
  Dim aOrdine As String[]
  Dim oldEntries As CEntry[]
  Dim sNum As String
  Dim iNum As Integer
  Dim j As Integer
  Dim e As CEntry
  TimerGrid.Stop
  ' Ricostruisce la lista nell'ordine dato PRESERVANDO le entry (e quindi gli
  ' orari) degli equipaggi ancora presenti; gli altri vengono scartati.
  oldEntries = $entries
  $entries = New CEntry[]
  aOrdine = Split(Order, "-")
  GridView1.Rows.Count = aOrdine.Count + 1
  For Each sNum In aOrdine
    iNum = 0
    Try iNum = CInt(Trim$(sNum))
    If iNum <= 0 Or iNum >= MAX_NUMERO Then Continue
    If FindIndex(iNum) >= 0 Then Continue
    e = Null
    For j = 0 To oldEntries.Max
      If oldEntries[j].Numero = iNum Then
        e = oldEntries[j]
        Break
      Endif
    Next
    If e = Null Then
      e = New CEntry
      e.Numero = iNum
    Endif
    $entries.Add(e)
  Next
  UpgradeSessionFile()
  TimerGrid.Start
  Try MLog.Write("modifica_ordine", "ordine=" & Order)
End

Public Sub ButtonEsporta_Click()
  ' Export CSV partenze:
  '   numero,partenza_hh,partenza_mm,partenza_ss,partenza_ms,partenza_unix_ms
  ' Stesso schema dei campi inviati a Google Sheets. Tutto int puro (niente
  ' CStr di Date che truncherebbe i ms).
  Dim Counter As Integer
  Dim e As CEntry
  Dim iEqui As Integer
  Dim tPart As Date
  Dim iMillis As Integer
  Dim sOut As String
  Dim sPath As String

  sOut = "numero,partenza_hh,partenza_mm,partenza_ss,partenza_ms,partenza_unix_ms\n"

  For Counter = 0 To $entries.Max
    e = $entries[Counter]
    iEqui = e.Numero
    If iEqui = 0 Then Continue
    If e.Partenza = 0 Then Continue
    tPart = e.Partenza
    iMillis = MTime.MillisOf(tPart)
    sOut = sOut & iEqui & "," & Hour(tPart) & "," & Minute(tPart) & "," & Second(tPart) & "," & Format$(iMillis, "000") & "," & MTime.DateToUnixMs(tPart) & "\n"
  Next

  Dialog.Title = "Salva orari partenza"
  Dialog.Filter = ["*.csv", "File CSV"]
  Dialog.Path = User.Home &/ "brrm-partenze.csv"
  If Dialog.SaveFile() Then Return
  sPath = Dialog.Path
  If LCase$(File.Ext(sPath)) <> "csv" Then sPath = sPath & ".csv"
  Try File.Save(sPath, sOut)
  If Error Then
    Message.Error("Impossibile salvare il file: " & Error.Text)
    Try MLog.Write("esporta_errore", "path=" & sPath & " errore=" & Error.Text)
  Else
    Try MLog.Write("esporta", "path=" & sPath & " righe=" & CStr($entries.Count))
  Endif
End

Public Sub GridView1_Click()
  If GridView1.Row > 0 Then
  If CurrAct = ACT_ANNPART Then
  If Message.Question("Sei sicuro di voler annullare la partenza dell'equipaggio numero " & EntryNumeroAt(GridView1.Row - 1) & "?", "Sì", "No") = 1 Then
  TimerGrid.Stop
  Dim iAnnNum As Integer = EntryNumeroAt(GridView1.Row - 1)
  Try MLog.Write("annulla_partenza", "numero=" & CStr(iAnnNum) & " orario_prec=" & MLog.FmtTime(PartenzaOf(iAnnNum)))
  ClearPartenza(iAnnNum)
  AlignEnqueue(iAnnNum, 0)
  Endif
    GridView1.Background = &H0FFFFFF&
  GridView1.Mouse = 0
  CurrAct = ACT_NONE
  TimerGrid.Start
  End If

  If CurrAct = ACT_MODNUM Then
    Dim iOld As Integer
    Dim sNew As String
    Dim iNew As Integer
    iOld = EntryNumeroAt(GridView1.Row - 1)
    If PartenzaOf(iOld) = 0 Then
      Message.Error("L'equipaggio " & iOld & " non ha un orario di partenza da spostare.")
    Else
      TimerGrid.Stop
      sNew = InputBox("Nuovo numero per l'equipaggio " & iOld & " (partenza " & PartenzaOf(iOld) & "):", "Cambia numero")
      If sNew <> "" Then
        iNew = 0
        Try iNew = CInt(Trim$(sNew))
        If iNew <= 0 Or iNew >= MAX_NUMERO Then
          Message.Error("Numero non valido. Deve essere fra 1 e 9999.")
        Else If iNew = iOld Then
          ' no-op
        Else If HasEntry(iNew) Then
          Message.Error("L'equipaggio " & iNew & " esiste già: non posso assegnare lo stesso numero a due partenze.")
        Else
          ChangeNumero(iOld, iNew)
        Endif
      Endif
      TimerGrid.Start
    Endif
    GridView1.Background = &H0FFFFFF&
    GridView1.Mouse = 0
    CurrAct = ACT_NONE
  End If

  If CurrAct = ACT_INVPART2 Then
    INV2 = EntryNumeroAt(GridView1.Row - 1)
    If INV2 = INV1 Then
      Message.Error("Non posso invertire un equipaggio con se stesso.")
    Else If Message.Question("Sei sicuro di voler invertire le partenze degli equipaggi " & INV1 & " e " & INV2 & "?", "Sì", "No") = 1 Then
      TimerGrid.Stop
      InvertiPartenze(INV1, INV2)
      TimerGrid.Start
    Endif
    GridView1.Background = &H0FFFFFF&
    GridView1.Mouse = 0
    CurrAct = ACT_NONE
  End If

  If CurrAct = ACT_INVPART1 Then
    INV1 = EntryNumeroAt(GridView1.Row - 1)
    CurrAct = ACT_INVPART2
    GridView1.Background = &H007FFFFF&
    GridView1.Mouse = 2
  End If

Endif
UpgradeSessionFile()
End

Public Sub ButtonAnnullaPart_Click()

If CurrAct = ACT_ANNPART Then
  GridView1.Background = &H0FFFFFF&
  GridView1.Mouse = 0
  CurrAct = ACT_NONE
  Else
CurrAct = ACT_ANNPART
GridView1.Background = &H00FFFF7F&
GridView1.Mouse = 2
End If
End

Public Sub ButtonChangeNum_Click()
  ' Toggle: clicco di nuovo per annullare il "pick row" pendente.
  If CurrAct = ACT_MODNUM Then
    GridView1.Background = &H0FFFFFF&
    GridView1.Mouse = 0
    CurrAct = ACT_NONE
  Else
    CurrAct = ACT_MODNUM
    GridView1.Background = &H00FFFF7F&
    GridView1.Mouse = 2
  Endif
End

Public Sub ButtonInvert_Click()
  ' Toggle: clic ulteriore (in qualsiasi fase invpart1/invpart2) annulla.
  If CurrAct = ACT_INVPART1 Or CurrAct = ACT_INVPART2 Then
    GridView1.Background = &H0FFFFFF&
    GridView1.Mouse = 0
    CurrAct = ACT_NONE
  Else
    CurrAct = ACT_INVPART1
    GridView1.Background = &H00FFFF7F&
    GridView1.Mouse = 2
  Endif
End

Public Sub ButtonOrdine_Click()
  FOrdine.Show
End

Public Sub ButtonSettings_Click()
  FSettings.Show
End

Private Sub ChangeNumero(oldNum As Integer, newNum As Integer)
  ' Sostituisce oldNum → newNum preservando l'orario di partenza e la posizione
  ' nella lista equipaggi. Sync: invia annullamento per oldNum + nuovo per newNum.
  Dim e As CEntry
  Dim dPart As Date
  e = FindEntry(oldNum)
  If e = Null Then Return
  dPart = e.Partenza
  ' Rinomina sul posto: l'oggetto (col suo orario e la sua posizione) resta.
  e.Numero = newNum
  UpgradeSessionFile()
  AlignEnqueue(oldNum, 0)
  AlignEnqueue(newNum, dPart)
  Try MLog.Write("cambia_numero", "old=" & CStr(oldNum) & " new=" & CStr(newNum) & " orario=" & MLog.FmtTime(dPart))
End

Private Sub InvertiPartenze(n1 As Integer, n2 As Integer)
  ' Scambia gli orari di partenza fra due equipaggi. I numeri restano.
  Dim e1 As CEntry
  Dim e2 As CEntry
  Dim pt1 As Date
  Dim pt2 As Date
  e1 = FindEntry(n1)
  e2 = FindEntry(n2)
  If e1 = Null Or e2 = Null Then Return
  pt1 = e1.Partenza
  pt2 = e2.Partenza
  e1.Partenza = pt2
  e2.Partenza = pt1
  UpgradeSessionFile()
  Try MLog.Write("inverti_partenze", "n1=" & CStr(n1) & " orario1_prec=" & MLog.FmtTime(pt1) & " n2=" & CStr(n2) & " orario2_prec=" & MLog.FmtTime(pt2))
  AlignEnqueue(n1, pt2)
  AlignEnqueue(n2, pt1)
End
  

Public Sub ButtonFotON_Click()
  FotON = True
  TimerBlink.Stop
  ButtonFotOFF.Background = &HFFFFFF&
  ButtonFotON.Background = &H00FF00&
  Try MLog.Write("foto_toggle", "stato=ON")
End

Public Sub ButtonFotOFF_Click()
  FotON = False
  ButtonFotOFF.Background = &HFF0000&
  ButtonFotON.Background = &HFFFFFF&
  TimerBlink.Start
  Try MLog.Write("foto_toggle", "stato=OFF")
End

Public Sub TimerBlink_Timer()

  If ButtonFotOFF.Background = &HFF0000& Then 
  ButtonFotOFF.Background = &HFFFFFF&
  Else 
  ButtonFotOFF.Background = &HFF0000&
  Endif 
  

End

Public Sub ButtonPartenza_Click()
  Dim sNow As String = Format$(Time, "hh:nn:ss.uuu")
  BPartenze.Add(sNow)
  Try MLog.Write("fotocellula", "source=bottone orario=" & sNow)
End

Public Sub TimerPartenzaQueue_Timer()

  If FPartenza.Visible = False And BPartenze.Count > 0 And CurrAct = ACT_NONE Then 
  FPartenza.Show
  FPartenza.setOrario(BPartenze[0].Text)
  BPartenze.Remove(0)
  Endif  

End

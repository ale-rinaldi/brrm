  If Button8.Background = &HFF0000& Then 
  Button8.Background = &HFFFFFF&
  Else 
  Button8.Background = &HFF0000&
  Endif 
  

End

Public Sub Button9_Click()

BArrivi.Add(Format$(Time, "hh:nn:ss.uuu"))

End

Public Sub SetArrivo(Numero As Integer, Orario As Date) 

Timer1.Stop
arrivi[Numero] = Orario
Timer1.Start
  UpgradeSessionFile()
  
End 

Public Sub Timer3_Timer()

  If FArrivo.Visible = False And BArrivi.Count > 0 And FPartenza.Visible = False And CurrAct = ACT_NONE Then 
  FArrivo.Show
  FArrivo.setOrario(BArrivi[0].Text)
  BArrivi.Remove(0)
  Endif  

End

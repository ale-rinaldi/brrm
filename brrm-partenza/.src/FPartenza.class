' Gambas class file


PUBLIC SUB Form_Open()

  Label1.Text = ""
  FPartenza.Center()

END

PUBLIC SUB setOrario(Orario AS String)
  
  Label1.Text = Orario
  
END

PUBLIC SUB Label1_MouseDown()

  

END

PUBLIC SUB Button1_Click()

DIM Numero AS Integer
DIM Confermato AS Boolean
Confermato = FALSE
Numero = 0
TRY Numero = TextBox1.Text
IF Numero > 0 AND Numero < 10000 THEN 
IF FMain.ReturnPartenza(Numero) <> 0 THEN 
IF Message.Question("L'equipaggio " & Numero & " risulta essere già partito! Si desidera sostituire il suo orario di partenza con questo?", "Sì", "No") = 1 THEN
Confermato = TRUE
ENDIF 
ELSE 
Confermato = TRUE
ENDIF 
IF Confermato = TRUE THEN
FMain.SetPartenza(Numero, Label1.Text)
Try MLog.Write("partenza", "numero=" & CStr(Numero) & " orario=" & Label1.Text)
FPartenza.Close
ENDIF
ELSE
Message("Numero non riconosciuto!")
Try MLog.Write("partenza_numero_invalido", "input=" & TextBox1.Text & " orario=" & Label1.Text)
ENDIF
END

PUBLIC SUB Button2_Click()
  If FMain.ConfermaScartoOrario("partenza") Then
    Try MLog.Write("scarto_orario", "tipo=partenza orario=" & Label1.Text)
    FPartenza.Close
  Endif
END

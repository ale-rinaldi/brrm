' MInstance — istanza unica per postazione. All'avvio, se un'altra istanza
' della STESSA app e' ancora viva, la termina (SIGTERM, poi SIGKILL se resiste)
' e ne attende la morte, cosi' la porta seriale viene rilasciata dal kernel
' prima che la riapriamo. Poi registra il proprio PID in un pidfile.
'
' Rinforzo contro le chiusure non pulite: se una vecchia istanza fosse rimasta
' appesa tenendo occupata la seriale, la nuova la elimina senza intervento
' manuale (niente piu' killall gbr3).
'
' Source-of-truth symlinkata nei due progetti: SOLO funzioni Public (bug Gambas
' 3.20 sulle Private nei moduli symlinkati).

Public Function PidPath(sName As String) As String
  Return User.Home &/ ".local/share/brrm" &/ sName & ".pid"
End

Public Function SelfPid() As Integer
  ' PID del processo corrente: primo campo di /proc/self/stat.
  Dim s As String
  s = ""
  Try s = File.Load("/proc/self/stat")
  If s = "" Then Return 0
  Return CInt(Trim$(Split(s, " ")[0]))
End

Public Function IsAlive(pid As Integer) As Boolean
  If pid <= 0 Then Return False
  Return Exist("/proc/" & CStr(pid))
End

Public Function CmdlineOf(pid As Integer) As String
  ' /proc/<pid>/cmdline, argomenti separati da NUL -> spazi.
  Dim s As String
  Dim p As String
  s = ""
  p = "/proc/" & CStr(pid) & "/cmdline"
  If Not Exist(p) Then Return ""
  Try s = File.Load(p)
  Return Replace(s, Chr(0), " ")
End

Public Sub Ensure(sName As String, sExe As String)
  ' sName: nome del pidfile (es. "arrivo"). sExe: stringa che identifica la
  ' nostra app nella cmdline (es. "brrm.gambas"), per NON uccidere un processo
  ' che avesse riusato il PID di un'istanza morta senza pulizia (fail-safe:
  ' se non combacia, non si tocca nulla).
  Dim sPath As String
  Dim iSelf As Integer
  Dim iOld As Integer
  Dim i As Integer
  sPath = PidPath(sName)
  iSelf = SelfPid()
  If Exist(sPath) Then
    iOld = 0
    Try iOld = CInt(Trim$(File.Load(sPath)))
    If iOld > 0 And If iOld <> iSelf And If IsAlive(iOld) And If InStr(CmdlineOf(iOld), sExe) > 0 Then
      Try MLog.Write("istanza_precedente", "pid=" & CStr(iOld) & " azione=term")
      Shell "kill -TERM " & CStr(iOld) & " 2>/dev/null" Wait
      For i = 1 To 10
        If Not IsAlive(iOld) Then Break
        Sleep 0.1
      Next
      If IsAlive(iOld) Then
        Try MLog.Write("istanza_precedente", "pid=" & CStr(iOld) & " azione=kill")
        Shell "kill -KILL " & CStr(iOld) & " 2>/dev/null" Wait
        For i = 1 To 10
          If Not IsAlive(iOld) Then Break
          Sleep 0.1
        Next
      Endif
      ' Lascia al kernel il tempo di rilasciare la porta seriale.
      Sleep 0.3
    Endif
  Endif
  If iSelf > 0 Then MFile.AtomicSave(sPath, CStr(iSelf))
End

Public Sub Release(sName As String)
  ' Rimuove il pidfile se contiene il NOSTRO PID (uscita pulita).
  Dim sPath As String
  Dim iOld As Integer
  sPath = PidPath(sName)
  If Not Exist(sPath) Then Return
  iOld = 0
  Try iOld = CInt(Trim$(File.Load(sPath)))
  If iOld = SelfPid() Then Try Kill sPath
End

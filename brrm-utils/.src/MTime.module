' MTime — funzioni di data/ora pure usate da brrm e brrm-partenza.
' Source-of-truth: gli altri progetti (brrm, brrm-partenza, brrm-utils
' test) puntano qui via symlink. Mai duplicare il codice.
'
' Tutte aritmetica intera, niente Float, niente dipendenza da fuso/locale
' tranne dove esplicitamente nominato (DateToUnixMs usa System.TimeZone).

Public Function MillisOf(d As Date) As Integer
  ' Frazione di secondo in millisecondi (0-999). Format$(d, "uuu")
  ' restituisce stringa vuota quando i ms sono 0 (verificato su 3.20 e
  ' su master), quindi CInt() su quel risultato lancia Type mismatch.
  ' Pre-controllo esplicito per non far esplodere il chiamante.
  Dim sMs As String = Format$(d, "uuu")
  If sMs = "" Then Return 0
  Return CInt(sMs)
End

Public Function MsInDay(d As Date) As Long
  ' Millisecondi trascorsi da mezzanotte locale, 0..86399999.
  Return Hour(d) * 3600000 + Minute(d) * 60000 + Second(d) * 1000 + MillisOf(d)
End

Public Function DaysFromEpoch(y As Long, m As Long, d As Long) As Long
  ' Howard Hinnant civil_to_days: giorni dal 1970-01-01. Int puro,
  ' esatto per qualsiasi data gregoriana (centenari compresi: 1900 e
  ' 2100 non bisestili, 2000 bisestile).
  Dim era, yoe, mAdj, doy, doe As Long
  If m <= 2 Then y = y - 1
  If y >= 0 Then era = y \ 400 Else era = (y - 399) \ 400
  yoe = y - era * 400
  If m > 2 Then mAdj = m - 3 Else mAdj = m + 9
  doy = (153 * mAdj + 2) \ 5 + d - 1
  doe = yoe * 365 + yoe \ 4 - yoe \ 100 + doy
  Return era * 146097 + doe - 719468
End

Public Function DateToUnixMs(d As Date) As Long
  ' Converte (data odierna + ora di d) in UNIX ms (UTC). Tutto int.
  ' System.TimeZone e' in secondi a ovest di UTC (POSIX): CEST = -7200,
  ' quindi UNIX_ms = local_ms + System.TimeZone * 1000 (l'addendo e'
  ' negativo per fusi a est, e ci porta dal locale all'UTC).
  '
  ' Cross-midnight: partenze/arrivi sono Date time-only. Se il time-of-day
  ' di `d` e' successivo a quello attuale, l'evento e' avvenuto IERI
  ' (assunzione gara < 24h). Sottraggo un giorno cosi' l'UNIX ms assoluto
  ' resta coerente con la durata calcolata via delta.
  Dim t As Date = Now
  Dim daysEpoch As Long = DaysFromEpoch(Year(t), Month(t), Day(t))
  Dim msEvent As Long = MsInDay(d)
  If msEvent > MsInDay(t) Then daysEpoch = daysEpoch - 1
  Return daysEpoch * 86400000 + msEvent + CLong(System.TimeZone) * 1000
End

Public Function FormatDateMs(d As Date) As String
  ' Serializzazione locale-indipendente di una Date che PRESERVA i ms.
  ' Sostituto totale di Str$(d): Str$ in Gambas 3 emette "hh:nn:ss" o
  ' "MM/dd/yyyy hh:nn:ss" ma sempre senza la parte frazionaria, quindi
  ' rompe ogni round-trip su orari con ms != 0 (sync partenza→arrivo,
  ' file di session locale, ecc.).
  '
  '   FormatDateMs(Time(10,23,45,678))           → "10:23:45.678"
  '   FormatDateMs(Time(10,23,45,0))             → "10:23:45.000"
  '   FormatDateMs(CDate("12/30/2026 10:00:00")) → "12/30/2026 10:00:00.000"
  '
  ' Mai usare Str$(date) nel codice di brrm/brrm-partenza: usare questa.
  Dim sMs As String = Format$(d, "uuu")
  If sMs = "" Then sMs = "000"
  If Date(d) = CDate(0) Then
    ' Time-only: niente parte data, replica il prefisso di Str$.
    Return Format$(d, "hh:nn:ss") & "." & sMs
  Else
    Return Format$(d, "mm/dd/yyyy hh:nn:ss") & "." & sMs
  Endif
End

Public Function ParseDateMs(s As String) As Date
  ' Inverso di FormatDateMs. Accetta sia "hh:nn:ss.uuu" che
  ' "MM/dd/yyyy hh:nn:ss.uuu" sia varianti senza ms (tolleranza).
  ' Ritorna CDate(0) se la stringa non e' parsabile, senza propagare
  ' l'errore del cast implicito.
  Dim result As Date = CDate(0)
  If s = "" Then Return result
  Try result = s
  Return result
End

Public Function PadMillis(s As String) As String
  ' Pad a stringa di 3 cifre (ms display: "5" -> "005", "12" -> "012",
  ' "1234" -> "123" troncato). Robusto a input vuoti o lunghi.
  Select Case Len(s)
    Case 0
      Return "000"
    Case 1
      Return s & "00"
    Case 2
      Return s & "0"
    Case 3
      Return s
    Case Else
      Return Left$(s, 3)
  End Select
End

Public Function ParseTimeFromCsvParts(sHh As String, sMm As String, sSs As String, sMs As String) As Date
  ' Costruisce una Date time-only "hh:nn:ss.uuu" a partire dai 4 campi
  ' "split" come compaiono nei CSV di brrm-partenza/brrm: ore, minuti,
  ' secondi (interi non-zero-padded, es. "8" non "08") e ms (string
  ' arbitraria, normalizzata via PadMillis). Ritorna CDate(0) se uno
  ' qualunque dei campi non e' parsabile o se la stringa risultante
  ' non e' una Date valida.
  Dim iHh As Integer = 0
  Dim iMm As Integer = 0
  Dim iSs As Integer = 0
  Try iHh = CInt(Trim$(sHh))
  Try iMm = CInt(Trim$(sMm))
  Try iSs = CInt(Trim$(sSs))
  Return ParseDateMs(Format$(iHh, "00") & ":" & Format$(iMm, "00") & ":" & Format$(iSs, "00") & "." & PadMillis(Trim$(sMs)))
End

Public Function CivilFromDays(days As Long) As Integer[]
  ' Inverso di DaysFromEpoch (Howard Hinnant civil_from_days). Int puro.
  ' days = giorni dal 1970-01-01. Ritorna [anno, mese, giorno].
  Dim z As Long = days + 719468
  Dim era As Long
  If z >= 0 Then era = z \ 146097 Else era = (z - 146096) \ 146097
  Dim doe As Long = z - era * 146097
  Dim yoe As Long = (doe - doe \ 1460 + doe \ 36524 - doe \ 146096) \ 365
  Dim y As Long = yoe + era * 400
  Dim doy As Long = doe - (365 * yoe + yoe \ 4 - yoe \ 100)
  Dim mp As Long = (5 * doy + 2) \ 153
  Dim d As Long = doy - (153 * mp + 2) \ 5 + 1
  Dim m As Long
  If mp < 10 Then m = mp + 3 Else m = mp - 9
  If m <= 2 Then y = y + 1
  Return [CInt(y), CInt(m), CInt(d)]
End

Public Function UnixMsToDateTZ(unixMs As Long, tzSec As Long) As Date
  ' Inverso di DateToUnixMs con fuso esplicito. tzSec = secondi a ovest
  ' di UTC (POSIX, come System.TimeZone): locale = UTC - tzSec.
  Dim localMs As Long = unixMs - tzSec * 1000
  Dim days As Long = localMs \ 86400000
  Dim msOfDay As Long = localMs Mod 86400000
  If msOfDay < 0 Then
    msOfDay = msOfDay + 86400000
    days = days - 1
  Endif
  Dim ymd As Integer[] = CivilFromDays(days)
  Dim hh As Integer = CInt(msOfDay \ 3600000)
  Dim mm As Integer = CInt((msOfDay \ 60000) Mod 60)
  Dim ss As Integer = CInt((msOfDay \ 1000) Mod 60)
  Dim uuu As Integer = CInt(msOfDay Mod 1000)
  Return Date(ymd[0], ymd[1], ymd[2], hh, mm, ss, uuu)
End

Public Function UnixMsToDate(unixMs As Long) As Date
  ' Wrapper col fuso di sistema corrente.
  Return UnixMsToDateTZ(unixMs, CLong(System.TimeZone))
End

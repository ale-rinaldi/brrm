' Test per MAlignSync — generazione monotona di session_id e parsing
' del file di state (session=N\nseq=M).
Public Sub RunAll()
  ' --- NextSessionId: monotonia robusta -------------------------------
  Dim iNow As Long = MTime.DateToUnixMs(Now)

  ' lastSession=0: ritorna il timestamp corrente (>= iNow).
  Dim iFresh As Long = MAlignSync.NextSessionId(0)
  Assert.Ok(iFresh >= iNow, "NextSessionId(0) >= now ms")
  Assert.Ok(iFresh < iNow + 1000, "NextSessionId(0) entro 1s da now")

  ' lastSession nel futuro: ritorna lastSession+1 (orologio indietro).
  Dim iFuture As Long = iNow + 86400000
  Dim iExpected As Long = iFuture + 1
  Assert.Equals(MAlignSync.NextSessionId(iFuture), iExpected, "NextSessionId con lastSession nel futuro: +1")

  ' lastSession vicino a now ma minore: ritorna now ms.
  Dim iPast As Long = iNow - 5000
  Dim iOut As Long = MAlignSync.NextSessionId(iPast)
  Assert.Ok(iOut >= iNow, "NextSessionId con lastSession nel passato: ritorna now")

  ' --- EncodeStateFile -----------------------------------------------
  Dim sEnc1 As String = "session=1734567890123" & gb.NewLine & "seq=42" & gb.NewLine
  Assert.Equals(MAlignSync.EncodeStateFile(1734567890123, 42), sEnc1, "EncodeStateFile produce due righe")
  Dim sEnc2 As String = "session=0" & gb.NewLine & "seq=0" & gb.NewLine
  Assert.Equals(MAlignSync.EncodeStateFile(0, 0), sEnc2, "EncodeStateFile con zeri")

  ' --- DecodeStateFile ------------------------------------------------
  ' DecodeStateFile ritorna Long[]{session, seq} oppure Null se malformato.
  ' (ByRef non funziona su funzioni di modulo in Gambas 3; Long[] e' il
  ' pattern idiomatico per valori multipli di ritorno.)
  Dim r As Long[]

  Dim sDec1 As String = "session=1734567890123" & gb.NewLine & "seq=42" & gb.NewLine
  r = MAlignSync.DecodeStateFile(sDec1)
  Assert.NotOk(r = Null, "DecodeStateFile due righe ok")
  Assert.Equals(r[0], 1734567890123, "DecodeStateFile: session parsata")
  Assert.Equals(r[1], 42, "DecodeStateFile: seq parsato")

  ' Tolleranza all'ordine delle righe
  Dim sDec2 As String = "seq=7" & gb.NewLine & "session=99" & gb.NewLine
  r = MAlignSync.DecodeStateFile(sDec2)
  Assert.NotOk(r = Null, "DecodeStateFile righe in ordine inverso ok")
  Assert.Equals(r[0], 99, "DecodeStateFile inverso: session")
  Assert.Equals(r[1], 7, "DecodeStateFile inverso: seq")

  ' Tolleranza a spazi/empty trailing newline mancante
  Dim sDec3 As String = "session=5" & gb.NewLine & "seq=3"
  r = MAlignSync.DecodeStateFile(sDec3)
  Assert.NotOk(r = Null, "DecodeStateFile senza newline finale")
  Assert.Equals(r[0], 5, "DecodeStateFile senza newline: session")
  Assert.Equals(r[1], 3, "DecodeStateFile senza newline: seq")

  ' Malformati: ritorna Null
  r = MAlignSync.DecodeStateFile("")
  Assert.Ok(r = Null, "DecodeStateFile: stringa vuota fallisce")

  Dim sDec4 As String = "session=abc" & gb.NewLine & "seq=1"
  r = MAlignSync.DecodeStateFile(sDec4)
  Assert.Ok(r = Null, "DecodeStateFile: session non numerica fallisce")

  r = MAlignSync.DecodeStateFile("session=1")
  Assert.Ok(r = Null, "DecodeStateFile: solo session senza seq fallisce")
End

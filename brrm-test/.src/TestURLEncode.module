' Test per CSheet.URLEncode — RFC 3986 unreserved [A-Za-z0-9-._~]
' passano, tutto il resto in %HH (esadecimale maiuscolo).
Public Sub RunAll()
  Dim s As New CSheet

  Assert.Equals(s.URLEncode(""), "", "empty")
  Assert.Equals(s.URLEncode("abcXYZ"), "abcXYZ", "ASCII alfanumerico passa")
  Assert.Equals(s.URLEncode("0123456789"), "0123456789", "cifre")
  Assert.Equals(s.URLEncode("-._~"), "-._~", "unreserved RFC 3986")

  Assert.Equals(s.URLEncode(" "),   "%20",   "spazio -> %20")
  Assert.Equals(s.URLEncode("/"),   "%2F",   "slash -> %2F")
  Assert.Equals(s.URLEncode("?"),   "%3F",   "question -> %3F")
  Assert.Equals(s.URLEncode("&"),   "%26",   "amp -> %26")
  Assert.Equals(s.URLEncode("="),   "%3D",   "equal -> %3D")
  Assert.Equals(s.URLEncode("+"),   "%2B",   "plus -> %2B (NON conservato)")
  Assert.Equals(s.URLEncode("%"),   "%25",   "percent -> %25 (double-encoding ok)")

  ' UTF-8 multibyte: 'à' = U+00E0 -> bytes C3 A0
  Assert.Equals(s.URLEncode("à"),   "%C3%A0", "UTF-8 'à' = %C3%A0")

  ' Esadecimale sempre maiuscolo
  Assert.Equals(s.URLEncode(Chr(255)), "%FF", "0xFF maiuscolo")

  ' JWT grant URN usato in brrm
  Dim grantEnc As String = s.URLEncode("urn:ietf:params:oauth:grant-type:jwt-bearer")
  Assert.Equals(grantEnc, "urn%3Aietf%3Aparams%3Aoauth%3Agrant-type%3Ajwt-bearer", "grant URN")

  Assert.Equals(s.URLEncode(Chr(0)),   "%00", "Chr(0) -> %00 (zero-padded)")
  Assert.Equals(s.URLEncode(Chr(1)),   "%01", "Chr(1) -> %01")
  Assert.Equals(s.URLEncode(Chr(15)),  "%0F", "Chr(15) -> %0F")
  Assert.Equals(s.URLEncode(Chr(127)), "%7F", "Chr(127) DEL -> %7F")
End

' Test per CSheet.JsonEscape. NOTA: la funzione attuale gestisce solo
' backslash, quote, LF e rimuove CR. Tab e altri control char < 0x20
' NON vengono escaped (gap noto rispetto a RFC 8259); per brrm i payload
' sono numerici e nomi-foglio senza control chars, quindi in pratica OK.
' I test riflettono il comportamento attuale; se in futuro espanderemo
' la copertura RFC, aggiornare anche qui.
Public Sub RunAll()
  Dim s As New CSheet

  Assert.Equals(s.JsonEscape(""), "", "empty")
  Assert.Equals(s.JsonEscape("abc"), "abc", "ascii pulito invariato")
  Assert.Equals(s.JsonEscape("Prova"), "Prova", "nome foglio tipico invariato")

  ' Backslash: 1 -> 2 (output e' Gambas string con 2 backslash effettivi)
  Assert.Equals(s.JsonEscape("\\"), "\\\\", "backslash raddoppiato")

  ' Quote -> backslash-quote
  Assert.Equals(s.JsonEscape(Chr(34)), "\\" & Chr(34), "double quote escaped")

  ' Newline -> letterali backslash+n
  Assert.Equals(s.JsonEscape(Chr(10)), "\\n", "LF -> \\n")

  ' CR rimosso del tutto (intenzionale)
  Assert.Equals(s.JsonEscape(Chr(13)), "", "CR rimosso")
  Assert.Equals(s.JsonEscape("a" & Chr(13) & Chr(10) & "b"), "a\\nb", "CRLF -> \\n")

  ' Combo realistica
  Assert.Equals(s.JsonEscape("a\"b"), "a\\" & Chr(34) & "b", "ascii + quote")


  ' Tab (Chr(9)): RFC 8259 richiede \\t; il codice attuale lo lascia raw.
  ' Atteso: se il test FALLA, e' un bug latente (in pratica brrm non passa
  ' mai tab a JsonEscape, ma vale la pena segnalarlo).

  Assert.Equals(s.JsonEscape("a" & Chr(8) & "b"), "a\\bb", "backspace -> \\b (RFC 8259)")
  Assert.Equals(s.JsonEscape("a" & Chr(12) & "b"), "a\\fb", "form-feed -> \\f")
  Assert.Equals(s.JsonEscape("a" & Chr(9) & "b"), "a\\tb", "tab -> \\t (RFC 8259)")
End

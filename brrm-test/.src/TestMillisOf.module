' Test per CSheet.MillisOf — estrazione dei millisecondi dalla parte
' frazionaria di un Date. Bug noto: Format$(d, "uuu") restituisce ""
' invece di "000" per d con 0 ms, e CInt("") lancia Type mismatch.
' Fixato dal commit "brrm/CSheet: fix MillisOf su orari con .000 ms".
Public Sub RunAll()
  Dim s As New CSheet

  Assert.Equals(s.MillisOf(Time(14, 35, 0, 0)),   0,   "MillisOf(.000) = 0  (regressione fix)")
  Assert.Equals(s.MillisOf(Time(14, 35, 0, 1)),   1,   "MillisOf(.001) = 1")
  Assert.Equals(s.MillisOf(Time(14, 35, 0, 10)),  10,  "MillisOf(.010) = 10")
  Assert.Equals(s.MillisOf(Time(14, 35, 0, 100)), 100, "MillisOf(.100) = 100")
  Assert.Equals(s.MillisOf(Time(14, 35, 0, 999)), 999, "MillisOf(.999) = 999")
  Assert.Equals(s.MillisOf(Time(0,  0,  0, 0)),   0,   "MillisOf midnight = 0")
  Assert.Equals(s.MillisOf(Time(23, 59, 59, 999)), 999, "MillisOf(23:59:59.999) = 999")

End
